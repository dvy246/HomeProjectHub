---
interface Props {
  formula: string;
  assumptions: string[];
  reviewed?: string;
}

const { formula, assumptions, reviewed = "Reviewed for calculation accuracy on July 2, 2026" } = Astro.props;
---

<aside class="rounded-xl border border-[var(--border)] bg-[var(--bg-subtle)] p-5 my-6 flex flex-col gap-6">
  <!-- Top Methodology Section -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--fg-muted)] mb-2">Formula</h3>
      <p class="font-mono text-xs leading-relaxed bg-[var(--bg)] border border-[var(--border)] rounded-lg p-3 text-[var(--fg-secondary)]">
        {formula}
      </p>
    </div>
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--fg-muted)] mb-2">Assumptions</h3>
      <ul class="flex flex-col gap-1.5 text-xs text-[var(--fg-secondary)] leading-relaxed">
        {assumptions.map((assumption) => <li>{assumption}</li>)}
      </ul>
    </div>
  </div>

  <!-- Reviewed and Disclaimer Footer -->
  <div class="flex flex-col gap-1.5 pt-1 border-t border-[var(--border)]">
    <p class="text-[10px] text-[var(--fg-muted)] leading-relaxed">
      {reviewed}. Estimates are for planning and purchasing checks only. Structural projects, code requirements, soil conditions, and load-bearing designs should be verified by a qualified local professional.
    </p>
  </div>
</aside>
