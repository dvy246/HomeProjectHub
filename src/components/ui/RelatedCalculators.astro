---
import type { RelatedLink } from "../../lib/relatedCalculators";
import { getRelatedCalculators } from "../../lib/relatedCalculators";

export interface Props {
  slug: string;
}

const { slug } = Astro.props;
const related = getRelatedCalculators(slug);
---

<section class="pt-8 mt-6 border-t border-[var(--border)]">
  <h3 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4 flex items-center gap-2">
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
    </svg>
    You Might Also Need
  </h3>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
    {related.map((link: RelatedLink) => (
      <a
        href={link.href}
        class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-3.5 hover:border-[var(--border-hover)] transition-all hover:shadow-sm group"
      >
        <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5 group-hover:text-[var(--accent)] transition-colors">{link.label}</span>
        <span class="text-[11px] text-[var(--fg-muted)] leading-normal">{link.description}</span>
      </a>
    ))}
  </div>
</section>
