---
interface Props {
  slotId: string;
  adClient?: string;
  className?: string;
}

const { slotId, adClient = "ca-pub-0000000000000000", className = "" } = Astro.props;
---

<div class={`ad-slot-wrapper w-full flex justify-center my-6 ${className}`} aria-hidden="true">
  <div
    class="ad-slot-container min-h-[120px] w-full max-w-[728px] rounded-lg overflow-hidden"
    data-ad-client={adClient}
    data-ad-slot={slotId}
  >
    <ins
      class="adsbygoogle block"
      style="display:block; min-height:120px;"
      data-ad-client={adClient}
      data-ad-slot={slotId}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
  </div>
</div>

<script>
  function setupLazyAdLoading() {
    const containers = document.querySelectorAll(".ad-slot-container:not([data-loaded])");
    if (!containers.length) return;

    const observerOptions = {
      root: null,
      rootMargin: "300px 0px",
      threshold: 0.01,
    };

    let scriptLoaded = false;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const container = entry.target;
          container.setAttribute("data-loaded", "true");

          if (!scriptLoaded) {
            const script = document.createElement("script");
            script.src = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${container.getAttribute("data-ad-client")}`;
            script.async = true;
            script.crossOrigin = "anonymous";
            document.head.appendChild(script);
            scriptLoaded = true;
          }

          try {
            (window.adsbygoogle = window.adsbygoogle || []).push({});
          } catch (e) {}

          observer.unobserve(container);
        }
      });
    }, observerOptions);

    containers.forEach((container) => {
      observer.observe(container);
    });
  }

  document.addEventListener("DOMContentLoaded", setupLazyAdLoading);
  setupLazyAdLoading();
</script>
