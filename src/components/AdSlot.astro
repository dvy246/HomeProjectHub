---
interface Props {
  slotId?: string;
  className?: string;
}
const { slotId = "ad-general", className = "" } = Astro.props;
---

<div class={`ad-container my-8 mx-auto flex flex-col items-center justify-center clear-both overflow-hidden no-print select-none ${className}`}>
  <!-- Label to prevent user confusion and accidental clicks -->
  <span class="text-[9px] uppercase font-mono tracking-widest text-[var(--fg-muted)] mb-2 block text-center select-none pointer-events-none opacity-60">
    Advertisement
  </span>
  
  <!-- Fixed/responsive min-height container to protect against CLS (Cumulative Layout Shift) -->
  <div 
    class="ad-slot bg-[var(--bg-inset)] border border-dashed border-[var(--border)] flex items-center justify-center text-center text-xs text-[var(--fg-muted)] font-mono rounded-xl transition-all w-full max-w-(--breakpoint-md)"
    style="min-height: 90px; content-visibility: auto;"
  >
    <!-- AdSense Auto/Manual Responsive Unit Placeholder -->
    <ins class="adsbygoogle"
         style="display:block; width:100%; min-height:90px;"
         data-ad-client="ca-pub-0000000000000000"
         data-ad-slot={slotId}
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
</div>
