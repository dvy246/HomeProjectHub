        { name: "Measure Room Square Footage from Photo Scale & Area Simulator", url: "/calculators/measure-from-photo/" },
        { name: "Free Online Stair Stringer Calculator & Layout Planner", url: "/calculators/stair-stringer-designer/" },
        { name: "DIY vs Pro Cost Splitter — Should You DIY or Hire a Contractor?", url: "/calculators/diy-vs-pro/" },
        { name: "Ready-Mix vs. Bagged Material Delivery Planner", url: "/calculators/bulk-vs-bagged/" },
        { name: "Room Renovation Budget Binder & Material Scope", url: "/plan/" }
      ];

      const setupSearch = (inputId, resultsId) => {
        const input = document.getElementById(inputId);
        const results = document.getElementById(resultsId);
        if (!input || !results) return;

        input.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase().trim();
          if (!query) {
            results.classList.add('hidden');
            results.innerHTML = '';
            return;
          }

          const filtered = UTILITIES.filter(item => item.name.toLowerCase().includes(query));
          if (filtered.length === 0) {
            results.innerHTML = '<div class="px-3 py-2 text-[var(--fg-muted)]">No utilities found</div>';
          } else {
            results.innerHTML = filtered.map(item => `
              <a href="${item.url}" class="block px-3 py-2 hover:bg-[var(--bg-muted)] text-[var(--fg-secondary)] hover:text-[var(--fg)] transition-colors font-medium">
                ${item.name}
              </a>
            `).join('');
          }
          results.classList.remove('hidden');
        });

        // Hide results when clicking outside
        document.addEventListener('click', (e) => {
          if (!input.contains(e.target) && !results.contains(e.target)) {
            results.classList.add('hidden');
          }
        });

        // Show results on focus if there is input
        input.addEventListener('focus', () => {
          if (input.value.trim()) {
            results.classList.remove('hidden');
          }
        });
      };

      setupSearch('search-input-desktop', 'search-results-desktop');
      setupSearch('search-input-mobile', 'search-results-mobile');

      const navToggle = document.getElementById('mobile-nav-toggle');
      const navMenu = document.getElementById('mobile-nav');
      if (navToggle && navMenu) {
        const toggleMobile = () => {
          const isOpen = !navMenu.classList.contains('hidden');
          if (isOpen) {
            navMenu.classList.add('hidden');
            navToggle.setAttribute('aria-expanded', 'false');
            navToggle.setAttribute('aria-label', 'Open menu');
          } else {
            navMenu.classList.remove('hidden');
            navToggle.setAttribute('aria-expanded', 'true');
            navToggle.setAttribute('aria-label', 'Close menu');
          }
        };
        navToggle.addEventListener('click', toggleMobile);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !navMenu.classList.contains('hidden')) {
            navMenu.classList.add('hidden');
            navToggle.setAttribute('aria-expanded', 'false');
            navToggle.setAttribute('aria-label', 'Open menu');
            navToggle.focus();
          }
        });
      }

      // Dropdown accessibility logic
      const setupDropdown = (btnId) => {
        const btn = document.getElementById(btnId);
        const parent = btn ? btn.parentElement : null;
        if (!btn || !parent) return;

        const menu = parent.querySelector('[role="menu"]');
        const menuItems = Array.from(parent.querySelectorAll('a[role="menuitem"]'));
        if (!menu) return;

        const setOpen = (open) => {
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          if (open) {
            menu.classList.remove('opacity-0', 'invisible');
            menu.classList.add('opacity-100', 'visible');
          } else {
            menu.classList.remove('opacity-100', 'visible');
            menu.classList.add('opacity-0', 'invisible');
          }
        };

        // Click to toggle
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = btn.getAttribute('aria-expanded') === 'true';
          setOpen(!isOpen);
        });

        // Hover events
        parent.addEventListener('mouseenter', () => setOpen(true));
        parent.addEventListener('mouseleave', () => setOpen(false));

        // Focus events
        parent.addEventListener('focusin', () => setOpen(true));
        parent.addEventListener('focusout', (e) => {
          if (!parent.contains(e.relatedTarget)) {
            setOpen(false);
          }
        });

        // Keyboard navigation
        parent.addEventListener('keydown', (e) => {
          const isOpen = btn.getAttribute('aria-expanded') === 'true';

          if (e.key === 'Escape') {
            setOpen(false);
            btn.focus();
            e.preventDefault();
            return;
          }

          if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (!isOpen) {
              setOpen(true);
              if (menuItems.length > 0) menuItems[0].focus();
            } else {
              const activeIndex = menuItems.indexOf(document.activeElement);
              const nextIndex = (activeIndex + 1) % menuItems.length;
              menuItems[nextIndex].focus();
            }
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (isOpen) {
              const activeIndex = menuItems.indexOf(document.activeElement);
              const prevIndex = activeIndex <= 0 ? menuItems.length - 1 : activeIndex - 1;
              menuItems[prevIndex].focus();
            }
          } else if (e.key === 'Home') {
            if (isOpen && menuItems.length > 0) {
              e.preventDefault();
              menuItems[0].focus();
            }
          } else if (e.key === 'End') {
            if (isOpen && menuItems.length > 0) {
              e.preventDefault();
              menuItems[menuItems.length - 1].focus();
            }
          }
        });
      };

      setupDropdown('calc-dropdown-btn');
      setupDropdown('designers-dropdown-btn');
    </script>


    {Astro.url.pathname.startsWith('/calculators/') && Astro.url.pathname !== '/calculators/' && Astro.url.pathname !== '/calculators' && (
      <button
        type="button"
        onclick="window.print()"
        class="no-print fixed bottom-6 right-6 z-50 flex items-center gap-1.5 px-4 py-2.5 bg-[var(--accent)] hover:bg-[var(--accent-hover)] text-white text-xs font-semibold rounded-full shadow-lg transition-all duration-200 hover:scale-105 active:scale-95 cursor-pointer"
        aria-label="Print or save estimate as PDF"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        <span>Print Estimate</span>
      </button>
    )}
  </body>
</html>
