---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
  articlePubDate?: Date;
  articleUpdatedDate?: Date;
}

const { title, description, canonical, schema, noindex, articlePubDate, articleUpdatedDate } = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site || "https://homeplanninghub.com").toString();

const SUPPORTED_LOCALES = ['en', 'es', 'de', 'pt', 'pl', 'it'] as const;
const LOCALE_NAMES: Record<string, string> = { en: '🇺🇸 English', es: '🇪🇸 Español', de: '🇩🇪 Deutsch', pt: '🇵🇹 Português', pl: '🇵🇱 Polski', it: '🇮🇹 Italiano' };
const LOCALE_FLAGS: Record<string, string> = { en: '🇺🇸', es: '🇪🇸', de: '🇩🇪', pt: '🇵🇹', pl: '🇵🇱', it: '🇮🇹' };
const currentPathRaw = Astro.url.pathname;
const currentLocale = SUPPORTED_LOCALES.find(l => currentPathRaw.startsWith(`/${l}/`) || currentPathRaw === `/${l}`) || 'en';
const pathWithoutLocale = currentLocale === 'en' ? currentPathRaw : currentPathRaw.replace(/^\/[a-z]{2}/, '') || '/';
const ogImage = new URL("/og-image.png", canonicalURL).toString();
const currentPath = Astro.url.pathname;
const lUrl = (path: string) => {
  if (currentLocale === 'en') return path;
  if (path === '/') return `/${currentLocale}/`;
  return `/${currentLocale}${path}`;
};
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://homeplanninghub.com/#organization",
  name: "HomePlanningHub",
  url: "https://homeplanninghub.com",
  logo: "https://homeplanninghub.com/og-image.png",
  description: "Free home improvement planning calculators and project estimating guides for homeowners and DIY builders.",
  foundingDate: "2026",
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: "support@homeplanninghub.com",
    areaServed: "US",
    availableLanguage: "English",
  },
};
---

<!doctype html>
<html lang={currentLocale} class="scroll-smooth" style="color-scheme: light dark;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-title" content="HomePlanningHub" />
    <meta name="application-name" content="HomePlanningHub" />
    <meta name="author" content="HomePlanningHub Team" />
    <meta name="language" content="English" />
    <meta name="country" content="US" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    {import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION} />
    )}
    {import.meta.env.PROD && (
      <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://pagead2.googlesyndication.com https://www.googletagmanager.com; img-src 'self' https: data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self'; frame-src 'self' https://pagead2.googlesyndication.com; object-src 'none'; base-uri 'self'; form-action 'self' https://formspree.io; upgrade-insecure-requests" />
    )}

    <script is:inline>
      (function() {
        const supported = ['en', 'es', 'de', 'pt', 'pl', 'it'];
        const currentPath = window.location.pathname;
        let currentLocale = 'en';
        for (const l of supported) {
          if (currentPath.startsWith('/' + l + '/') || currentPath === '/' + l) {
            currentLocale = l;
            break;
          }
        }
        const pathWithoutLocale = currentLocale === 'en' ? currentPath : currentPath.replace(/^\/[a-z]{2}/, '') || '/';
        const supportedPaths = [
          '/', '/about/', '/contact/', '/strategy/', '/guides/', '/compare/', '/quizzes/', 
          '/privacy/', '/terms/', '/disclaimer/', '/maintenance/', '/maintenance/planner/', 
          '/maintenance/calendar/', '/maintenance/cost-estimator/', '/maintenance/spring/', 
          '/maintenance/summer/', '/maintenance/fall/', '/maintenance/winter/', 
          '/maintenance/first-time-homeowner/', '/calculators/'
        ];
        const isSupportedPage = supportedPaths.includes(pathWithoutLocale);
        if (isSupportedPage) {
          const preferred = localStorage.getItem('preferred-locale');
          if (preferred && preferred !== currentLocale && supported.includes(preferred)) {
            const targetUrl = preferred === 'en' ? (pathWithoutLocale === '' ? '/' : pathWithoutLocale) : '/' + preferred + (pathWithoutLocale === '/' ? '/' : pathWithoutLocale);
            window.location.replace(targetUrl);
          }
        }
      })();
    </script>

    <title>{title} | HomePlanningHub</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:type" content={articlePubDate ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | HomePlanningHub`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="HomePlanningHub — free home improvement calculators and project planning tools" />
    <meta property="og:site_name" content="HomePlanningHub" />
    <meta property="og:locale" content={currentLocale === 'en' ? 'en_US' : currentLocale === 'es' ? 'es_ES' : currentLocale === 'de' ? 'de_DE' : currentLocale === 'pt' ? 'pt_PT' : currentLocale === 'pl' ? 'pl_PL' : currentLocale === 'it' ? 'it_IT' : 'en_US'} />
    {articlePubDate && <meta property="article:published_time" content={articlePubDate.toISOString()} />}
    {articleUpdatedDate && <meta property="article:modified_time" content={articleUpdatedDate.toISOString()} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`${title} | HomePlanningHub`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="HomePlanningHub — free home improvement calculators and project planning tools" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
    <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    {/* Organization schema for EEAT */}
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    {import.meta.env.PUBLIC_GA_ID && import.meta.env.PUBLIC_GA_ID !== 'G-XXXXXXXXXX' && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`} />
        <script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${import.meta.env.PUBLIC_GA_ID}');`} />
      </>
    )}

    <!-- Dark mode init — runs before paint to prevent flash -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var system = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && system)) {
            document.documentElement.classList.add('dark');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Skip link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-black focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold focus:shadow-lg">
      Skip to content
    </a>

    <!-- Header -->
    <header class="sticky top-0 z-50 w-full border-b border-[var(--border)] bg-[var(--bg)]/80 backdrop-blur-xl">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group" aria-label="HomePlanningHub home">
          <svg class="w-7 h-7 text-[var(--fg)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 12L12 3l9 9M5 10v10h14V10" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M9 20v-6h6v6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="font-bold text-[15px] tracking-tight">HomePlanningHub</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
          <a href={lUrl("/calculators/concrete/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/concrete") ? "page" : undefined}>Concrete</a>
          <a href={lUrl("/calculators/roofing/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/roofing") ? "page" : undefined}>Roofing</a>
          <a href={lUrl("/calculators/paint/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/paint") ? "page" : undefined}>Paint</a>
          <a href={lUrl("/calculators/tile/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/tile") ? "page" : undefined}>Tile</a>
          <a href={lUrl("/maintenance/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/maintenance") ? "page" : undefined}>Maintenance</a>
          <a href={lUrl("/compare/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/compare") ? "page" : undefined}>Compare</a>
          <a href={lUrl("/guides/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/guides") ? "page" : undefined}>Guides</a>
          <a href={lUrl("/projects/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/projects") ? "page" : undefined}>My Projects</a>
          <a href={lUrl("/saved/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath === "/saved/" ? "page" : undefined}>Saved</a>
          <a href={lUrl("/about/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath === "/about/" ? "page" : undefined}>About</a>
          <a href={lUrl("/contact/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath === "/contact/" ? "page" : undefined}>Contact</a>
        </nav>

        <div class="flex items-center gap-1">
          <!-- Language switcher -->
          <div class="relative group">
            <button
              type="button"
              class="flex items-center gap-1 px-2 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors"
              aria-label="Select language"
              aria-haspopup="true"
              aria-expanded="false"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M2 12h20" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
              </svg>
              <span class="hidden sm:inline">{LOCALE_FLAGS[currentLocale]} {currentLocale.toUpperCase()}</span>
            </button>
            <div class="absolute right-0 top-full mt-1 w-36 rounded-xl border border-[var(--border)] bg-[var(--bg)] shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible focus-within:opacity-100 focus-within:visible transition-all duration-150 z-50" role="menu">
              <div class="py-1">
                {SUPPORTED_LOCALES.map(locale => {
                  const href = locale === 'en' ? pathWithoutLocale || '/' : `/${locale}${pathWithoutLocale}`;
                  return (
                    <a
                      href={href}
                      role="menuitem"
                      class={`locale-link block px-3 py-2 text-xs font-medium transition-colors ${locale === currentLocale ? 'text-[var(--accent)] bg-[var(--bg-muted)]' : 'text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)]'}`}
                      hreflang={locale}
                      data-locale={locale}
                    >
                      {LOCALE_NAMES[locale]}
                    </a>
                  );
                })}
              </div>
            </div>
          </div>

          <!-- Dark mode toggle -->
          <button
            type="button"
            id="theme-toggle"
            class="flex items-center justify-center w-9 h-9 rounded-md border border-[var(--border)] hover:bg-[var(--bg-muted)] transition-colors"
            aria-label="Toggle dark mode"
          >
            <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            <svg class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
          </button>

          <!-- Mobile nav toggle -->
          <button
            type="button"
            id="mobile-nav-toggle"
            class="lg:hidden flex items-center justify-center w-9 h-9 rounded-md border border-[var(--border)] hover:bg-[var(--bg-muted)] transition-colors"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-nav"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Nav -->
      <nav id="mobile-nav" class="hidden lg:hidden border-t border-[var(--border)] bg-[var(--bg)]" aria-label="Mobile navigation">
        <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-0.5">
          <a href={lUrl("/calculators/concrete/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/calculators/concrete") ? "page" : undefined}>Concrete</a>
          <a href={lUrl("/calculators/roofing/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/calculators/roofing") ? "page" : undefined}>Roofing</a>
          <a href={lUrl("/calculators/paint/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/calculators/paint") ? "page" : undefined}>Paint</a>
          <a href={lUrl("/calculators/tile/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/calculators/tile") ? "page" : undefined}>Tile</a>
          <a href={lUrl("/maintenance/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/maintenance") ? "page" : undefined}>Maintenance</a>
          <a href={lUrl("/compare/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/compare") ? "page" : undefined}>Compare</a>
          <a href={lUrl("/guides/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/guides") ? "page" : undefined}>Guides</a>
          <a href={lUrl("/projects/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/projects") ? "page" : undefined}>My Projects</a>
          <a href={lUrl("/saved/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath === "/saved/" ? "page" : undefined}>Saved</a>
          <a href={lUrl("/about/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath === "/about/" ? "page" : undefined}>About</a>
          <a href={lUrl("/contact/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath === "/contact/" ? "page" : undefined}>Contact</a>
          <div class="border-t border-[var(--border)] mt-2 pt-2 flex gap-4 px-3">
            <a href={lUrl("/privacy/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Privacy</a>
            <a href={lUrl("/terms/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Terms</a>
          </div>
        </div>
      </nav>
    </header>

    <main id="main-content" class="flex-grow w-full max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[var(--border)] bg-[var(--bg-subtle)] mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
          <div class="col-span-2">
            <a href="/" class="flex items-center gap-2.5 mb-3">
              <svg class="w-6 h-6 text-[var(--fg)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M3 12L12 3l9 9M5 10v10h14V10" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M9 20v-6h6v6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="font-bold text-sm tracking-tight">HomePlanningHub</span>
            </a>
            <p class="text-xs text-[var(--fg-muted)] leading-relaxed max-w-xs text-pretty">
              Free, precise construction calculators for homeowners and DIY builders. No sign-up, no tracking, no nonsense.
            </p>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">Calculators</h4>
            <ul class="flex flex-col gap-2">
              <li><a href={lUrl("/calculators/concrete/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Concrete</a></li>
              <li><a href={lUrl("/calculators/roofing/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Roofing</a></li>
              <li><a href={lUrl("/calculators/paint/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Paint</a></li>
              <li><a href={lUrl("/calculators/tile/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Tile</a></li>
              <li><a href={lUrl("/maintenance/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Maintenance</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">Planning</h4>
            <ul class="flex flex-col gap-2">
              <li><a href={lUrl("/strategy/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Strategy Guide</a></li>
              <li><a href={lUrl("/projects/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">My Projects</a></li>
              <li><a href={lUrl("/guides/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Planning Guides</a></li>
              <li><a href={lUrl("/compare/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Compare Materials</a></li>
