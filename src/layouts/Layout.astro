---
import "../styles/global.css";
import { t } from "../i18n";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
  articlePubDate?: Date;
  articleUpdatedDate?: Date;
}

const { title, description, canonical, schema, noindex, articlePubDate, articleUpdatedDate } = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site || "https://homeplanninghub.com").toString();

const currentPath = Astro.url.pathname;
const tr = (key: string) => t('en', key);
const lUrl = (path: string) => path;
const ogImage = new URL("/og-image.png", canonicalURL).toString();

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://homeplanninghub.com/#organization",
  name: "HomePlanningHub",
  url: "https://homeplanninghub.com",
  logo: "https://homeplanninghub.com/og-image.png",
  description: "Free home improvement planning calculators and project estimating guides for homeowners and DIY builders.",
  foundingDate: "2026",
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: "support@homeplanninghub.com",
    areaServed: "US",
    availableLanguage: "English",
  },
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="homeplan" />
    <link rel="manifest" href="/site.webmanifest" />


    <title>{title.includes("HomePlanningHub") ? title : `${title} | HomePlanningHub`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:type" content={articlePubDate ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title.includes("HomePlanningHub") ? title : `${title} | HomePlanningHub`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="HomePlanningHub — free home improvement calculators and project planning tools" />
    <meta property="og:site_name" content="HomePlanningHub" />
    <meta property="og:locale" content="en_US" />
    {articlePubDate && <meta property="article:published_time" content={articlePubDate.toISOString()} />}
    {articleUpdatedDate && <meta property="article:modified_time" content={articleUpdatedDate.toISOString()} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title.includes("HomePlanningHub") ? title : `${title} | HomePlanningHub`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="HomePlanningHub — free home improvement calculators and project planning tools" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
    <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    {/* Organization schema for EEAT */}
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    {import.meta.env.PUBLIC_GA_ID && import.meta.env.PUBLIC_GA_ID !== 'G-XXXXXXXXXX' && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`} />
        <script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${import.meta.env.PUBLIC_GA_ID}');`} />
      </>
    )}

    <!-- Dark mode init — runs before paint to prevent flash -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var system = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && system)) {
            document.documentElement.classList.add('dark');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Skip link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-black focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold focus:shadow-lg">
      Skip to content
    </a>

    <!-- Header -->
    <header class="sticky top-0 z-50 w-full border-b border-[var(--border)] bg-[var(--bg)]/80 backdrop-blur-xl">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group" aria-label="HomePlanningHub home">
          <svg class="w-7 h-7 transition-all duration-300 group-hover:scale-105" viewBox="0 0 24 24" fill="none" stroke="url(#shiny-orange-grad)" stroke-width="1.75" aria-hidden="true" style="filter: drop-shadow(0 0 4px rgba(249, 115, 22, 0.7));">
            <defs>
              <linearGradient id="shiny-orange-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#fdba74" />
                <stop offset="50%" stop-color="#f97316" />
                <stop offset="100%" stop-color="#ea580c" />
              </linearGradient>
            </defs>
            <path d="M3 12L12 3l9 9M5 10v10h14V10" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M9 20v-6h6v6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="font-bold text-[15px] tracking-tight group-hover:text-[var(--accent)] transition-colors">HomePlanningHub</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
          <!-- Calculators dropdown -->
          <div class="relative group">
            <button
              type="button"
              id="calc-dropdown-btn"
              class="flex items-center gap-1 px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors"
              aria-haspopup="true"
              aria-expanded="false"
            >
              {tr('nav.calculators')}
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="absolute left-0 top-full mt-1 w-48 rounded-xl border border-[var(--border)] bg-[var(--bg)] shadow-lg opacity-0 invisible transition-all duration-150 z-50" role="menu">
              <div class="py-1">
                <a href={lUrl("/calculators/concrete/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/concrete") ? "page" : undefined}>{tr('calculators.concrete')}</a>
                <a href={lUrl("/calculators/roofing/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/roofing") ? "page" : undefined}>{tr('calculators.roofing')}</a>
                <a href={lUrl("/calculators/paint/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/paint") ? "page" : undefined}>{tr('calculators.paint')}</a>
                <a href={lUrl("/calculators/tile/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/tile") ? "page" : undefined}>{tr('calculators.tile')}</a>
                <a href={lUrl("/calculators/renovation/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/renovation") ? "page" : undefined}>Renovation</a>
                <div class="border-t border-[var(--border)] mx-2 my-1"></div>
                <a href={lUrl("/calculators/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors">{tr('nav.all_calculators')}</a>
              </div>
            </div>
          </div>
          <a href={lUrl("/renovate/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/renovate") ? "page" : undefined}>{tr('nav.plan_budget')}</a>
          <a href={lUrl("/maintenance/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/maintenance") ? "page" : undefined}>{tr('nav.maintenance')}</a>
          <a href={lUrl("/compare/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/compare") ? "page" : undefined}>{tr('nav.compare')}</a>
          <a href={lUrl("/guides/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/guides") ? "page" : undefined}>{tr('nav.guides')}</a>
          <a href={lUrl("/projects/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/projects") ? "page" : undefined}>{tr('nav.projects')}</a>
          <a href={lUrl("/about/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath === "/about/" ? "page" : undefined}>{tr('nav.about')}</a>
          <a href={lUrl("/methodology/")} class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath === "/methodology/" ? "page" : undefined}>{tr('nav.methodology')}</a>
        </nav>

        <div class="flex items-center gap-1">

          <!-- Dark mode toggle -->
          <button
            type="button"
            id="theme-toggle"
            class="flex items-center justify-center w-9 h-9 rounded-md border border-[var(--border)] hover:bg-[var(--bg-muted)] transition-colors"
            aria-label="Toggle dark mode"
          >
            <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            <svg class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
          </button>

          <!-- Mobile nav toggle -->
          <button
            type="button"
            id="mobile-nav-toggle"
            class="lg:hidden flex items-center justify-center w-9 h-9 rounded-md border border-[var(--border)] hover:bg-[var(--bg-muted)] transition-colors"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-nav"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Nav -->
      <nav id="mobile-nav" class="hidden lg:hidden border-t border-[var(--border)] bg-[var(--bg)]" aria-label="Mobile navigation">
        <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-0.5">
          <details class="group">
            <summary class="flex items-center justify-between px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px] cursor-pointer list-none">
              {tr('nav.calculators')}
              <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="ml-3 flex flex-col">
              <a href={lUrl("/calculators/concrete/")} class="px-3 py-2.5 rounded-md text-sm font-medium text-[var(--fg-muted)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('calculators.concrete')}</a>
              <a href={lUrl("/calculators/roofing/")} class="px-3 py-2.5 rounded-md text-sm font-medium text-[var(--fg-muted)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('calculators.roofing')}</a>
              <a href={lUrl("/calculators/paint/")} class="px-3 py-2.5 rounded-md text-sm font-medium text-[var(--fg-muted)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('calculators.paint')}</a>
              <a href={lUrl("/calculators/tile/")} class="px-3 py-2.5 rounded-md text-sm font-medium text-[var(--fg-muted)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('calculators.tile')}</a>
              <a href={lUrl("/calculators/")} class="px-3 py-2.5 rounded-md text-sm font-medium text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('nav.all_calculators')}</a>
            </div>
          </details>
          <a href={lUrl("/renovate/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('nav.plan_budget')}</a>
          <a href={lUrl("/maintenance/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('nav.maintenance')}</a>
          <a href={lUrl("/compare/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('nav.compare')}</a>
          <a href={lUrl("/guides/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('nav.guides')}</a>
          <a href={lUrl("/projects/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('nav.projects')}</a>
          <a href={lUrl("/about/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('nav.about')}</a>
          <a href={lUrl("/methodology/")} class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]">{tr('nav.methodology')}</a>
          <div class="border-t border-[var(--border)] mt-2 pt-2 flex gap-4 px-3">
            <a href={lUrl("/privacy/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.privacy')}</a>
            <a href={lUrl("/terms/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.terms')}</a>
          </div>
        </div>
      </nav>
    </header>

    <main id="main-content" class="flex-grow w-full max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[var(--border)] bg-[var(--bg-subtle)] mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
          <div class="col-span-2">
            <a href="/" class="flex items-center gap-2.5 mb-3 group">
              <svg class="w-6 h-6 transition-all duration-300 group-hover:scale-105" viewBox="0 0 24 24" fill="none" stroke="url(#shiny-orange-grad-footer)" stroke-width="1.75" aria-hidden="true" style="filter: drop-shadow(0 0 3px rgba(249, 115, 22, 0.6));">
                <defs>
                  <linearGradient id="shiny-orange-grad-footer" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#fdba74" />
                    <stop offset="50%" stop-color="#f97316" />
                    <stop offset="100%" stop-color="#ea580c" />
                  </linearGradient>
                </defs>
                <path d="M3 12L12 3l9 9M5 10v10h14V10" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M9 20v-6h6v6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="font-bold text-sm tracking-tight group-hover:text-[var(--accent)] transition-colors">HomePlanningHub</span>
            </a>
            <p class="text-xs text-[var(--fg-muted)] leading-relaxed max-w-xs text-pretty">
              {tr('footer.description')}
            </p>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">{tr('footer.calculators')}</h4>
            <ul class="flex flex-col gap-2">
              <li><a href={lUrl("/calculators/concrete/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('calculators.concrete')}</a></li>
              <li><a href={lUrl("/calculators/roofing/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('calculators.roofing')}</a></li>
              <li><a href={lUrl("/calculators/paint/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('calculators.paint')}</a></li>
              <li><a href={lUrl("/calculators/tile/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('calculators.tile')}</a></li>
              <li><a href={lUrl("/maintenance/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('nav.maintenance')}</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">{tr('footer.planning')}</h4>
            <ul class="flex flex-col gap-2">
              <li><a href={lUrl("/strategy/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('nav.strategy')}</a></li>
              <li><a href={lUrl("/projects/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('nav.projects')}</a></li>
              <li><a href={lUrl("/guides/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('nav.guides')}</a></li>
              <li><a href={lUrl("/compare/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('nav.compare')}</a></li>
              <li><a href={lUrl("/saved/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.saved_measurements')}</a></li>
              <li><a href={lUrl("/maintenance/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.maintenance_planner')}</a></li>
              <li><a href={lUrl("/renovate/plans/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.budget_plans')}</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">{tr('footer.interior')}</h4>
            <ul class="flex flex-col gap-2">
              <li><a href={lUrl("/calculators/paint/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.paint_calculator')}</a></li>
              <li><a href={lUrl("/calculators/tile/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.tile_calculator')}</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">{tr('footer.company')}</h4>
            <ul class="flex flex-col gap-2">
              <li><a href={lUrl("/about/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('nav.about')}</a></li>
              <li><a href={lUrl("/methodology/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('nav.methodology')}</a></li>
              <li><a href={lUrl("/contact/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('nav.contact')}</a></li>
              <li><a href={lUrl("/privacy/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.privacy')}</a></li>
              <li><a href={lUrl("/terms/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.terms')}</a></li>
              <li><a href={lUrl("/disclaimer/")} class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">{tr('footer.disclaimer')}</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-[var(--border)] mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
          <p class="text-xs text-[var(--fg-muted)]">&copy; {new Date().getFullYear()} HomePlanningHub</p>
          <p class="text-xs text-[var(--fg-muted)]">{tr('footer.estimates_note')}</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      const toggle = document.getElementById('theme-toggle');
      if (toggle) {
        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (e) {}
        });
      }

      const navToggle = document.getElementById('mobile-nav-toggle');
      const navMenu = document.getElementById('mobile-nav');
      if (navToggle && navMenu) {
        const toggleMobile = () => {
          const isOpen = !navMenu.classList.contains('hidden');
          if (isOpen) {
            navMenu.classList.add('hidden');
            navToggle.setAttribute('aria-expanded', 'false');
            navToggle.setAttribute('aria-label', 'Open menu');
          } else {
            navMenu.classList.remove('hidden');
            navToggle.setAttribute('aria-expanded', 'true');
            navToggle.setAttribute('aria-label', 'Close menu');
          }
        };
        navToggle.addEventListener('click', toggleMobile);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !navMenu.classList.contains('hidden')) {
            navMenu.classList.add('hidden');
            navToggle.setAttribute('aria-expanded', 'false');
            navToggle.setAttribute('aria-label', 'Open menu');
            navToggle.focus();
          }
        });
      }

      // Dropdown accessibility logic
      const setupDropdown = (btnId) => {
        const btn = document.getElementById(btnId);
        const parent = btn ? btn.parentElement : null;
        if (!btn || !parent) return;

        const menu = parent.querySelector('[role="menu"]');
        const menuItems = Array.from(parent.querySelectorAll('a[role="menuitem"]'));
        if (!menu) return;

        const setOpen = (open) => {
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          if (open) {
            menu.classList.remove('opacity-0', 'invisible');
            menu.classList.add('opacity-100', 'visible');
          } else {
            menu.classList.remove('opacity-100', 'visible');
            menu.classList.add('opacity-0', 'invisible');
          }
        };

        // Click to toggle
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = btn.getAttribute('aria-expanded') === 'true';
          setOpen(!isOpen);
        });

        // Hover events
        parent.addEventListener('mouseenter', () => setOpen(true));
        parent.addEventListener('mouseleave', () => setOpen(false));

        // Focus events
        parent.addEventListener('focusin', () => setOpen(true));
        parent.addEventListener('focusout', (e) => {
          if (!parent.contains(e.relatedTarget)) {
            setOpen(false);
          }
        });

        // Keyboard navigation
        parent.addEventListener('keydown', (e) => {
          const isOpen = btn.getAttribute('aria-expanded') === 'true';

          if (e.key === 'Escape') {
            setOpen(false);
            btn.focus();
            e.preventDefault();
            return;
          }

          if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (!isOpen) {
              setOpen(true);
              if (menuItems.length > 0) menuItems[0].focus();
            } else {
              const activeIndex = menuItems.indexOf(document.activeElement);
              const nextIndex = (activeIndex + 1) % menuItems.length;
              menuItems[nextIndex].focus();
            }
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (isOpen) {
              const activeIndex = menuItems.indexOf(document.activeElement);
              const prevIndex = activeIndex <= 0 ? menuItems.length - 1 : activeIndex - 1;
              menuItems[prevIndex].focus();
            }
          } else if (e.key === 'Home') {
            if (isOpen && menuItems.length > 0) {
              e.preventDefault();
              menuItems[0].focus();
            }
          } else if (e.key === 'End') {
            if (isOpen && menuItems.length > 0) {
              e.preventDefault();
              menuItems[menuItems.length - 1].focus();
            }
          }
        });
      };

      setupDropdown('calc-dropdown-btn');
    </script>


    {Astro.url.pathname.startsWith('/calculators/') && Astro.url.pathname !== '/calculators/' && Astro.url.pathname !== '/calculators' && (
      <button
        type="button"
        onclick="window.print()"
        class="no-print fixed bottom-6 right-6 z-50 flex items-center gap-1.5 px-4 py-2.5 bg-[var(--accent)] hover:bg-[var(--accent-hover)] text-white text-xs font-semibold rounded-full shadow-lg transition-all duration-200 hover:scale-105 active:scale-95 cursor-pointer"
        aria-label="Print or save estimate as PDF"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        <span>Print Estimate</span>
      </button>
    )}
  </body>
</html>
