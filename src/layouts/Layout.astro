---
import "../styles/global.css";
import { t } from "../i18n";
import { getParentHub } from "../lib/relatedCalculators";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
  articlePubDate?: Date;
  articleUpdatedDate?: Date;
}

const { title, description, canonical, schema, noindex, articlePubDate, articleUpdatedDate } = Astro.props;

const canonicalURL = canonical || (() => {
  const base = Astro.site?.toString() || "https://homeplanninghub.com";
  const path = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : Astro.url.pathname + "/";
  return new URL(path, base).toString();
})();

const currentPath = Astro.url.pathname;
const parentHub = getParentHub(currentPath);
const tr = (key: string) => t('en', key);
const lUrl = (path: string) => path;
const ogImage = new URL("/og-image.png", canonicalURL).toString();

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://homeplanninghub.com/#organization",
  name: "HomePlanningHub",
  url: "https://homeplanninghub.com",
  logo: "https://homeplanninghub.com/og-image.png",
  description: "Free home improvement planning calculators and project estimating guides for homeowners and DIY builders.",
  foundingDate: "2026",
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: "support@homeplanninghub.com",
    areaServed: "US",
    availableLanguage: "English",
  },
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="homeplan" />
    <link rel="manifest" href="/site.webmanifest" />


    <title>{title.includes("HomePlanningHub") ? title : `${title} | HomePlanningHub`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:type" content={articlePubDate ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title.includes("HomePlanningHub") ? title : `${title} | HomePlanningHub`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="HomePlanningHub — free home improvement calculators and project planning tools" />
    <meta property="og:site_name" content="HomePlanningHub" />
    <meta property="og:locale" content="en_US" />
    {articlePubDate && <meta property="article:published_time" content={articlePubDate.toISOString()} />}
    {articleUpdatedDate && <meta property="article:modified_time" content={articleUpdatedDate.toISOString()} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title.includes("HomePlanningHub") ? title : `${title} | HomePlanningHub`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="HomePlanningHub — free home improvement calculators and project planning tools" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
    <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
    {(() => {
      const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT && import.meta.env.PUBLIC_ADSENSE_CLIENT !== ''
        ? import.meta.env.PUBLIC_ADSENSE_CLIENT
        : 'ca-pub-5910777021067126';
      return (
        <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`} crossorigin="anonymous" />
      );
    })()}
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    {/* Organization schema for EEAT */}
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    {(() => {
      const gaId = import.meta.env.PUBLIC_GA_ID && import.meta.env.PUBLIC_GA_ID !== 'G-XXXXXXXXXX'
        ? import.meta.env.PUBLIC_GA_ID
        : 'G-B3GRZPTM95';
      return (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
          <script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');`} />
        </>
      );
    })()}

    <!-- Dark mode init — runs before paint to prevent flash -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var system = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && system)) {
            document.documentElement.classList.add('dark');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Skip link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-black focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold focus:shadow-lg">
      Skip to content
    </a>

    <!-- Header -->
    <header class="sticky top-0 z-50 w-full border-b border-[var(--border)] bg-[var(--bg)]/80 backdrop-blur-xl">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group shrink-0" aria-label="HomePlanningHub home">
          <svg class="w-7 h-7 transition-all duration-300 group-hover:scale-105" viewBox="0 0 24 24" fill="none" stroke="url(#shiny-orange-grad)" stroke-width="1.75" aria-hidden="true" style="filter: drop-shadow(0 0 4px rgba(249, 115, 22, 0.7));">
            <defs>
              <linearGradient id="shiny-orange-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#fdba74" />
                <stop offset="50%" stop-color="#f97316" />
                <stop offset="100%" stop-color="#ea580c" />
              </linearGradient>
            </defs>
            <path d="M3 12L12 3l9 9M5 10v10h14V10" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M9 20v-6h6v6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="font-bold text-[15px] tracking-tight group-hover:text-[var(--accent)] transition-colors">HomePlanningHub</span>
        </a>

        <!-- Desktop Search Bar -->
        <div class="hidden md:block relative w-44 lg:w-56 mx-4 no-print">
          <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
            <svg class="w-3.5 h-3.5 text-[var(--fg-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <input
            type="text"
            id="search-input-desktop"
            placeholder="Search calculators..."
            class="w-full pl-8 pr-3 py-1.5 text-xs bg-[var(--bg-inset)] border border-[var(--border)] rounded-full text-[var(--fg)] placeholder-[var(--fg-muted)] focus:outline-none focus:border-[var(--primary)] focus:ring-1 focus:ring-[var(--primary)]/20 transition-all"
            autocomplete="off"
            aria-label="Search utilities"
          />
          <div
            id="search-results-desktop"
            class="absolute left-0 right-0 top-full mt-1.5 max-h-60 overflow-y-auto rounded-xl border border-[var(--border)] bg-[var(--bg)] shadow-lg hidden z-50 text-xs py-1"
          >
          </div>
        </div>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
          <!-- Calculators dropdown -->
          <div class="relative group">
            <button
              type="button"
              id="calc-dropdown-btn"
              class="flex items-center gap-1 px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors"
              aria-haspopup="true"
              aria-expanded="false"
            >
              {tr('nav.calculators')}
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="absolute left-0 top-full mt-1 w-52 rounded-xl border border-[var(--border)] bg-[var(--bg)] shadow-lg opacity-0 invisible transition-all duration-150 z-50" role="menu">
              <div class="py-1">
                <a href={lUrl("/calculators/concrete/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/concrete") ? "page" : undefined}>{tr('calculators.concrete')}</a>
                <a href={lUrl("/calculators/roofing/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/roofing") ? "page" : undefined}>{tr('calculators.roofing')}</a>
                <a href={lUrl("/calculators/paint/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/paint") ? "page" : undefined}>{tr('calculators.paint')}</a>
                <a href={lUrl("/calculators/tile/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/tile") ? "page" : undefined}>{tr('calculators.tile')}</a>
                <a href={lUrl("/calculators/renovation/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/renovation") ? "page" : undefined}>Renovation</a>
                <div class="border-t border-[var(--border)] mx-2 my-1"></div>
                <a href={lUrl("/calculators/bulk-vs-bagged/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/bulk-vs-bagged") ? "page" : undefined}>★ Bulk vs. Bagged Planner</a>
                <a href={lUrl("/calculators/payload/")} role="menuitem" class="block px-3 py-2 text-xs font-semibold text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/payload") ? "page" : undefined}>Payload & Weight Safety</a>
                <a href={lUrl("/calculators/diy-vs-pro/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/diy-vs-pro") ? "page" : undefined}>★ DIY vs. Pro Cost Splitter</a>
                <div class="border-t border-[var(--border)] mx-2 my-1"></div>
                <a href={lUrl("/calculators/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-muted)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors">{tr('nav.all_calculators')}</a>
              </div>
            </div>
          </div>

          <!-- Designers dropdown -->
          <div class="relative group">
            <button
              type="button"
              id="designers-dropdown-btn"
              class="flex items-center gap-1 px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors"
              aria-haspopup="true"
              aria-expanded="false"
            >
              Designers
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="absolute left-0 top-full mt-1 w-56 rounded-xl border border-[var(--border)] bg-[var(--bg)] shadow-lg opacity-0 invisible transition-all duration-150 z-50" role="menu">
              <div class="py-1">
                <a href={lUrl("/calculators/concrete-slab-designer/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/concrete-slab-designer") ? "page" : undefined}>★ Concrete Slab & Patio Designer</a>
                <a href={lUrl("/calculators/deck-designer/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/deck-designer") ? "page" : undefined}>★ Deck Layout Designer</a>
                <a href={lUrl("/calculators/tile-designer/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/tile-designer") ? "page" : undefined}>★ Tile Layout Designer</a>
                <a href={lUrl("/calculators/closet-designer/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/closet-designer") ? "page" : undefined}>★ Closet & Storage Designer</a>
                <a href={lUrl("/calculators/wainscoting-designer/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/wainscoting-designer") ? "page" : undefined}>★ Wainscoting Designer</a>
                <a href={lUrl("/calculators/framing-designer/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/framing-designer") ? "page" : undefined}>★ Wall Framing Designer</a>
                <a href={lUrl("/calculators/hardscape-designer/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/hardscape-designer") ? "page" : undefined}>★ Hardscape Designer</a>
                <a href={lUrl("/calculators/measure-from-photo/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/measure-from-photo") ? "page" : undefined}>★ Photo-to-Measurement Simulator</a>
                <a href={lUrl("/calculators/stair-stringer-designer/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/stair-stringer-designer") ? "page" : undefined}>★ Stair Stringer Designer</a>
              </div>
            </div>
          </div>
          <!-- Planners dropdown -->
          <div class="relative group">
            <button
              type="button"
              class="flex items-center gap-1 px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors"
              aria-haspopup="true"
              aria-expanded="false"
            >
              Planning
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="absolute left-0 top-full mt-1 w-52 rounded-xl border border-[var(--border)] bg-[var(--bg)] shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50" role="menu">
              <div class="py-1">
                <a href={lUrl("/plan/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/plan") ? "page" : undefined}>★ Budget Binder</a>
                <a href={lUrl("/cost-estimator/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/cost-estimator") ? "page" : undefined}>★ {tr('nav.bid_estimators')}</a>
                <a href={lUrl("/skill-profile/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/skill-profile") ? "page" : undefined}>★ {tr('nav.diy_skill_profile')}</a>
                <a href={lUrl("/best/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/best") ? "page" : undefined}>★ {tr('nav.climate_matchmaker')}</a>
                <a href={lUrl("/planning/permit-guides/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/planning/permit-guides") ? "page" : undefined}>★ Permit Guides</a>
                <a href={lUrl("/planning/permit-cost-calculator/")} role="menuitem" class="block px-3 py-2 text-xs font-bold text-[var(--accent)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/planning/permit-cost-calculator") ? "page" : undefined}>★ Permit Estimator</a>
                <div class="border-t border-[var(--border)] mx-2 my-1"></div>
                <a href={lUrl("/renovate/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/renovate") ? "page" : undefined}>{tr('nav.plan_budget')}</a>
                <a href={lUrl("/playbook/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/playbook") ? "page" : undefined}>Playbooks</a>
                <a href={lUrl("/projects/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/projects") ? "page" : undefined}>{tr('nav.projects')}</a>
              </div>
            </div>
          </div>

          <!-- Resources dropdown -->
          <div class="relative group">
            <button
              type="button"
              class="flex items-center gap-1 px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors"
              aria-haspopup="true"
              aria-expanded="false"
            >
              Resources
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="absolute right-0 top-full mt-1 w-52 rounded-xl border border-[var(--border)] bg-[var(--bg)] shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50" role="menu">
              <div class="py-1">
                <a href={lUrl("/maintenance/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/maintenance") ? "page" : undefined}>{tr('nav.maintenance')}</a>
                <a href={lUrl("/compare/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/compare") ? "page" : undefined}>{tr('nav.compare')}</a>
                <a href={lUrl("/guides/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/guides") ? "page" : undefined}>{tr('nav.guides')}</a>
                <a href={lUrl("/about/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath === "/about/" ? "page" : undefined}>{tr('nav.about')}</a>
                <a href={lUrl("/methodology/")} role="menuitem" class="block px-3 py-2 text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath === "/methodology/" ? "page" : undefined}>{tr('nav.methodology')}</a>
              </div>
            </div>
          </div>
        </nav>

        <div class="flex items-center gap-1">

          <!-- Dark mode slider toggle -->
          <div class="flex items-center gap-1.5 border border-[var(--border)] rounded-full px-2.5 py-1 bg-[var(--bg-inset)]/30 no-print">
            <svg class="w-3.5 h-3.5 text-[var(--fg-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            
            <label class="relative inline-flex items-center cursor-pointer" aria-label="Toggle theme">
              <input type="checkbox" id="theme-slider" class="sr-only peer" />
              <div class="w-8 h-4.5 bg-stone-300 dark:bg-stone-600 rounded-full peer peer-focus:outline-none peer-checked:after:translate-x-[14px] after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-3.5 after:w-3.5 after:transition-all transition-colors duration-200"></div>
