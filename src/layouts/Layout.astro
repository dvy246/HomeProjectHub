---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
  articlePubDate?: Date;
  articleUpdatedDate?: Date;
}

const { title, description, canonical, schema, noindex, articlePubDate, articleUpdatedDate } = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site || "https://homeprojecthub.com").toString();
const ogImage = new URL("/og-image.png", canonicalURL).toString();
const currentPath = Astro.url.pathname;
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://homeprojecthub.com/#organization",
  name: "HomeProjectHub",
  url: "https://homeprojecthub.com",
  logo: "https://homeprojecthub.com/og-image.png",
  description: "Free home improvement planning calculators and project estimating guides for homeowners.",
  foundingDate: "2026",
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: "support@homeprojecthub.com",
    areaServed: "US",
    availableLanguage: "English",
  },
};
---

<!doctype html>
<html lang="en" class="scroll-smooth" style="color-scheme: light dark;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://pagead2.googlesyndication.com https://www.googletagmanager.com; img-src 'self' https: data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self'; frame-src 'self' https://pagead2.googlesyndication.com; object-src 'none'; base-uri 'self'; form-action 'self' https://formspree.io; upgrade-insecure-requests" />

    <title>{title} | HomeProjectHub</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:type" content={articlePubDate ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | HomeProjectHub`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="HomeProjectHub" />
    <meta property="og:locale" content="en_US" />
    {articlePubDate && <meta property="article:published_time" content={articlePubDate.toISOString()} />}
    {articleUpdatedDate && <meta property="article:modified_time" content={articleUpdatedDate.toISOString()} />}

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | HomeProjectHub`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
    <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    {/* Organization schema for EEAT */}
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    {import.meta.env.PUBLIC_GA_ID && import.meta.env.PUBLIC_GA_ID !== 'G-XXXXXXXXXX' && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`} />
        <script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${import.meta.env.PUBLIC_GA_ID}');`} />
      </>
    )}

    <!-- Dark mode init — runs before paint to prevent flash -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var system = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && system)) {
            document.documentElement.classList.add('dark');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Skip link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-black focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold focus:shadow-lg">
      Skip to content
    </a>

    <!-- Header -->
    <header class="sticky top-0 z-50 w-full border-b border-[var(--border)] bg-[var(--bg)]/80 backdrop-blur-xl">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group" aria-label="HomeProjectHub home">
          <svg class="w-7 h-7 text-[var(--fg)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 12L12 3l9 9M5 10v10h14V10" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M9 20v-6h6v6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="font-bold text-[15px] tracking-tight">HomeProjectHub</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
          <a href="/calculators/concrete/" class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/concrete") ? "page" : undefined}>Concrete</a>
          <a href="/calculators/roofing/" class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/roofing") ? "page" : undefined}>Roofing</a>
          <a href="/calculators/paint/" class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/paint") ? "page" : undefined}>Paint</a>
          <a href="/calculators/tile/" class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/calculators/tile") ? "page" : undefined}>Tile</a>
          <a href="/compare/" class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/compare") ? "page" : undefined}>Compare</a>
          <a href="/guides/" class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/guides") ? "page" : undefined}>Guides</a>
          <a href="/planner/" class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath.startsWith("/planner") ? "page" : undefined}>Planner</a>
          <a href="/saved/" class="px-3 py-1.5 text-[13px] font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] rounded-md hover:bg-[var(--bg-muted)] transition-colors" aria-current={currentPath === "/saved/" ? "page" : undefined}>Saved</a>
        </nav>

        <div class="flex items-center gap-2">
          <!-- Dark mode toggle -->
          <button
            type="button"
            id="theme-toggle"
            class="flex items-center justify-center w-9 h-9 rounded-md border border-[var(--border)] hover:bg-[var(--bg-muted)] transition-colors"
            aria-label="Toggle dark mode"
          >
            <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            <svg class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
          </button>

          <!-- Mobile nav toggle -->
          <button
            type="button"
            id="mobile-nav-toggle"
            class="md:hidden flex items-center justify-center w-9 h-9 rounded-md border border-[var(--border)] hover:bg-[var(--bg-muted)] transition-colors"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-nav"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Nav -->
      <nav id="mobile-nav" class="hidden md:hidden border-t border-[var(--border)] bg-[var(--bg)]" aria-label="Mobile navigation">
        <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-0.5">
          <a href="/calculators/concrete/" class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/calculators/concrete") ? "page" : undefined}>Concrete</a>
          <a href="/calculators/roofing/" class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/calculators/roofing") ? "page" : undefined}>Roofing</a>
          <a href="/calculators/paint/" class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/calculators/paint") ? "page" : undefined}>Paint</a>
          <a href="/calculators/tile/" class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/calculators/tile") ? "page" : undefined}>Tile</a>
          <a href="/compare/" class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/compare") ? "page" : undefined}>Compare</a>
          <a href="/guides/" class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/guides") ? "page" : undefined}>Guides</a>
          <a href="/planner/" class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath.startsWith("/planner") ? "page" : undefined}>Planner</a>
          <a href="/saved/" class="px-3 py-3 rounded-md text-sm font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors min-h-[44px]" aria-current={currentPath === "/saved/" ? "page" : undefined}>Saved</a>
          <div class="border-t border-[var(--border)] mt-2 pt-2 flex gap-4 px-3">
            <a href="/about/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">About</a>
            <a href="/contact/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Contact</a>
            <a href="/privacy/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Privacy</a>
            <a href="/terms/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Terms</a>
          </div>
        </div>
      </nav>
    </header>

    <main id="main-content" class="flex-grow w-full max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[var(--border)] bg-[var(--bg-subtle)] mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
          <div class="col-span-2">
            <a href="/" class="flex items-center gap-2.5 mb-3">
              <svg class="w-6 h-6 text-[var(--fg)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M3 12L12 3l9 9M5 10v10h14V10" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M9 20v-6h6v6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="font-bold text-sm tracking-tight">HomeProjectHub</span>
            </a>
            <p class="text-xs text-[var(--fg-muted)] leading-relaxed max-w-xs text-pretty">
              Free, precise construction calculators for homeowners and DIY builders. No sign-up, no tracking, no nonsense.
            </p>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">Concrete</h4>
            <ul class="flex flex-col gap-2">
              <li><a href="/calculators/concrete/slab/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Slab</a></li>
              <li><a href="/calculators/concrete/footing/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Footing</a></li>
              <li><a href="/calculators/concrete/rebar/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Rebar</a></li>
              <li><a href="/calculators/concrete/block-fill/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Block Fill</a></li>
              <li><a href="/calculators/concrete/column/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Column</a></li>
              <li><a href="/calculators/concrete/wall/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Wall</a></li>
              <li><a href="/calculators/concrete/tube/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Tube Form</a></li>
              <li><a href="/calculators/concrete/steps/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Steps</a></li>
              <li><a href="/calculators/concrete/curb-gutter/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Curb &amp; Gutter</a></li>
              <li><a href="/calculators/concrete/mix-ratio/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Mix Ratio</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">Roofing</h4>
            <ul class="flex flex-col gap-2">
              <li><a href="/calculators/roofing/shingles/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Shingles</a></li>
              <li><a href="/calculators/roofing/metal/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Metal Roof</a></li>
              <li><a href="/calculators/roofing/plywood/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Plywood Deck</a></li>
              <li><a href="/calculators/roofing/pitch/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Roof Pitch</a></li>
              <li><a href="/calculators/roofing/ice-water-shield/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Ice &amp; Water Shield</a></li>
              <li><a href="/calculators/roofing/snow-load/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Snow Load</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">Interior</h4>
            <ul class="flex flex-col gap-2">
              <li><a href="/calculators/paint/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Paint Calculator</a></li>
              <li><a href="/calculators/tile/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Tile Calculator</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">Resources</h4>
            <ul class="flex flex-col gap-2">
              <li><a href="/guides/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Planning Guides</a></li>
              <li><a href="/compare/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Compare Materials</a></li>
              <li><a href="/planner/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Project Planner</a></li>
              <li><a href="/saved/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Saved Measurements</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-[var(--fg)] mb-3">Company</h4>
            <ul class="flex flex-col gap-2">
              <li><a href="/about/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">About</a></li>
              <li><a href="/contact/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Contact</a></li>
              <li><a href="/privacy/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Privacy</a></li>
              <li><a href="/terms/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Terms</a></li>
              <li><a href="/disclaimer/" class="text-xs text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">Disclaimer</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-[var(--border)] mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
          <p class="text-xs text-[var(--fg-muted)]">&copy; {new Date().getFullYear()} HomeProjectHub</p>
          <p class="text-xs text-[var(--fg-muted)]">Estimates are for planning only. Some outbound shopping links may be affiliate links.</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      const toggle = document.getElementById('theme-toggle');
      if (toggle) {
        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }

      const navToggle = document.getElementById('mobile-nav-toggle');
      const navMenu = document.getElementById('mobile-nav');
      if (navToggle && navMenu) {
        const toggleMobile = () => {
          const isOpen = !navMenu.classList.contains('hidden');
          if (isOpen) {
            navMenu.classList.add('hidden');
            navToggle.setAttribute('aria-expanded', 'false');
            navToggle.setAttribute('aria-label', 'Open menu');
          } else {
            navMenu.classList.remove('hidden');
            navToggle.setAttribute('aria-expanded', 'true');
            navToggle.setAttribute('aria-label', 'Close menu');
          }
        };
        navToggle.addEventListener('click', toggleMobile);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !navMenu.classList.contains('hidden')) {
            navMenu.classList.add('hidden');
            navToggle.setAttribute('aria-expanded', 'false');
            navToggle.setAttribute('aria-label', 'Open menu');
            navToggle.focus();
          }
        });
      }
    </script>
  </body>
</html>
