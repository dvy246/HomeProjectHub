---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, any>;
}

const { title, description, canonical, schema } = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site || "https://homeprojecthub.com").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title} | HomeProjectHub</title>
    <meta name="description" content={description} />
    
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Google Fonts for Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body class="flex flex-col min-h-screen bg-[#ffffff] dark:bg-[#000000] text-[#171717] dark:text-[#ededed] antialiased">
    <!-- Header -->
    <header class="sticky top-0 z-40 w-full border-b border-neutral-200 dark:border-neutral-800 bg-white/80 dark:bg-black/80 backdrop-blur-md">
      <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 select-none hover:opacity-90 transition-opacity">
          <span class="font-bold text-lg tracking-tight">HomeProjectHub</span>
          <span class="text-xs bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 px-1.5 py-0.5 rounded text-neutral-500 font-mono">v3.0</span>
        </a>
        <nav class="flex items-center gap-6 text-sm font-medium">
          <a href="/calculators/concrete/" class="text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100 transition-colors">Concrete</a>
          <a href="/calculators/roofing/" class="text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100 transition-colors">Roofing</a>
          <a href="/compare/" class="text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100 transition-colors">Compare</a>
          <a href="/saved/" class="text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100 transition-colors flex items-center gap-1.5">
            <span>Saved Rooms</span>
          </a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-5xl w-full mx-auto px-4 py-8 md:py-12">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-neutral-200 dark:border-neutral-800 bg-[#fafafa] dark:bg-[#111111] py-8 mt-auto select-none">
      <div class="max-w-5xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-neutral-500 dark:text-neutral-400">
        <div>
          &copy; {new Date().getFullYear()} HomeProjectHub. All rights reserved.
        </div>
        <div class="flex items-center gap-6">
          <a href="/privacy/" class="hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">Privacy</a>
          <a href="/terms/" class="hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">Terms</a>
          <a href="/about/" class="hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">About</a>
        </div>
      </div>
    </footer>
  </body>
</html>
