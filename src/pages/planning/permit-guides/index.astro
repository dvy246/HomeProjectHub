---
import Layout from "../../../layouts/Layout.astro";
import PermitStateGuides from "../../../components/calculators/PermitStateGuides";
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro";
import { graphSchema, webApplicationSchema, faqPageSchema, breadcrumbListSchema } from "../../../lib/schema";

const canonical = "https://homeplanninghub.com/planning/permit-guides/";
const title = "Do You Need a Building Permit? State-by-State Rules & Exemptions";
const description = "Check if your deck, concrete patio, or roofing replacement project requires a building permit. Interactive guidelines and thresholds for CA, TX, FL, NY, and MT.";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const faqs = [
  {
    q: "Do I need a building permit for a deck?",
    a: "Generally, yes, if the deck is attached to your home, sits more than 30 inches above the ground, or exceeds 200 square feet in area. Detached decks under 200 square feet and under 30 inches off grade are typically exempt."
  },
  {
    q: "Do you need a permit to pour concrete in your backyard?",
    a: "Standard concrete slab patios or walkways on grade (under 30 inches above grade) that do not support structural posts do not require a building permit. However, you must check local setback limits to avoid pouring within property line setbacks."
  },
  {
    q: "Is a building permit required for reroofing?",
    a: "Yes, in most states (including California and Florida), reroofing permits are mandatory to verify sheathing fasteners, underlayment ratings, and ventilation. New York allows reroofing without a permit in some rural towns unless you are replacing rafters or installing a third layer."
  },
  {
    q: "What happens if I build without a permit?",
    a: "Building without a permit can result in stop-work orders, code violation fines (often double or triple the permit fee), and you may be forced to tear down the finished work. It also creates major issues during home sales and can lead to insurance coverage denials."
  }
];

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Planning", path: "/planning/" },
    { name: "Permit Guides", path: PAGE_PATH }
  ]),
  webApplicationSchema(title, description, canonical),
  faqPageSchema(faqs, canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/planning/permit-cost-calculator/" class="hover:text-[var(--fg)] transition-colors">Planning</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)] font-medium">Permit Guides</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">
        Do You Need a Building Permit?
      </h1>
      <p class="text-base text-[var(--fg-secondary)] text-pretty leading-relaxed">
        Check structural permit triggers, exceptions, and building codes by state and project type. Select your state below to see standard thresholds for decks, concrete flatwork, and reroofing before starting construction.
      </p>
    </header>

    <section>
      <PermitStateGuides client:load />
    </section>

    <section class="mt-4">
      <h2 class="text-xl font-bold mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        {faqs.map((faq) => (
          <details class="group border border-[var(--border)] rounded-xl bg-[var(--card-bg)] p-4 transition-all duration-200 open:bg-[var(--bg-subtle)]">
            <summary class="flex justify-between items-center font-semibold text-sm text-[var(--fg)] cursor-pointer list-none focus:outline-none">
              <span>{faq.q}</span>
              <svg class="w-4 h-4 text-[var(--fg-muted)] transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="text-xs text-[var(--fg-secondary)] leading-relaxed mt-3 pt-3 border-t border-[var(--border)]">
              {faq.a}
            </p>
          </details>
        ))}
      </div>
    </section>

    <footer class="mt-8 pt-6 border-t border-[var(--border)] no-print">
      <RelatedCalculators slug="permit-guides" />
    </footer>
  </article>
</Layout>
