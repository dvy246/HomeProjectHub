---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { graphSchema, breadcrumbListSchema, webPageSchema, howToSchema, faqPageSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const hubs = [
    {
      slug: "concrete-patio",
      title: "Concrete Patios & Slabs Hub",
      description: "The complete planning guide for concrete slabs, patios, footings, and structural pours. Estimate volume in cubic yards, rebar reinforcement grids, sub-base gravel layers, and logistics.",
      flagship: {
        name: "Concrete Slab & Patio Designer",
        href: "/calculators/concrete-slab-designer/",
        description: "Interactive visualizer to model rectangular or L-shaped slabs, rebar grids, sub-base depths, and bag count configurations."
      },
      spokes: [
        { href: "/calculators/concrete/slab/", name: "Concrete Slab Calculator", desc: "Calculate cubic yards and dry mix bags for rectangular slabs." },
        { href: "/calculators/concrete/footing/", name: "Concrete Footing Calculator", desc: "Estimate concrete volume for post and deck footings." },
        { href: "/calculators/concrete/rebar/", name: "Rebar Reinforcement Calculator", desc: "Determine rebar grid lengths, spacing, and wire ties." },
        { href: "/calculators/gravel/", name: "Gravel Base Calculator", desc: "Estimate tons or cubic yards of aggregate for sub-bases." },
        { href: "/calculators/concrete/mix-ratio/", name: "Concrete Mix Ratio", desc: "Convert cement, sand, and gravel ratios for manual mixing." },
        { href: "/calculators/bulk-vs-bagged/", name: "Bulk vs Bagged Logistics", desc: "Determine when ready-mix delivery beats manual bag mixing." },
        { href: "/calculators/diy-vs-pro/", name: "DIY vs Pro Cost Estimator", desc: "Compare contractor quotes against DIY risks and material costs." }
      ],
      guides: [
        "concrete-volume-guide",
        "concrete-curing-time-guide",
        "concrete-reinforcement-guide",
        "slab-preparation-guide",
        "slab-thickness-guide"
      ]
    },
    {
      slug: "building-deck",
      title: "Decks, Railings & Stairs Hub",
      description: "Your master planning workspace for backyard decks, railing spans, and custom stair stringers. Estimate structural lumber, joist spacing, footings, and code compliance.",
      flagship: {
        name: "Deck Layout & Joist Designer",
        href: "/calculators/deck-designer/",
        description: "Visual blueprint modeler to calculate joists, beams, support posts, concrete tubes, and deck boards."
      },
      spokes: [
        { href: "/calculators/decking/", name: "Deck Board Calculator", desc: "Calculate individual decking boards and fastener clip requirements." },
        { href: "/calculators/stair-stringer-designer/", name: "Stair Stringer Designer", desc: "Plan stair rise, run, tread counts, and verify stringer dimensions." },
        { href: "/calculators/baluster/", name: "Baluster Spacing Calculator", desc: "Distribute balusters evenly while satisfying safety spacing rules." },
        { href: "/calculators/spindle-spacing/", name: "Spindle Spacing", desc: "Estimate layout gaps for railing spindles." },
        { href: "/calculators/spiral-staircase/", name: "Spiral Staircase Planner", desc: "Plan space-saving spiral stairs for interiors or deck connections." },
        { href: "/calculators/lumber/", name: "Lumber Estimator", desc: "Calculate board feet, lumber sizes, and aggregate pricing." }
      ],
      guides: [
        "deck-spindle-spacing-guide",
        "material-weight-guide"
      ]
    },
    {
      slug: "room-renovation",
      title: "Room Renovation & Framing Hub",
      description: "Group guide to renovating interiors, constructing wall framing, hanging drywall sheets, and estimating paint finishes. Build custom budgets and check stud layouts.",
      flagship: {
        name: "Room Renovation Budget Binder",
        href: "/plan/",
        description: "The primary budgeting planner. Specify room shapes, finishes, doors, and windows to generate printable contractor scopes."
      },
      spokes: [
        { href: "/calculators/framing-designer/", name: "Wall Framing Designer", desc: "Render stud layouts, plates, and headers with printable cut lists." },
        { href: "/calculators/drywall/", name: "Drywall Sheet Calculator", desc: "Estimate standard drywall sheets, joint compound, tape, and screws." },
        { href: "/calculators/paint/", name: "Paint Gallon Estimator", desc: "Calculate paint cans needed for walls, ceilings, trim, and doors." },
        { href: "/calculators/wainscoting-designer/", name: "Wainscoting Designer", desc: "Visualize and plan board and batten panel spacing for accent walls." },
        { href: "/calculators/closet-designer/", name: "Closet & Storage Designer", desc: "Layout custom Reach-in or Walk-in shelving sections and drawers." },
        { href: "/calculators/square-footage/", name: "Square Footage Calculator", desc: "Calculate wall and floor surface areas for multi-wall layouts." }
      ],
      guides: [
        "drywall-estimating-guide",
        "how-much-paint-do-i-need-for-12x12-room",
        "interior-paint-sheens-guide",
        "paint-estimating-guide",
        "lumber-board-foot-guide"
      ]
    },
    {
      slug: "flooring-tiling",
      title: "Flooring, Tiling & Accents Hub",
      description: "Plan floor tiling patterns, vinyl roll sheets, wood planks, or mortar and grout bags. Estimate coverage, cut waste, and layout configurations.",
      flagship: {
        name: "Tile Grid & Layout Designer",
        href: "/calculators/tile-designer/",
        description: "Interactive visual grid to model Herringbone, Brick, or Grid tiling layouts with dynamic offset offsets."
      },
      spokes: [
        { href: "/calculators/tile/", name: "Flooring Tile Calculator", desc: "Quickly compute tiles, grout bags, and mortar bags needed." },
        { href: "/calculators/flooring/", name: "Flooring & Roll Calculator", desc: "Plan composite plank flooring boxes, LVP, or carpet rolls." },
        { href: "/calculators/diy-vs-pro/", name: "DIY vs Pro Cost", desc: "Evaluate subfloor preparation, tool rentals, and contractor tradeoffs." }
      ],
      guides: [
        "tile-installation-guide",
        "tiling-subfloor-preparation-guide",
        "underlayment-for-flooring-guide",
        "flooring-materials-guide",
        "flooring-transition-strips-guide"
      ]
    },
    {
      slug: "roofing-replacement",
      title: "Roof Replacement & Pitch Hub",
      description: "Estimate structural roof replacement parameters. Calculate shingles, metal panels, plywood sheathing deck boards, and structural snow load capacity.",
      flagship: {
        name: "Roof Shingles Estimator",
        href: "/calculators/roofing/shingles/",
        description: "Convert roof footprint, pitch, and waste factors into bundles, underlayment rolls, and roofing nails."
      },
      spokes: [
        { href: "/calculators/roofing/metal/", name: "Metal Roofing Calculator", desc: "Estimate metal siding panels, ridge caps, and mounting screws." },
        { href: "/calculators/roofing/plywood/", name: "Plywood Deck Calculator", desc: "Determine structural roof sheathing board count." },
        { href: "/calculators/roofing/pitch/", name: "Roof Pitch & Slope", desc: "Measure rafter lengths, angles, and pitch factor multipliers." },
        { href: "/calculators/roofing/snow-load/", name: "Roof Snow Load Capacity", desc: "Check structural safety margins against localized snow weight." },
        { href: "/calculators/roofing/ice-water-shield/", name: "Ice & Water Shield", desc: "Calculate protective adhesive roll coverage for eaves and valleys." }
      ],
      guides: [
        "how-to-estimate-roof-shingles",
        "metal-roofing-vs-shingles",
        "roof-ventilation-estimating-guide",
        "roofing-material-guide"
      ]
    },
    {
      slug: "landscaping-hardscape",
      title: "Landscaping, Hardscapes & Drainage Hub",
      description: "Backyard hardscaping and drainage guide. Design paver patios, retaining walls, french drains, limestone bases, and verify hauling vehicle payload margins.",
      flagship: {
        name: "Hardscape & Paver Designer",
        href: "/calculators/hardscape-designer/",
        description: "Visual canvas layout editor to model paver blocks, sub-base gravel, setting sand, and edge restraint lines."
      },
      spokes: [
        { href: "/calculators/gravel/", name: "Gravel Base Calculator", desc: "Calculate gravel base and aggregate volumes for paths." },
        { href: "/calculators/sand/", name: "Bedding Sand Calculator", desc: "Determine setting bed volume for paving blocks." },
        { href: "/calculators/retaining-wall/", name: "Retaining Wall Calculator", desc: "Estimate block stacks, base layers, and structural backfill." },
        { href: "/calculators/french-drain/", name: "French Drain Calculator", desc: "Plan gravel backfill, filter fabric, and perforated piping." },
        { href: "/calculators/payload/", name: "Payload Safety Calculator", desc: "Check if your vehicle can safely haul aggregate and sand weight." },
        { href: "/calculators/brick/", name: "Brick Masonry Calculator", desc: "Estimate brick counts and mortar bags for structures." }
      ],
      guides: [
        "landscaping-materials-guide",
        "gravel-base-guide",
        "mulch-soil-depth-guide",
        "brick-mortar-estimating-guide"
      ]
    }
  ];

  return hubs.map((hub) => ({
    params: { slug: hub.slug },
    props: { hub }
  }));
}

const { hub } = Astro.props;

// Fetch collection guides
const allGuides = await getCollection("guide");
const matchingGuides = allGuides.filter((g) => hub.guides.includes(g.id));

const canonical = `https://homeplanninghub.com/projects/${hub.slug}/`;

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Projects", path: "/playbook/" },
    { name: hub.title, path: `/projects/${hub.slug}/` }
  ]),
  webPageSchema({ url: canonical, topicName: hub.title }),
  howToSchema(
    `How to Plan a ${hub.title}`,
    hub.description,
    hub.spokes.slice(0, 3).map((s) => ({
      name: s.name,
      text: s.desc
    }))
  ),
  faqPageSchema(
    hub.spokes.slice(0, 3).map((s) => ({
      q: `What is the purpose of the ${s.name}?`,
      a: `${s.desc} This tool is available online as part of our specialized suite.`
    })),
    canonical
  )
);
---

<Layout title={`${hub.title} | HomePlanningHub`} description={hub.description} canonical={canonical} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-4 no-print" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/playbook/" class="hover:text-[var(--fg)] transition-colors">Projects</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">{hub.title}</span>
    </nav>

    <!-- Header Section -->
    <header class="pb-6 border-b border-[var(--border)]">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        {hub.title} Master Guide
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty mb-4">
        {hub.description}
      </p>

      <!-- E-E-A-T Author Badge -->
      <div class="flex items-center gap-2.5 bg-[var(--bg-muted)] border border-[var(--border)] rounded-xl p-3 w-fit text-xs text-[var(--fg-secondary)]">
        <svg class="w-4 h-4 text-[var(--accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
        </svg>
        <span>Reviewed & Attributed to <strong>Marcus Vance (DIY Construction Specialist)</strong></span>
      </div>
    </header>

    <!-- Flagship Interactive Designer Product (Hero CTA) -->
    <section class="bg-[var(--bg-subtle)] border border-[var(--border)] rounded-2xl p-6 relative overflow-hidden transition-all duration-300 hover:border-[var(--border-strong)]">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div class="flex-grow flex flex-col gap-1.5">
          <span class="text-[10px] font-bold text-[var(--accent)] uppercase tracking-wider">Flagship Interactive Layout Designer</span>
          <h2 class="text-xl font-bold text-[var(--fg)] flex items-center gap-1.5">
            <svg class="w-5 h-5 text-[var(--accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
            </svg>
            {hub.flagship.name}
          </h2>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed max-w-xl">
            {hub.flagship.description} Use this canvas layout utility to map complex boundaries and output precise dry mix bag counts or lumber cutting plans in real-time.
          </p>
        </div>
        <a href={hub.flagship.href} class="w-full md:w-auto inline-flex items-center justify-center px-5 py-2.5 text-xs font-bold rounded-lg bg-[var(--accent)] text-white hover:bg-orange-600 shadow-sm transition-all text-center">
          Open Designer
          <svg class="w-3.5 h-3.5 ml-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- Spoke Tools Grid -->
    <section class="flex flex-col gap-4">
      <h2 class="text-lg font-bold text-[var(--fg)] flex items-center gap-2">
        <svg class="w-4 h-4 text-[var(--fg-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        Interactive Planning Calculators
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3.5">
        {hub.spokes.map((spoke) => (
          <a href={spoke.href} class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] transition-all card-elevated flex flex-col justify-between group min-h-[110px]">
            <div class="flex flex-col gap-1">
              <span class="text-xs font-bold text-[var(--fg)] group-hover:text-[var(--accent)] transition-colors">{spoke.name}</span>
              <p class="text-[11px] text-[var(--fg-muted)] leading-relaxed">{spoke.desc}</p>
            </div>
            <span class="text-[10px] text-[var(--fg-muted)] font-medium mt-3 flex items-center gap-0.5">
              Launch tool
              <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Content Guides List -->
    {matchingGuides.length > 0 && (
      <section class="flex flex-col gap-4 pt-4 border-t border-[var(--border)]">
        <h2 class="text-lg font-bold text-[var(--fg)] flex items-center gap-2">
          <svg class="w-4 h-4 text-[var(--fg-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          Expert Construction & DIY Guides
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {matchingGuides.map((guide) => (
            <a href={`/guides/${guide.id}/`} class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] transition-all card-elevated flex flex-col gap-2">
              <span class="text-xs font-semibold text-[var(--fg)]">{guide.data.title}</span>
              <p class="text-[11px] text-[var(--fg-muted)] leading-relaxed line-clamp-2">{guide.data.description}</p>
              <div class="mt-2 flex items-center gap-1.5 text-[10px] text-[var(--fg-muted)]">
                <span class="font-medium">By {guide.data.author.split(' (')[0]}</span>
                <span>•</span>
                <span>{new Date(guide.data.pubDate).toLocaleDateString(undefined, { year: 'numeric', month: 'short' })}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- EEAT Editorial Section (Pillar Content Context) -->
    <section class="mt-6 pt-6 border-t border-[var(--border)] flex flex-col gap-4 text-sm leading-relaxed text-[var(--fg-secondary)] text-pretty">
      <h2 class="text-lg font-bold text-[var(--fg)]">Professional Project Strategy & Methodology</h2>
      <p>
        Planning a structural home improvement project requires aligning raw material geometry with regional building conditions, compaction limits, and load capacities. Every calculator linked above resolves spatial constraints strictly:
      </p>
      <ul class="list-disc pl-5 flex flex-col gap-2.5">
        <li>
          <strong>Excavation & Sub-Base Ratios:</strong> Standard residential layouts require 4 to 6 inches of compacted gravel sub-base to prevent settlement. Be sure to account for a 10-15% compaction loss when purchasing loose aggregate.
        </li>
        <li>
          <strong>Waste Allowances:</strong> Dry bags and lumber cuts are subject to physical layout limits. For straight cuts, apply a 5-10% waste buffer; for complex herringbone layouts, curves, or diagonal slopes, increase this to 15-20% to prevent project delays.
        </li>
        <li>
          <strong>Structural Codes:</strong> Always consult your local municipality and international building codes (e.g. IRC spacing limits for railings and stair risers) before executing any physical excavation or framing.
        </li>
      </ul>
    </section>
  </article>
</Layout>
