---
import Layout from "../../layouts/Layout.astro";
import ProjectWizard from "../../components/project/ProjectWizard";

const title = "New Project";
const description = "Create a new home improvement project plan with guided calculator recommendations.";
---

<Layout title={title} description={description}>
  <article class="max-w-3xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)]" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/projects/" class="hover:text-[var(--fg)] transition-colors">My Projects</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">New Project</span>
    </nav>

    <header class="pb-4 border-b border-[var(--border)]">
      <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-balance">Start a New Project Plan</h1>
      <p class="text-sm text-[var(--fg-muted)] mt-1">Tell us what you are building and enter your dimensions. We will recommend the right calculators in the right order.</p>
    </header>

    <ProjectWizard client:visible />
  </article>
</Layout>
