---
import Layout from "../../layouts/Layout.astro";
import workflowsData from "../../data/workflows.json";
import { graphSchema, breadcrumbListSchema, webPageSchema } from "../../lib/schema";

const title = "Project Playbooks | HomePlanningHub";
const description = "Free construction and home improvement project playbooks — step-by-step execution plans with preparation checklists, tool lists, decision checkpoints, and maintenance tips for every DIY project.";
const canonical = "https://homeplanninghub.com/playbook/";

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Playbooks", path: "/playbook/" }
  ]),
  webPageSchema({ url: canonical, topicName: "Construction Project Playbooks" })
);

const difficultyColor = (level: string) => {
  if (level === "Easy") return "bg-emerald-100 text-emerald-800";
  if (level === "Hard") return "bg-red-100 text-red-800";
  return "bg-amber-100 text-amber-800";
};
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6 no-print" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Playbooks</span>
    </nav>

    <header class="pb-6 border-b border-[var(--border)]">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        Project Playbooks
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty max-w-2xl">
        Every project needs a plan. Each playbook gives you a complete execution guide — preparation checklist, tool list, step-by-step timeline, common mistakes to avoid, and long-term maintenance tips.
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {workflowsData.map((workflow) => {
        const difficulties = [...new Set(workflow.timeline.map((t) => t.diyDifficulty))];
        const durations = workflow.timeline.map((t) => t.duration);
        const totalDuration = durations[0] !== durations[durations.length - 1]
          ? `${durations[0]} – ${durations[durations.length - 1]}`
          : durations[0];
        return (
          <a
            
            href={`/playbook/${workflow.id}/`}
            class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-6 hover:border-[var(--border-hover)] transition-all card-elevated flex flex-col gap-3"
          >
            <div>
              <h2 class="text-base font-semibold text-[var(--fg)]">{workflow.name}</h2>
              <p class="text-xs text-[var(--fg-secondary)] mt-1 leading-relaxed">{workflow.description}</p>
            </div>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-[var(--bg-muted)] text-[var(--fg-muted)] font-medium">
                {workflow.timeline.length} phases
              </span>
              {totalDuration && (
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-[var(--bg-muted)] text-[var(--fg-muted)] font-medium">
                  {totalDuration}
                </span>
              )}
              {difficulties.map((level) => (
                <span  class={`text-[10px] px-2 py-0.5 rounded-full font-medium ${difficultyColor(level)}`}>
                  {level}
                </span>
              ))}
            </div>
          </a>
        );
      })}
    </div>

    <section class="rounded-xl border border-[var(--border)] bg-[var(--bg-subtle)] p-6 mt-4">
      <h2 class="text-sm font-semibold mb-2">What is a Project Playbook?</h2>
      <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">
        A project playbook is a complete execution guide that goes beyond simple material estimates.
        Each playbook includes a preparation checklist, tool list with buy/rent recommendations,
        a step-by-step timeline with difficulty ratings, decision checkpoints to verify before proceeding,
        common mistakes to avoid, cleanup steps, and long-term maintenance tips.
      </p>
      <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty mt-3">
        Use the calculators to get personalized quantities, then print your playbook to take to the job site.
      </p>
    </section>

    <footer class="pt-6 mt-2 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Tools</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/planner/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Project Planner</span>
          <span class="text-[10px] text-[var(--fg-muted)]">Interactive step-by-step workflow.</span>
        </a>
        <a href="/projects/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">My Projects</span>
          <span class="text-[10px] text-[var(--fg-muted)]">Save and manage your plans.</span>
        </a>
        <a href="/planner/shopping-list/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Shopping List</span>
          <span class="text-[10px] text-[var(--fg-muted)]">Consolidated material list.</span>
        </a>
      </div>
    </footer>
  </article>
</Layout>
