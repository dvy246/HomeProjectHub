---
import Layout from "../../layouts/Layout.astro";
import workflowsData from "../../data/workflows.json";
import { graphSchema, breadcrumbListSchema, webPageSchema, howToSchema, faqPageSchema } from "../../lib/schema";

export function getStaticPaths() {
  return workflowsData.map((w) => ({
    params: { projectType: w.id }
  }));
}

const { projectType } = Astro.params;
const workflow = workflowsData.find((w) => w.id === projectType);

if (!workflow) {
  return Astro.redirect("/playbook/");
}

const title = `${workflow.name} Playbook | HomePlanningHub`;
const description = `Complete ${workflow.name.toLowerCase()} playbook — step-by-step timeline, preparation checklist, tool list, common mistakes, and printable execution plan for DIYers and homeowners.`;
const canonical = `https://homeplanninghub.com/playbook/${projectType}/`;

const difficulties = [...new Set(workflow.timeline.map((t) => t.diyDifficulty))];
const totalDuration = (() => {
  const d = workflow.timeline.map((t) => t.duration);
  return d[0] !== d[d.length - 1] ? `${d[0]} – ${d[d.length - 1]}` : d[0];
})();

const howToSteps = workflow.timeline.map((t) => ({
  name: t.phase,
  text: `${t.description} (${t.duration}, ${t.diyDifficulty} difficulty)`
}));

const faqItems = [
  ...(workflow.timeline.length > 0 ? [{
    q: `How long does a ${workflow.name.toLowerCase()} take?`,
    a: `A typical ${workflow.name.toLowerCase()} takes ${totalDuration} across ${workflow.timeline.length} phases. ${workflow.timeline[0].description.split('.')[0]}.`
  }] : []),
  ...(difficulties.length > 0 ? [{
    q: `Can I DIY a ${workflow.name.toLowerCase()}?`,
    a: `This project ranges from ${difficulties.join(' to ')} difficulty. ${workflow.timeline.map(t => `"${t.phase}" is rated ${t.diyDifficulty} — ${t.hiringRecommendation}`).join('. ')}. Assess your skill level honestly before starting.`
  }] : []),
  {
    q: `What materials do I need for a ${workflow.name.toLowerCase()}?`,
    a: `Use our ${workflow.name.replace(' Project', '')} Calculator to get exact material quantities. Enter your dimensions and the calculator will tell you exactly how much material to buy.`
  },
  {
    q: `What are common mistakes in ${workflow.name.toLowerCase()}?`,
    a: workflow.mistakes.slice(0, 3).map((m) => m.replace(/\.$/, '')).join('. ') + '.'
  },
  ...(workflow.maintenanceTips && workflow.maintenanceTips.length > 0 ? [{
    q: `How do I maintain my ${workflow.name.toLowerCase()} after completion?`,
    a: workflow.maintenanceTips.slice(0, 3).map((t) => t.replace(/\.$/, '')).join('. ') + '.'
  }] : []),
];

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Playbooks", path: "/playbook/" },
    { name: workflow.name, path: `/playbook/${projectType}/` }
  ]),
  webPageSchema({ url: canonical, topicName: title }),
  howToSchema(
    `How to Plan a ${workflow.name}`,
    workflow.description,
    howToSteps
  ),
  faqPageSchema(faqItems, canonical)
);
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <article class="max-w-3xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6 no-print" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/playbook/" class="hover:text-[var(--fg)] transition-colors">Playbooks</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">{workflow.name}</span>
    </nav>

    <header class="pb-6 border-b border-[var(--border)]">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        {workflow.name} Playbook
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        {workflow.description}
      </p>
      <div class="flex flex-wrap gap-2 mt-4">
        <span class="text-xs px-3 py-1 rounded-full bg-[var(--bg-muted)] text-[var(--fg-secondary)] font-medium">
          {workflow.timeline.length} phases
        </span>
        {totalDuration && (
          <span class="text-xs px-3 py-1 rounded-full bg-[var(--bg-muted)] text-[var(--fg-secondary)] font-medium">
            {totalDuration}
          </span>
        )}
        {difficulties.map((level) => (
          <span class={`text-xs px-3 py-1 rounded-full font-medium ${
            level === "Easy" ? "bg-emerald-100 text-emerald-800" :
            level === "Hard" ? "bg-red-100 text-red-800" :
            "bg-amber-100 text-amber-800"
          }`}>
            {level}
          </span>
        ))}
      </div>
    </header>

    <div class="rounded-xl border border-[var(--border)] bg-[var(--accent)]/5 p-6 text-center">
      <p class="text-sm font-semibold text-[var(--fg)] mb-2">Get Personalized Quantities</p>
      <p class="text-xs text-[var(--fg-secondary)] mb-4">Enter your dimensions in the calculator to get exact material counts, then print your playbook.</p>
      <a
        href={`/planner/${projectType}/`}
        class="inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-semibold rounded-lg bg-[var(--accent)] text-white hover:bg-[var(--accent-hover)] transition-all shadow-sm"
      >
        Start Planning
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>

    <section>
      <h2 class="text-lg font-bold tracking-tight mb-4">Preparation Checklist</h2>
      <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
        {workflow.preparationSteps && workflow.preparationSteps.length > 0 ? (
          <ul class="flex flex-col gap-2 text-sm">
            {workflow.preparationSteps.map((step) => (
              <li  class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-[var(--accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span class="text-[var(--fg)]">{step}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-sm text-[var(--fg-muted)]">Use the interactive planner for a personalized preparation checklist.</p>
        )}
      </div>
    </section>

    <section>
      <h2 class="text-lg font-bold tracking-tight mb-4">Tools & Equipment</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        {workflow.accessoryTools.map((tool) => (
          <div  class="flex items-center justify-between p-3 rounded-lg border border-[var(--border)] bg-[var(--card-bg)]">
            <span class="text-sm text-[var(--fg)]">{tool.name}</span>
            <span class={`text-[10px] font-semibold px-2 py-0.5 rounded-full uppercase tracking-wide ${
              tool.recommendation === "buy" ? "bg-blue-100 text-blue-700" :
              tool.recommendation === "rent" ? "bg-amber-100 text-amber-700" :
              "bg-purple-100 text-purple-700"
            }`}>
              {tool.recommendation}
            </span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-lg font-bold tracking-tight mb-4">Execution Timeline</h2>
      <div class="flex flex-col gap-4">
        {workflow.timeline.map((phase, idx) => (
          <div  class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
            <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
              <div class="flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-[var(--accent)]/10 text-[var(--accent)] flex items-center justify-center text-xs font-bold">{idx + 1}</span>
                <h3 class="text-sm font-semibold text-[var(--fg)]">{phase.phase}</h3>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-[var(--fg-muted)]">{phase.duration}</span>
                <span class={`text-[10px] font-semibold px-2 py-0.5 rounded-full ${
                  phase.diyDifficulty === "Easy" ? "bg-emerald-100 text-emerald-800" :
                  phase.diyDifficulty === "Hard" ? "bg-red-100 text-red-800" :
                  "bg-amber-100 text-amber-800"
                }`}>
                  {phase.diyDifficulty}
                </span>
              </div>
            </div>
            <p class="text-sm text-[var(--fg-secondary)] leading-relaxed">{phase.description}</p>
            <p class="text-xs text-[var(--fg-muted)] mt-2 italic">{phase.hiringRecommendation}</p>
          </div>
        ))}
      </div>
    </section>

    {workflow.mistakes.length > 0 && (
      <section>
        <h2 class="text-lg font-bold tracking-tight mb-4">Common Mistakes</h2>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
          <ul class="flex flex-col gap-2 text-sm">
            {workflow.mistakes.map((mistake) => (
              <li  class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
                <span class="text-[var(--fg)]">{mistake}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {workflow.cleanupSteps && workflow.cleanupSteps.length > 0 && (
      <section>
        <h2 class="text-lg font-bold tracking-tight mb-4">Cleanup Checklist</h2>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
          <ul class="flex flex-col gap-2 text-sm">
            {workflow.cleanupSteps.map((step) => (
              <li  class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-[var(--fg-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
                <span class="text-[var(--fg)]">{step}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {workflow.maintenanceTips && workflow.maintenanceTips.length > 0 && (
      <section>
        <h2 class="text-lg font-bold tracking-tight mb-4">Maintenance Tips</h2>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
          <ul class="flex flex-col gap-2 text-sm">
            {workflow.maintenanceTips.map((tip) => (
              <li  class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
                <span class="text-[var(--fg)]">{tip}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {workflow.related && workflow.related.length > 0 && (
      <section>
        <h2 class="text-lg font-bold tracking-tight mb-4">Related Resources</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {workflow.related.map((rel) => (
            <a  href={rel.url} class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-all card-elevated">
              <span class="block text-sm font-semibold text-[var(--fg)] mb-1">{rel.name}</span>
              <span class="text-xs text-[var(--fg-muted)]">View calculator</span>
            </a>
          ))}
          <a href={`/planner/${projectType}/`} class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-all card-elevated">
            <span class="block text-sm font-semibold text-[var(--fg)] mb-1">Interactive Planner</span>
            <span class="text-xs text-[var(--fg-muted)]">Step-by-step project workflow</span>
          </a>
        </div>
      </section>
    )}
  </article>
</Layout>
