---
import Layout from "../../../layouts/Layout.astro";
import Quiz from "../../../components/Quiz";
import AdSlot from "../../../components/AdSlot.astro";
import { STONE_WEIGHT_QUESTIONS } from "../../../data/quizzes/stone-weight";
import { graphSchema, webPageSchema, breadcrumbListSchema, faqPageSchema } from "../../../lib/schema";

const canonical = "https://homeprojecthub.com/quizzes/stone-weight/";
const title = "Stone Weight Quiz";
const description = "Test your knowledge of natural stone weights and densities. Questions cover granite, marble, sandstone, countertop weights, and stone material properties.";
const PAGE_PATH = "/quizzes/stone-weight/";

const schema = graphSchema(
  breadcrumbListSchema([{ name: "Home", path: "/" }, { name: "Quizzes", path: "/quizzes/" }, { name: title, path: PAGE_PATH }]),
  webPageSchema({ url: canonical, topicName: title }),
  faqPageSchema([
    { q: "How much does granite weigh per cubic foot?", a: "Granite weighs approximately 170 lb/cu ft (2,700 kg/cu m). This makes it one of the denser natural stones used in countertops." },
    { q: "How do I calculate stone countertop weight?", a: "Multiply the length × width × thickness to get volume, then multiply by the stone's density. A typical 3 cm granite slab weighs 15-19 lbs per sq ft." },
    { q: "What is the lightest natural stone?", a: "Sandstone and limestone are among the lightest natural stones at about 145-150 lb/cu ft, due to their higher porosity." },
    { q: "Why is stone weight important for installation?", a: "Stone countertops are very heavy. A typical kitchen island slab can weigh 200-400 lbs, requiring adequate cabinet support and multiple installers." },
  ], canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/quizzes/" class="hover:text-[var(--fg)] transition-colors">Quizzes</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Stone Weight</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Stone Weight Quiz</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Test your knowledge of natural stone densities, countertop weights, and material properties. This 8-question quiz covers granite, marble, sandstone, and practical installation considerations.</p>
    <AdSlot slotId="ad-top-leaderboard" />
    <section><Quiz title="Stone Weight Quiz" questions={STONE_WEIGHT_QUESTIONS} client:visible /></section>
    <AdSlot slotId="ad-in-content-mid" />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Stone Weight Reference</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does a granite countertop weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 3 cm (1-1/4\") granite slab weighs 15-19 lbs per sq ft. A typical kitchen with 40 sq ft of countertop weighs 600-760 lbs total.</p></details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Does stone density vary by color?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Yes, darker granites tend to be denser because they have more dark minerals (biotite, hornblende) and less quartz. Density varies by mineral composition, not color alone.</p></details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How does engineered quartz compare to granite?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Engineered quartz (Caesarstone, Silestone) has similar density to granite at about 165-170 lb/cu ft. It's slightly more uniform since it's manufactured rather than natural.</p></details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Do I need special cabinets for stone countertops?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Standard 3/4\" plywood cabinets are sufficient for most stone countertops. Wider spans (over 36\") between cabinets may need additional support or plywood substrate.</p></details>
      </div>
    </section>
    <p class="text-xs text-[var(--fg-muted)]">Use our <a href="/calculators/stone-weight/" class="text-[var(--accent)] hover:underline">Stone Weight Calculator</a> to estimate weights for any stone type and dimensions.</p>
  </article>
</Layout>
