---
import Layout from "../../layouts/Layout.astro";

const title = "Shopping List Generator";
const description = "Generate a consolidated shopping list from your saved home improvement projects.";

const checklists = [
  { project: "Concrete Slab", items: ["Concrete mix or ready-mix quote", "Gravel base", "Form boards and stakes", "Rebar or welded wire mesh if specified", "Expansion/control joint material", "Concrete sealer", "Trowel, float, screed board, gloves"] },
  { project: "Concrete Steps", items: ["Concrete mix or ready-mix quote", "Rebar pins if specified", "Gravel backfill", "Form lumber", "Step edge forms", "Release agent", "Finishing tools"] },
  { project: "Roof Shingles", items: ["Shingle bundles", "Underlayment", "Drip edge", "Starter strip", "Ridge cap shingles", "Roofing nails", "Flashing and pipe boots", "Dumpster or tear-off bags"] },
  { project: "Metal Roof", items: ["Metal panels", "Screws with neoprene washers", "Ridge cap", "Drip edge", "Valley flashing", "Pipe boots", "Underlayment", "Cutting tools approved for panel type"] },
  { project: "Paint Room", items: ["Paint gallons", "Primer if needed", "Painter's tape", "Drop cloths", "Roller covers", "Brushes", "Tray and liners", "Spackle and putty knife", "Sandpaper"] },
  { project: "Tile Floor", items: ["Tile boxes plus waste", "Thinset mortar", "Grout", "Notched trowel", "Spacers", "Tile cutter or wet saw", "Backer board if needed", "Grout sealer"] },
];
---

<Layout title={title} description={description} noindex={true}>
  <article class="max-w-3xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/planner/" class="hover:text-[var(--fg)] transition-colors">Planner</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Shopping List</span>
    </nav>

    <header class="pb-6 mb-2 border-b border-[var(--border)]">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        Shopping List Generator
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Build a printable checklist from your project estimate. Use the calculators to determine quantities, then verify the final products and coverage rates before buying.
      </p>
    </header>

    <section class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-6">
      <h2 class="text-sm font-semibold mb-3">How It Works</h2>
      <ol class="flex flex-col gap-3 text-sm text-[var(--fg-secondary)]">
        <li class="flex gap-3">
          <span class="w-6 h-6 rounded-full bg-[var(--bg-muted)] flex items-center justify-center text-xs font-bold shrink-0">1</span>
          <span>Save your room dimensions in the <a href="/saved/" class="text-[var(--fg)] underline underline-offset-2 hover:no-underline">Saved Measurements</a> workspace.</span>
        </li>
        <li class="flex gap-3">
          <span class="w-6 h-6 rounded-full bg-[var(--bg-muted)] flex items-center justify-center text-xs font-bold shrink-0">2</span>
          <span>Use each calculator (Concrete, Roofing, Paint, Tile) and apply your saved dimensions to calculate exact material quantities.</span>
        </li>
        <li class="flex gap-3">
          <span class="w-6 h-6 rounded-full bg-[var(--bg-muted)] flex items-center justify-center text-xs font-bold shrink-0">3</span>
          <span>Print this page or copy the relevant checklist before visiting a supplier.</span>
        </li>
      </ol>
    </section>

    <!-- Quick-reference checklist -->
    <section>
      <h2 class="text-lg font-bold tracking-tight mb-4">Project Checklist</h2>
      <div class="flex flex-col gap-2">
        {checklists.map((section) => (
          <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-4 text-sm font-medium text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors list-none">
              {section.project}
              <svg class="w-4 h-4 text-[var(--fg-muted)] group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-4 pb-4">
              <ul class="flex flex-col gap-1.5 text-sm text-[var(--fg-secondary)]">
                {section.items.map((item) => (
                  <li class="flex items-center gap-2">
                    <input type="checkbox" class="w-4 h-4 rounded border-[var(--border)] text-[var(--accent)]" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="rounded-xl border border-[var(--border)] bg-[var(--bg-subtle)] p-6">
      <h2 class="text-sm font-semibold mb-2">Pro Tip</h2>
      <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Use the <a href="/calculators/concrete/slab/" class="underline underline-offset-2 hover:no-underline">Concrete Slab Calculator</a>, <a href="/calculators/paint/" class="underline underline-offset-2 hover:no-underline">Paint Calculator</a>, and <a href="/calculators/tile/" class="underline underline-offset-2 hover:no-underline">Tile Calculator</a> to estimate quantities. Product coverage, regional availability, delivery fees, and local code requirements can change, so verify the final list with the label, supplier, or contractor.
      </p>
    </section>

    <footer class="pt-8 mt-4 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Tools</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/saved/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Saved Measurements</span>
          <span class="text-[10px] text-[var(--fg-muted)]">Store your project dimensions.</span>
        </a>
        <a href="/compare/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Compare Materials</span>
          <span class="text-[10px] text-[var(--fg-muted)]">Side-by-side material comparison.</span>
        </a>
        <a href="/guides/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Planning Guides</span>
          <span class="text-[10px] text-[var(--fg-muted)]">Expert guides for your project.</span>
        </a>
      </div>
    </footer>
  </article>
</Layout>
