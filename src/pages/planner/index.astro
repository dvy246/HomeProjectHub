---
import Layout from "../../layouts/Layout.astro";

const title = "Project Planner";
const description = "Plan your home improvement projects from start to finish. Save room dimensions, calculate materials, compare options, and generate a shopping list.";

const projectTemplates = [
  {
    name: "Patio Slab",
    bestFor: "Backyard patios, shed bases, walkways",
    assumptions: "Rectangular area, uniform slab thickness, user-selected waste factor",
    steps: ["Measure length and width", "Choose slab thickness", "Calculate concrete", "Compare pavers or gravel", "Build shopping checklist"],
    calculator: "/calculators/concrete/slab/",
    compare: "/compare/concrete-vs-pavers/",
  },
  {
    name: "Room Painting",
    bestFor: "Bedrooms, living rooms, interior repainting",
    assumptions: "Wall area minus openings, standard coat count, product coverage verified on paint label",
    steps: ["Measure walls", "Subtract doors and windows", "Estimate gallons", "Add primer and supplies", "Print checklist"],
    calculator: "/calculators/paint/",
    compare: "/guides/paint-estimating-guide/",
  },
  {
    name: "Tile Floor",
    bestFor: "Bathrooms, kitchens, laundry rooms",
    assumptions: "Floor area plus waste for cuts and pattern complexity",
    steps: ["Measure floor area", "Select tile pattern", "Estimate tile boxes", "Add thinset and grout", "Check tool rentals"],
    calculator: "/calculators/tile/",
    compare: "/guides/tile-installation-guide/",
  },
  {
    name: "Roof Shingles",
    bestFor: "Simple residential roof replacement planning",
    assumptions: "Roof area, pitch factor, waste, bundles per square",
    steps: ["Measure roof footprint", "Calculate pitch", "Estimate squares", "Add underlayment and ridge cap", "Verify with roofer"],
    calculator: "/calculators/roofing/shingles/",
    compare: "/compare/shingles-vs-metal-roof/",
  },
];
---

<Layout title={title} description={description} noindex={true}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Project Planner</span>
    </nav>

    <header class="pb-6 mb-2 border-b border-[var(--border)]">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        Project Planner
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Plan your home improvement project from start to finish. Save room dimensions in your workspace, use calculators to estimate materials, compare material options side by side, and generate a complete shopping list.
      </p>
    </header>

    <section class="rounded-xl border border-[var(--border)] bg-[var(--bg-subtle)] p-6">
      <h2 class="text-lg font-bold tracking-tight mb-2">Start with a project type</h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-5">
        Pick the closest project below, then use the linked calculator and checklist to build a planning estimate. Each template states its assumptions so you can decide what still needs local verification.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {projectTemplates.map((project) => (
          <article class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 card-elevated">
            <h3 class="text-sm font-semibold tracking-tight mb-1">{project.name}</h3>
            <p class="text-xs text-[var(--fg-muted)] mb-3">{project.bestFor}</p>
            <p class="text-xs text-[var(--fg-secondary)] leading-relaxed mb-4">
              <strong class="text-[var(--fg)]">Assumes:</strong> {project.assumptions}
            </p>
            <ol class="flex flex-col gap-1.5 text-xs text-[var(--fg-secondary)] mb-4">
              {project.steps.map((step, index) => (
                <li><span class="font-mono text-[10px] text-[var(--fg-muted)]">{index + 1}.</span> {step}</li>
              ))}
            </ol>
            <div class="flex flex-wrap gap-2">
              <a href={project.calculator} class="inline-flex items-center justify-center px-3 py-1.5 text-xs font-medium rounded-lg bg-[var(--accent)] text-[var(--accent-fg)] border border-[var(--accent)] hover:bg-[var(--accent-hover)] transition-colors">
                Open calculator
              </a>
              <a href={project.compare} class="inline-flex items-center justify-center px-3 py-1.5 text-xs font-medium rounded-lg border border-[var(--border-strong)] text-[var(--fg)] hover:border-[var(--border-hover)] hover:bg-[var(--bg-muted)] transition-colors">
                Compare options
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Workflow Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href="/saved/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-all">
        <div class="w-9 h-9 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center mb-3 text-[var(--fg-secondary)]">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
        </div>
        <h2 class="text-sm font-semibold mb-1">1. Save Measurements</h2>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed">Store room and project dimensions in your browser workspace.</p>
      </a>

      <a href="/calculators/concrete/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-all">
        <div class="w-9 h-9 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center mb-3 text-[var(--fg-secondary)]">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
        </div>
        <h2 class="text-sm font-semibold mb-1">2. Calculate Materials</h2>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed">Use our calculators to estimate concrete, roofing, paint, or tile quantities.</p>
      </a>

      <a href="/compare/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-all">
        <div class="w-9 h-9 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center mb-3 text-[var(--fg-secondary)]">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
        </div>
        <h2 class="text-sm font-semibold mb-1">3. Compare Materials</h2>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed">Side-by-side comparison of concrete, pavers, gravel, and other options.</p>
      </a>

      <a href="/planner/shopping-list/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-all">
        <div class="w-9 h-9 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center mb-3 text-[var(--fg-secondary)]">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
        </div>
        <h2 class="text-sm font-semibold mb-1">4. Shopping List</h2>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed">Use printable checklists for common project materials and supplies.</p>
      </a>
    </div>

    <!-- Link to Saved Projects -->
    <section class="rounded-xl border border-[var(--accent)]/30 bg-[var(--accent)]/5 p-6 text-center">
      <h2 class="text-sm font-bold tracking-tight mb-2">Your Saved Projects</h2>
      <p class="text-xs text-[var(--fg-secondary)] mb-4">View your project plans with linked calculator results and aggregated shopping lists.</p>
      <a href="/projects/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg bg-[var(--accent)] text-[var(--accent-fg)] hover:bg-[var(--accent-hover)] border border-[var(--accent)] shadow-sm transition-all">
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
        Go to My Projects
      </a>
    </section>

    <!-- Get Started CTA -->
    <section class="rounded-xl border border-[var(--border)] bg-[var(--bg-subtle)] p-8 text-center mt-4">
      <h2 class="text-xl font-bold tracking-tight mb-3">Ready to start planning?</h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-6 max-w-lg mx-auto">
        Enter your project dimensions once in the Saved Measurements workspace, then use them across calculators that support saved dimensions. Verify final material choices against product labels, contractor quotes, and local building requirements.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/saved/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg bg-[var(--accent)] text-[var(--accent-fg)] hover:bg-[var(--accent-hover)] border border-[var(--accent)] shadow-sm transition-all active:scale-[0.98]">
          Get Started
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
        <a href="/guides/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg border border-[var(--border-strong)] text-[var(--fg)] hover:border-[var(--border-hover)] hover:bg-[var(--bg-muted)] transition-all">
          Read the Guides
        </a>
      </div>
    </section>
  </article>
</Layout>
