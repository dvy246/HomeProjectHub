---
import Layout from "../../layouts/Layout.astro";
import ProjectWorkflow from "../../components/project/ProjectWorkflow";
import workflowsData from "../../data/workflows.json";
import { graphSchema, breadcrumbListSchema, webPageSchema } from "../../lib/schema";

export function getStaticPaths() {
  return workflowsData.map((w) => ({
    params: { workflow: w.id }
  }));
}

const { workflow } = Astro.params;
const workflowDetails = workflowsData.find((w) => w.id === workflow);

const title = `${workflowDetails?.name || "Project"} Planner | HomePlanningHub`;
const description = workflowDetails?.description || "Plan your next renovation or construction project step-by-step.";
const canonical = `https://homeplanninghub.com/planner/${workflow}/`;

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Planner", path: `/planner/${workflow}/` }
  ]),
  webPageSchema({ url: canonical, topicName: title })
);
---

<Layout title={title} description={description} canonical={canonical} schema={schema} noindex={true}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6 no-print" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/projects/" class="hover:text-[var(--fg)] transition-colors">Projects</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Planner</span>
    </nav>

    <header class="pb-6 mb-2 border-b border-[var(--border)] no-print">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        {workflowDetails?.name || "Project"} Planner
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        {description}
      </p>
    </header>

    <ProjectWorkflow client:visible workflowId={workflow} />
  </article>
</Layout>
