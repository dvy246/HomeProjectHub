---
import Layout from "../../../layouts/Layout.astro";
import ConcreteSlabDesigner from "../../../components/calculators/ConcreteSlabDesigner";
import AdSlot from "../../../components/AdSlot.astro";
import EstimateMethodology from "../../../components/EstimateMethodology.astro";
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro";
import { graphSchema, mathSolverSchema, faqPageSchema, breadcrumbListSchema, webApplicationSchema, howToSchema } from "../../../lib/schema";
import { BLUEPRINT_SLAB_SEEDS } from "../../../data/blueprint-seeds";
import { computeSlab } from "../../../lib/concreteSlabEngine";

export function getStaticPaths() {
  return BLUEPRINT_SLAB_SEEDS.map((seed) => ({
    params: { slug: seed.slug },
    props: { seed },
  }));
}

interface Props {
  seed: (typeof BLUEPRINT_SLAB_SEEDS)[number];
}

const { seed } = Astro.props;

// Compute values at build-time using our TS Engine
const result = computeSlab({
  shape: seed.shape,
  lengthA: seed.length,
  widthA: seed.width,
  lengthB: 0,
  widthB: 0,
  diameter: seed.diameter ?? seed.length,
  thickness: seed.thickness,
  subBaseMaterial: "crushed-stone",
  subBaseDepth: 4,
  reinforcement: seed.shape === "rect" ? "rebar" : "none",
  rebarSize: "#4",
  rebarSpacing: 18,
  finish: "broom",
  vaporBarrier: true,
  wasteFactor: 10,
  bagSize: "80lb",
});

const canonical = `https://homeplanninghub.com/calculators/concrete-slab-designer/${seed.slug}/`;
const title = `${seed.label} Material Blueprint & Layout Estimator`;
const description = `Get exact material specifications and visual layouts for a ${seed.label.toLowerCase()}. Pre-calculated bag counts, rebar grid spacing, and weight.`;
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

// Pre-render FAQs matching the exact dimensions
const faqs = [
  {
    q: `How many bags of concrete do I need for a ${seed.label.toLowerCase()}?`,
    a: `For a ${seed.label.toLowerCase()}, you will need approximately ${result.bagCount} bags of 80lb concrete mix. If you prefer other sizes, it requires ${result.bags.find(b => b.size === "60lb")?.count || 0} bags of 60lb mix or ${result.bags.find(b => b.size === "50lb")?.count || 0} bags of 50lb mix (includes 10% waste buffer).`,
  },
  {
    q: `What is the volume in cubic yards for a ${seed.length}x${seed.width} slab that is ${seed.thickness} inches thick?`,
    a: `The total concrete volume required is ${result.volumeCuYd.toFixed(2)} cubic yards (which translates to ${result.volumeCuFt.toFixed(1)} cubic feet). This accounts for a 10% waste factor for subgrade variance and form flex.`,
  },
  {
    q: `How much rebar is needed for a ${seed.length}x${seed.width} concrete grid?`,
    a: seed.shape === "rect" 
      ? `A ${seed.length}x${seed.width} rectangular slab configured with #4 rebar at 18 inches spacing on center requires ${result.rebarGrid?.sticksCount || 0} sticks of 20ft rebar, totaling ${result.rebarGrid?.totalLinearFt || 0} linear feet.`
      : "Circular slabs do not require a standard rectangular grid. Instead, wire mesh or fiber mesh can be used for general reinforcement.",
  }
];

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Concrete Calculators", path: "/calculators/concrete/" },
    { name: "Concrete Slab Designer", path: "/calculators/concrete-slab-designer/" },
    { name: seed.label, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: `${seed.label} Volume Formula`,
    description: `Compute dimensions for a ${seed.length} by ${seed.width} feet concrete slab at ${seed.thickness} inches thick.`,
    formula: seed.shape === "circle"
      ? `Volume = (π × (${seed.diameter} ÷ 2)² × (${seed.thickness} ÷ 12)) ÷ 27`
      : `Volume = (${seed.length} × ${seed.width} × (${seed.thickness} ÷ 12)) ÷ 27`,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Calculate Slab Volume",
      text: seed.shape === "circle"
        ? `Determine area: π × r² = 3.1416 × (${(seed.diameter ?? 10) / 2})² = ${result.area.toFixed(1)} sq ft. Volume = ${result.area.toFixed(1)} sq ft × ${(seed.thickness / 12).toFixed(3)} ft = ${result.volumeCuFt.toFixed(1)} cu ft.`
        : `Multiply length by width: ${seed.length}ft × ${seed.width}ft = ${result.area.toFixed(1)} sq ft. Volume = ${result.area.toFixed(1)} sq ft × ${(seed.thickness / 12).toFixed(3)} ft = ${result.volumeCuFt.toFixed(1)} cu ft.`,
    },
    {
      name: "Add Waste Factor",
      text: `Add 10% waste buffer to account for form flex: ${result.volumeCuFt.toFixed(1)} cu ft × 1.1 = ${result.volumeCuFt.toFixed(1)} cu ft. Convert to yards: ${result.volumeCuYd.toFixed(2)} cu yd.`,
    },
    {
      name: "Calculate Material Bags",
      text: `An 80lb bag yields 0.60 cu ft. Total bags: ${result.bagCount} bags.`,
    }
  ]),
  faqPageSchema(faqs, canonical)
);
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <article class="max-w-5xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/concrete/" class="hover:text-[var(--fg)] transition-colors">Concrete</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/concrete-slab-designer/" class="hover:text-[var(--fg)] transition-colors">Slab Designer</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">{seed.label}</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">{seed.label} Layout & Material Specs</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-3xl">
      Pre-calculated blueprints and complete material quantities for a {seed.label.toLowerCase()}. View structural details, rebar stick counts, and required sub-base materials. Customize the design in real-time below.
    </p>

    <AdSlot slotId="ad-top-leaderboard" />

    <!-- Static Build-time Output for SEO crawlability and fast page load -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 no-print">
      <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
        <h2 class="text-base font-bold tracking-tight mb-4">Calculated Dimensions</h2>
        <table class="w-full text-sm text-left border-collapse">
          <tbody class="text-[var(--fg-secondary)]">
            <tr class="border-b border-[var(--border)]">
              <td class="py-2.5">Slab Shape</td>
              <td class="py-2.5 font-semibold text-[var(--fg)] capitalize">{seed.shape}</td>
            </tr>
            <tr class="border-b border-[var(--border)]">
              <td class="py-2.5">Surface Area</td>
              <td class="py-2.5 font-semibold text-[var(--fg)]">{result.area.toFixed(1)} sq ft</td>
            </tr>
            <tr class="border-b border-[var(--border)]">
              <td class="py-2.5">Thickness</td>
              <td class="py-2.5 font-semibold text-[var(--fg)]">{seed.thickness} inches</td>
            </tr>
            <tr class="border-b border-[var(--border)]">
              <td class="py-2.5">Concrete Volume (with 10% waste)</td>
              <td class="py-2.5 font-semibold text-[var(--fg)]">{result.volumeCuYd.toFixed(2)} cu yd</td>
            </tr>
            <tr>
              <td class="py-2.5">Total Concrete Dry Weight</td>
              <td class="py-2.5 font-semibold text-[var(--fg)]">{result.weightLbs.toLocaleString()} lbs</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
        <h2 class="text-base font-bold tracking-tight mb-4">Required Materials</h2>
        <ul class="text-sm text-[var(--fg-secondary)] space-y-2 list-none pl-0">
          {result.materialList.map((item) => (
            <li class="flex justify-between py-1 border-b border-[var(--border)] last:border-0">
              <span>{item.name}</span>
              <span class="font-semibold text-[var(--fg)]">{item.quantity} {item.unit}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Live Interactive Component Hydrated client-side -->
    <section class="mt-4">
      <h2 class="text-lg font-bold mb-4">Interactive Builder for {seed.label}</h2>
      <ConcreteSlabDesigner 
        client:visible 
        initialLength={seed.length.toString()} 
        initialWidth={seed.width.toString()} 
        initialThickness={seed.thickness.toString()} 
        initialShape={seed.shape} 
        initialReinforcement={seed.shape === "rect" ? "rebar" : "none"}
      />
    </section>

    <EstimateMethodology
      formula="Volume = Area × Thickness; includes 10% waste factor and sub-base compaction rules."
      assumptions={[
        `Calculations are tailored for a ${seed.label.toLowerCase()}.`,
        "Pre-loaded rebar calculations assume #4 rebar at 18\" spacings on center.",
        "Compacted sub-base assumes 4 inches of crushed stone (#57)."
      ]}
    />

    <section class="prose dark:prose-invert max-w-none text-sm text-[var(--fg-secondary)] leading-relaxed space-y-6">
      <h2 class="text-xl font-bold text-[var(--fg)]">Construction Guide for {seed.label}</h2>
      <p>
        Building a {seed.label.toLowerCase()} requires meticulous planning and spatial coordination. Use the interactive designer above to adjust rebar configurations, change the sub-base material (gravel, crushed stone, or sand), and customize control joint lines. Proper installation of control joints ensures that any settling or cure-time contraction will produce clean fractures inside the pre-planned joint weak lines rather than unsightly surface cracks.
      </p>
    </section>

    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        {faqs.map((faq) => (
          <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
            <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">{faq.q}</h3></summary>
            <p class="mt-3 text-sm text-[var(--fg-secondary)]">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators slug="concrete-slab-designer" />
  </article>
</Layout>
