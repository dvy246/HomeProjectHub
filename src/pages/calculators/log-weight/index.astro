---
import Layout from "../../../layouts/Layout.astro"
import LogWeightCalc from "../../../components/calculators/LogWeightCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/log-weight/";
const title = "Log Weight Calculator";
const description = "Estimate the weight of a log based on diameter, length, and species.";
const formula = "Volume (cu ft) = (pi x (D/12)^2 x L) / 4 | Weight = Volume x Density";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Weight", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How much does an 8 ft oak log weigh?", a: "An 8 ft oak log with 12\" diameter weighs about 300 lbs. Oak density averages 47 lb/cu ft. Volume: (pi x 1^2 x 8) / 4 = 6.3 cu ft x 47 = 296 lbs." },
    { q: "What is the heaviest common log species?", a: "Hickory at 50 lb/cu ft and white oak at 47 lb/cu ft are among the heaviest. Balsa at 9 lb/cu ft is the lightest." },
    { q: "How do I estimate log volume for weight?", a: "Use the formula: (pi x diameter^2 x length) / 4 for cylindrical volume. For tapered logs, measure diameter at the mid-point." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Log Weight Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Log Weight Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Estimate the weight of a log based on diameter, length, and species.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><LogWeightCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Log approximated as a cylinder — actual taper may reduce volume.", "Species density values from the USDA Wood Handbook.", "Weight assumes green (freshly cut) moisture content.", "Standing timber weight is higher than milled lumber weight.", "Bark weight not included — adds ~10% to total."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does an 8 ft oak log weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">An 8 ft oak log with 12" diameter weighs about 300 lbs. Oak density averages 47 lb/cu ft. Volume: (pi x 1^2 x 8) / 4 = 6.3 cu ft x 47 = 296 lbs.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the heaviest common log species?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Hickory at 50 lb/cu ft and white oak at 47 lb/cu ft are among the heaviest. Balsa at 9 lb/cu ft is the lightest.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do I estimate log volume for weight?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Use the formula: (pi x diameter^2 x length) / 4 for cylindrical volume. For tapered logs, measure diameter at the mid-point.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/lumber/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Lumber</span></a>
    <a href="/calculators/size-to-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Size to Weight</span></a>
    <a href="/calculators/board-foot/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Board Foot</span></a>
  </div></footer>
</article>
</Layout>
