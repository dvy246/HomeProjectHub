---
import Layout from "../../../layouts/Layout.astro"
import AggregateCalc from "../../../components/calculators/AggregateCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/limestone/";
const title = "Limestone Calculator";
const description = "Calculate crushed limestone quantity in tons and cubic yards.";
const formula = "Tons = Cubic Yards x 1.55";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Landscaping", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How much crushed limestone for a driveway?", a: "A 10x40 ft driveway at 6\" depth needs about 5.9 tons: (400 x 0.5) / 27 = 7.4 cu yd x 1.55 = 11.5 tons." },
    { q: "What size crushed limestone is best for driveways?", a: "#57 stone (1-1.5\") is standard for driveways. #8 (3/8-1/2\") is better for walkways. #4 (2-4\") is used as base course." },
    { q: "Does limestone weigh more than gravel?", a: "Crushed limestone is slightly denser — 1.55 tons/cu yd vs gravel at 1.4 tons/cu yd. This is because limestone packs tighter." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Limestone Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Limestone Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate crushed limestone quantity in tons and cubic yards.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><AggregateCalc client:visible aggregates={[{ id: "limestone", label: "Crushed Limestone (1.55 t/cu yd)", tonsPerCuYd: 1.55 }]} defaultKey="limestone" calculatorLabel="Limestone" /></section>
  <EstimateMethodology formula={formula} assumptions={["Limestone density: 1.55 tons per cubic yard.", "Compaction factor: material settles 10-15%.", "Depth recommendations for driveways: 6 inches."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much crushed limestone for a driveway?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 10x40 ft driveway at 6" depth needs about 5.9 tons: (400 x 0.5) / 27 = 7.4 cu yd x 1.55 = 11.5 tons.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What size crushed limestone is best for driveways?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">#57 stone (1-1.5") is standard for driveways. #8 (3/8-1/2") is better for walkways. #4 (2-4") is used as base course.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Does limestone weigh more than gravel?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Crushed limestone is slightly denser — 1.55 tons/cu yd vs gravel at 1.4 tons/cu yd. This is because limestone packs tighter.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/gravel/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Gravel</span></a>
    <a href="/calculators/rip-rap/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Rip Rap</span></a>
    <a href="/calculators/sand/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Sand</span></a>
  </div></footer>
</article>
</Layout>
