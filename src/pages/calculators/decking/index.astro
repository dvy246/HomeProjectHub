---
import Layout from "../../../layouts/Layout.astro"
import DeckingCalc from "../../../components/calculators/DeckingCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/decking/";
const title = "Decking Calculator";
const description = "Calculate how many deck boards you need. Enter deck dimensions and board size to get board count, linear feet, square footage, and fastener estimates.";
const formula = "Boards = Ceil((Deck Width (ft) x 12) / (Board Width (in) + Gap (in))) | Linear Ft = Boards x Deck Length";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Specialty", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How many deck boards for a 12x12 deck?", a: "For a 12x12 deck using 5.5\" boards with 1/8\" gap: (144/5.625) = 26 boards. Add 10% waste = 29 boards." },
    { q: "What gap should I leave between deck boards?", a: "1/8\" for treated lumber, 1/4\" for hardwood. Treated lumber shrinks as it dries, so gaps will widen over time." },
    { q: "How many fasteners per deck board?", a: "Two fasteners at each joist intersection. For 16\" OC joists on a 12 ft board, that's about 18 fasteners per board." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Decking Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Decking Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate how many deck boards you need. Enter deck dimensions and board size to get board count, linear feet, square footage, and fastener estimates.</p>
  <AdSlot slotId="ad-top-leaderboard" />

  <section><DeckingCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Standard 5/4\" decking or 2x6 boards.", "Board gaps of 1/8\" between boards.", "10% waste factor recommended for cuts and mistakes."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many deck boards for a 12x12 deck?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">For a 12x12 deck using 5.5" boards with 1/8" gap: (144/5.625) = 26 boards. Add 10% waste = 29 boards.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What gap should I leave between deck boards?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">1/8" for treated lumber, 1/4" for hardwood. Treated lumber shrinks as it dries, so gaps will widen over time.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many fasteners per deck board?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Two fasteners at each joist intersection. For 16" OC joists on a 12 ft board, that's about 18 fasteners per board.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/board-foot/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Board Foot</span></a>
    <a href="/calculators/framing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Framing</span></a>
    <a href="/calculators/vinyl-fence/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Vinyl Fence</span></a>
  </div></footer>
</article>
</Layout>
