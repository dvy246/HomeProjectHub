---
import Layout from "../../../layouts/Layout.astro"
import FireGlassCalc from "../../../components/calculators/FireGlassCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/fire-glass/";
const title = "Fire Glass Calculator";
const description = "Calculate how much fire glass you need for fire pits, fire tables, and fireplaces. Get pounds and bag counts for round or square fire features.";
const formula = "Weight (lbs) = Area (sq ft) × Depth (ft) × Material Density";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Fire Glass Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How much fire glass for a 36\" fire pit?",
      a: "A 36\" round fire pit at 2\" depth needs about 27 lbs of fire glass or 6 bags (5 lb bags).",
    },
    {
      q: "Can I mix fire glass colors?",
      a: "Yes. Purchase separate bags and layer or mix for custom looks. Most installations use 1-2 colors.",
    },
    {
      q: "What depth of fire glass do I need?",
      a: "2\" is standard for gas fire pits. Too little exposes the burner; too much wastes fuel and glass.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Fire Glass Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Fire Glass Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate how much fire glass you need for fire pits, fire tables, and fireplaces. Get pounds and bag counts for round or square fire features.</p>
    <AdSlot slotId="ad-top-leaderboard" />
    <section><FireGlassCalc client:visible /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Fire glass density: approximately 100 lb/cu ft.",
        "Typical depth: 2 inches for fire pits.",
        "Round pits: use diameter, Square pits: use length × width."
      ]}
    />
    <AdSlot slotId="ad-in-content-mid" />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much fire glass for a 36" fire pit?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 36" round fire pit at 2" depth needs about 27 lbs of fire glass or 6 bags (5 lb bags).</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Can I mix fire glass colors?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Yes. Purchase separate bags and layer or mix for custom looks. Most installations use 1-2 colors.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What depth of fire glass do I need?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">2" is standard for gas fire pits. Too little exposes the burner; too much wastes fuel and glass.</p></details>
      </div>
    </section>
    <footer class="pt-8 mt-6 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/calculators/gravel/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Gravel</span></a>
      <a href="/calculators/river-rock/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">River Rock</span></a>
      </div>
    </footer>
  </article>
</Layout>
