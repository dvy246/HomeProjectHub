---
import Layout from "../../../layouts/Layout.astro"
import SquareYardsCalc from "../../../components/calculators/SquareYardsCalc"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/square-yards/";
const title = "Square Yards Calculator";
const description = "Convert square feet to square yards instantly.";
const formula = "Square Yards = Square Feet / 9";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Construction Converters", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How many square feet in a square yard?", a: "9 square feet = 1 square yard (3 ft x 3 ft). To convert sq ft to sq yd, divide by 9." },
    { q: "How many square yards is a 12x12 room?", a: "A 12x12 room = 144 sq ft. 144 / 9 = 16 square yards. Carpet is often sold by the square yard." },
    { q: "How do I calculate square yards for carpet?", a: "Measure room length and width in feet, multiply for sq ft, divide by 9. Add 10% for waste and pattern matching." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Square Yards Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Square Yards Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Convert square feet to square yards instantly.</p>
  <section><SquareYardsCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Formula: sq ft / 9 = sq yd.", "Based on 3 ft per yard (9 sq ft per sq yd).", "Result rounded to 2 decimal places."]} />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many square feet in a square yard?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">9 square feet = 1 square yard (3 ft x 3 ft). To convert sq ft to sq yd, divide by 9.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many square yards is a 12x12 room?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 12x12 room = 144 sq ft. 144 / 9 = 16 square yards. Carpet is often sold by the square yard.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do I calculate square yards for carpet?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Measure room length and width in feet, multiply for sq ft, divide by 9. Add 10% for waste and pattern matching.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/square-footage/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Square Footage</span></a>
    <a href="/calculators/sq-ft-to-cu-yd/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Sq Ft to Cu Yd</span></a>
    <a href="/calculators/cubic-yard/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Cubic Yard</span></a>
  </div></footer>
</article>
</Layout>
