---
import Layout from "../../../layouts/Layout.astro"
import FrenchDrainCalc from "../../../components/calculators/FrenchDrainCalc"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro"

const canonical = "https://homeplanninghub.com/calculators/french-drain/";
const title = "French Drain Calculator";
const description = "Calculate french drain materials including gravel, pipe, and fabric.";
const formula = "Gravel (cu yd) = (Length (ft) x Trench Width (ft) x Trench Depth (ft)) / 27 - Pipe Volume";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Landscaping", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How deep should a french drain be?", a: "French drains are typically 18-24 inches deep. The trench must be below the problem water level and slope 1% toward the outlet." },
    { q: "What size gravel for french drain?", a: "1-1.5 inch washed gravel (clear crush) is ideal. Pea gravel is too small and can clog. Never use dirty gravel with fines." },
    { q: "Does a french drain need a pipe?", a: "Yes, a perforated 4-inch PVC pipe wrapped in filter fabric is standard. The pipe collects and channels water to the outlet." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">French Drain Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">French Drain Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate french drain materials including gravel, pipe, and fabric.</p>

  <section><FrenchDrainCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Trench width: 12-18 inches for typical french drain.", "Gravel fill rate ~60% of trench volume (subtracting pipe).", "Standard perforated 4 inch PVC pipe.", "Filter fabric wraps the gravel envelope.", "Trench should slope 1% toward outlet (1 ft drop per 100 ft)."]} />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How deep should a french drain be?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">French drains are typically 18-24 inches deep. The trench must be below the problem water level and slope 1% toward the outlet.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What size gravel for french drain?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">1-1.5 inch washed gravel (clear crush) is ideal. Pea gravel is too small and can clog. Never use dirty gravel with fines.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Does a french drain need a pipe?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Yes, a perforated 4-inch PVC pipe wrapped in filter fabric is standard. The pipe collects and channels water to the outlet.</p></details>
  </div></section>
  <RelatedCalculators slug="french_drain" />
</article>
</Layout>
