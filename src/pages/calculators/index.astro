---
import Layout from "../../layouts/Layout.astro";
import CalculatorHub from "../../components/CalculatorHub";
import { graphSchema, webPageSchema, breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const canonical = "https://homeprojecthub.com/calculators/";
const title = "Home Improvement Calculators";
const description = "Browse all home improvement calculators. Find concrete, roofing, weight, wall & fence, landscaping, and specialty calculators for your next project.";
const PAGE_PATH = "/calculators/";

const schema = graphSchema(
  breadcrumbListSchema([{ name: "Home", path: "/" }, { name: "Calculators", path: PAGE_PATH }]),
  webPageSchema({ url: canonical, topicName: title }),
  faqPageSchema([
    { q: "How many calculators are available?", a: "We offer 60+ calculators covering concrete, roofing, weight calculations, wall and fence materials, landscaping, paint, tile, and specialty construction topics." },
    { q: "Are the calculators free to use?", a: "Yes, all calculators are completely free. No account, sign-up, or payment required." },
    { q: "How accurate are the calculations?", a: "Our calculators use standard industry formulas and material densities from published references. Always verify critical measurements with a professional." },
    { q: "Can I save my calculations?", a: "Yes, use our Project Planner feature to save materials, dimensions, and results for ongoing projects." },
  ], canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-5xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Calculators</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Home Improvement Calculators</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Find the right calculator for your project. Search by name or filter by category to quickly get the material estimates you need.</p>
    <CalculatorHub client:load />
    <section>
      <h2 id="calculator-categories" class="text-xl font-bold mb-3">Calculator Categories</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 text-sm">
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="font-semibold mb-2">Construction Converters</h3>
          <p class="text-xs text-[var(--fg-secondary)]">Board feet, cubic yards, square footage, and unit conversion calculators for dimensional estimates.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="font-semibold mb-2">Concrete</h3>
          <p class="text-xs text-[var(--fg-secondary)]">Slabs, footings, columns, walls, tubes, steps, mix ratios, curb & gutter, block fill, and rebar calculators.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="font-semibold mb-2">Roofing</h3>
          <p class="text-xs text-[var(--fg-secondary)]">Shingles, metal roofing, plywood, pitch, snow load, and ice & water shield material calculators.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="font-semibold mb-2">Weight</h3>
          <p class="text-xs text-[var(--fg-secondary)]">Material weight calculators for aluminum, glass, steel, pipe, plate, stone, and more.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="font-semibold mb-2">Wall & Fence</h3>
          <p class="text-xs text-[var(--fg-secondary)]">Framing, brick, retaining walls, baluster/spindle spacing, board & batten, vinyl fence, and siding calculators.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="font-semibold mb-2">Landscaping & Specialty</h3>
          <p class="text-xs text-[var(--fg-secondary)]">Gravel, mulch, sand, French drains, fire glass, sealant, sonotube, decking, drywall, lumber, shed cost, and spiral staircase calculators.</p>
        </div>
      </div>
    </section>
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do I use the calculators?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Enter your project dimensions in the input fields. Results update in real time. Each calculator includes a formula explanation, worked example, and material estimates.</p></details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Can I plan a full project?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Yes, use our Project Planner to create a project, add calculators, save all your material estimates, and generate a combined shopping list.</p></details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Do you have a mobile app?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Our website is fully responsive and works on all devices. Add it to your home screen for quick access to calculators on the job site.</p></details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Are calculations in imperial or metric?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Calculators default to imperial units (feet, inches, pounds). Many calculators include a toggle for metric units where applicable.</p></details>
      </div>
    </section>
  </article>
</Layout>
