---
import Layout from "../../../layouts/Layout.astro";
import SnowLoadCalc from "../../../components/calculators/SnowLoadCalc";
import AdSlot from "../../../components/AdSlot.astro";
import { graphSchema, mathSolverSchema, faqPageSchema, howToSchema } from "../../../lib/schema";

const canonical = "https://homeprojecthub.com/calculators/roofing/snow-load/";

const title = "Snow Load Calculator";
const description = "Calculate roof snow load based on snow depth, density, and building code ground snow load values. Check if your roof is safe under current snow conditions.";

const schema = graphSchema(
  mathSolverSchema({
    name: "Snow Load Formula",
    description: "Calculate design snow load based on depth, density, pitch, and code ground snow load.",
    formula: "Design Load = max(Depth × Density × 1.25, Ground Snow Load × Flat Roof Factor)",
    url: canonical,
  }),
  howToSchema(
    "Calculate Roof Snow Load",
    "Follow these steps to evaluate the snow load on your roof.",
    [
      {
        heading: "Measure snow depth and determine type",
        text: "Measure the snow depth on the roof in inches. Fresh snow is lighter (~5 pcf), while wet, packed snow can be 8x heavier (~40 pcf). Use the snow type selector to estimate density.",
      },
      {
        heading: "Find your ground snow load",
        text: "The ground snow load (psf) is found on local building code maps. This represents the expected snow load on the ground. The roof load is a percentage of this based on pitch and exposure.",
      },
      {
        heading: "Use the higher of depth or code values",
        text: "The design snow load is the higher of: (1) the actual measured snow depth × density, or (2) the code-based ground snow load × roof factor. If the design load exceeds 50 psf, consult a structural engineer.",
      },
    ]
  ),
  faqPageSchema([
    {
      q: "What is the standard snow load for my area?",
      a: "Ground snow loads vary by region from 10 psf in warm climates to over 100 psf in mountain areas. Check your local building department for the specific ground snow load value on the code map for your address and elevation.",
    },
    {
      q: "What roof pitch is best for snow?",
      a: "Steeper roofs (6:12 and above) shed snow more effectively, reducing the load. A 6:12 pitch has a 0.7 roof factor, while a 12:12 pitch has a 0.56 factor. Flat roofs (2:12 or less) accumulate the most snow and need the highest structural capacity.",
    },
    {
      q: "How much snow can a typical roof hold?",
      a: "Most residential roofs in snow country are designed for 30-50 psf (pounds per square foot). For reference, 1 foot of dry snow at 15 pcf = 15 psf, but 1 foot of wet snow at 40 pcf = 40 psf, which approaches the limit.",
    },
  ], canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/calculators/roofing/" class="hover:underline">roofing</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)]">snow load</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">
        Snow Load Calculator
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Evaluate whether snow accumulation on your roof is within safe limits. This calculator combines actual snow depth and density measurements with building code ground snow load values to determine the design snow load in pounds per square foot.
      </p>
    </header>

    <AdSlot slotId="ad-top-leaderboard" />

    <section>
      <SnowLoadCalc client:visible />
    </section>

    <section>
      <h2 id="how-to-calculate" class="text-xl font-bold tracking-tight mb-4">
        How to Calculate Snow Load
      </h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Snow load calculation uses two approaches and takes the more conservative (higher) value as the design load.
      </p>
      <ol class="list-decimal pl-5 flex flex-col gap-3 text-sm text-[var(--fg-secondary)]">
        <li>
          <strong>Depth-Based Load:</strong> Multiply the snow depth (in feet) by the density (in pcf). Fresh snow density is ~5 pcf, settled snow is ~15 pcf, and wet snow is ~40 pcf. A safety factor of 1.25 is applied.
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Depth Load = Depth (ft) &times; Density (pcf) &times; 1.25
          </div>
        </li>
        <li>
          <strong>Code-Based Load:</strong> The ground snow load (from local building code) is multiplied by a roof factor that accounts for pitch. Flatter roofs retain more snow.
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Code Load = Ground Snow Load &times; 0.7 (for pitches under 12:12)
          </div>
        </li>
        <li>
          <strong>Design Load:</strong> The higher of the two values is the design load. If it exceeds 50 psf, the roof may be at risk and snow removal should be considered.
        </li>
      </ol>
    </section>

    <section>
      <h2 id="faq" class="text-xl font-bold tracking-tight mb-4">
        Frequently Asked Questions
      </h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer">What is the standard snow load for my area?</summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            Ground snow loads vary by region from 10 psf (warm climates) to 100+ psf (mountain areas). Check your local building department for the code-map value specific to your address and elevation.
          </p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer">What roof pitch is best for snow?</summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            Steeper roofs (6:12 and above) shed snow naturally. A 6:12 pitch has a 0.7 roof factor versus 1.0 for flat roofs. Pitches over 12:12 use an additional reduction factor but may accumulate drifting at wall intersections.
          </p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer">How much snow can a typical roof hold?</summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            Most residential roofs in snow country are designed for 30-50 psf. One foot of dry snow (15 pcf) = 15 psf. One foot of wet snow (40 pcf) = 40 psf. Two feet of wet snow = 80 psf, which exceeds most residential designs.
          </p>
        </details>
      </div>
    </section>

    <footer class="pt-8 mt-6 mb-6">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">
        Related Construction Tools
      </h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/calculators/roofing/pitch/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Roof Pitch Calculator</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-normal">Calculate roof pitch, angle, and slope.</span>
        </a>
        <a href="/calculators/roofing/shingles/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Roof Shingle Calculator</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-normal">Estimate shingle bundles and squares.</span>
        </a>
        <a href="/calculators/roofing/metal/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Metal Roof Calculator</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-normal">Estimate metal panels and accessories.</span>
        </a>
      </div>
    </footer>
  </article>
</Layout>
