---
import Layout from "../../../layouts/Layout.astro";
import RoofPitchCalc from "../../../components/calculators/RoofPitchCalc";
import AdSlot from "../../../components/AdSlot.astro";

const title = "Roof Pitch Calculator";
const description = "Calculate roof pitch in degrees, percentage, and ratio. Find the pitch multiplier for material estimation and determine rafter length from building dimensions.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "MathSolver", "@id": "https://homeprojecthub.com/calculators/roofing/pitch/#math-solver", "name": "Roof Pitch Calculator", "description": "Converts roof pitch between ratio, degrees, and percentage. Calculates pitch multiplier and rafter length.", "potentialAction": { "@type": "SolveAction", "target": "https://homeprojecthub.com/calculators/roofing/pitch/?equation={equation}" } },
    { "@type": "FAQPage", "@id": "https://homeprojecthub.com/calculators/roofing/pitch/#faq", "mainEntity": [
      { "@type": "Question", "name": "What is roof pitch?", "acceptedAnswer": { "@type": "Answer", "text": "Roof pitch is the steepness of a roof, expressed as a ratio of vertical rise to horizontal run. For example, a 6:12 pitch means the roof rises 6 inches for every 12 inches of horizontal distance. Pitch can also be expressed in degrees or as a percentage." } },
      { "@type": "Question", "name": "How do you convert roof pitch to degrees?", "acceptedAnswer": { "@type": "Answer", "text": "To convert roof pitch to degrees, use the arctangent function: degrees = arctan(rise / run) x (180 / pi). For a 6:12 pitch, arctan(6/12) = 0.4636 radians, which equals 26.57 degrees." } },
      { "@type": "Question", "name": "What is a roof pitch multiplier?", "acceptedAnswer": { "@type": "Answer", "text": "The roof pitch multiplier (or correction factor) converts a flat building footprint into the actual sloped roof area. It is calculated as the square root of (1 + (rise/run) squared). A 6:12 pitch has a multiplier of 1.118, meaning the roof surface is 11.8% larger than the footprint." } }
    ]}
  ]
};
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="border-b border-neutral-100 dark:border-neutral-800 pb-6 mb-2">
      <nav class="text-xs text-neutral-400 dark:text-neutral-500 font-mono mb-2">
        <a href="/" class="hover:underline">home</a> &gt;
        <a href="/calculators/roofing/" class="hover:underline">roofing</a> &gt;
        <span class="text-neutral-600 dark:text-neutral-400">pitch</span>
      </nav>
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 dark:text-neutral-50 mb-3 text-balance">Roof Pitch Calculator</h1>
      <p class="text-base text-neutral-500 dark:text-neutral-400 leading-relaxed text-pretty">
        Convert roof pitch between ratio, degrees, and percentage. Calculate the pitch multiplier for material estimation, determine rafter length, and find the actual roof surface area from your building footprint dimensions.
      </p>
    </header>

    <AdSlot slotId="ad-top-pitch" />

    <section class="my-4"><RoofPitchCalc client:visible /></section>

    <section class="border-t border-neutral-100 dark:border-neutral-800 pt-8 mt-6">
      <h2 id="how-to-calculate" class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-4 tracking-tight">How to Calculate Roof Pitch</h2>
      <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4 text-pretty">
        Roof pitch describes the steepness of a roof and can be expressed three ways: as a ratio (rise:run), as an angle in degrees, or as a percentage slope.
      </p>
      <div class="flex flex-col gap-6">
        <div>
          <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-2">Pitch Ratio to Degrees</h3>
          <div class="p-3 bg-neutral-50 dark:bg-neutral-900 rounded font-mono text-center text-xs">Degrees = arctan(Rise &divide; Run) &times; (180 &divide; &pi;)</div>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-2">Pitch Ratio to Percentage</h3>
          <div class="p-3 bg-neutral-50 dark:bg-neutral-900 rounded font-mono text-center text-xs">Slope % = (Rise &divide; Run) &times; 100</div>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-2">Pitch Multiplier (for material estimation)</h3>
          <div class="p-3 bg-neutral-50 dark:bg-neutral-900 rounded font-mono text-center text-xs">Multiplier = &radic;(1 + (Rise &divide; Run)&sup2;)</div>
        </div>
      </div>
    </section>

    <section class="border-t border-neutral-100 dark:border-neutral-800 pt-8 mt-6">
      <h2 id="pitch-multiplier-table" class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-4 tracking-tight">Common Pitch Multipliers</h2>
      <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4 text-pretty">
        Use this table to quickly find the pitch multiplier for common roof pitches. Multiply your building footprint by the multiplier to get the actual roof surface area.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-xs text-left border border-neutral-200 dark:border-neutral-800 rounded-lg">
          <thead>
            <tr class="border-b border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/50 text-neutral-500">
              <th class="p-3 font-semibold">Pitch</th>
              <th class="p-3 font-semibold">Angle</th>
              <th class="p-3 font-semibold">Multiplier</th>
              <th class="p-3 font-semibold">Slope %</th>
              <th class="p-3 font-semibold">Category</th>
            </tr>
          </thead>
          <tbody class="tabular-nums">
            <tr class="border-b border-neutral-100 dark:border-neutral-800"><td class="p-3 font-mono font-bold">2:12</td><td class="p-3">9.46&deg;</td><td class="p-3">1.014</td><td class="p-3">16.7%</td><td class="p-3 text-neutral-500">Low Slope</td></tr>
            <tr class="border-b border-neutral-100 dark:border-neutral-800"><td class="p-3 font-mono font-bold">4:12</td><td class="p-3">18.43&deg;</td><td class="p-3">1.054</td><td class="p-3">33.3%</td><td class="p-3 text-neutral-500">Conventional</td></tr>
            <tr class="border-b border-neutral-100 dark:border-neutral-800"><td class="p-3 font-mono font-bold">6:12</td><td class="p-3">26.57&deg;</td><td class="p-3">1.118</td><td class="p-3">50.0%</td><td class="p-3 text-neutral-500">Conventional</td></tr>
            <tr class="border-b border-neutral-100 dark:border-neutral-800"><td class="p-3 font-mono font-bold">8:12</td><td class="p-3">33.69&deg;</td><td class="p-3">1.202</td><td class="p-3">66.7%</td><td class="p-3 text-neutral-500">Steep</td></tr>
            <tr class="border-b border-neutral-100 dark:border-neutral-800"><td class="p-3 font-mono font-bold">10:12</td><td class="p-3">39.81&deg;</td><td class="p-3">1.302</td><td class="p-3">83.3%</td><td class="p-3 text-neutral-500">Steep</td></tr>
            <tr><td class="p-3 font-mono font-bold">12:12</td><td class="p-3">45.00&deg;</td><td class="p-3">1.414</td><td class="p-3">100.0%</td><td class="p-3 text-neutral-500">Very Steep</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <AdSlot slotId="ad-mid-pitch" />

    <section class="border-t border-neutral-100 dark:border-neutral-800 pt-8 mt-6">
      <h2 id="faq" class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-4 tracking-tight">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-6">
        <div><h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-2">What is roof pitch?</h3><p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed text-pretty">Roof pitch is the steepness of a roof, expressed as a ratio of vertical rise to horizontal run. For example, a 6:12 pitch means the roof rises 6 inches for every 12 inches of horizontal distance. Pitch can also be expressed in degrees or as a percentage.</p></div>
        <div><h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-2">How do you convert roof pitch to degrees?</h3><p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed text-pretty">To convert roof pitch to degrees, use the arctangent function: degrees = arctan(rise / run) x (180 / pi). For a 6:12 pitch, arctan(6/12) = 0.4636 radians, which equals 26.57 degrees.</p></div>
        <div><h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-2">What is a roof pitch multiplier?</h3><p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed text-pretty">The roof pitch multiplier (or correction factor) converts a flat building footprint into the actual sloped roof area. It is calculated as the square root of (1 + (rise/run) squared). A 6:12 pitch has a multiplier of 1.118, meaning the roof surface is 11.8% larger than the footprint.</p></div>
      </div>
    </section>

    <footer class="border-t border-neutral-100 dark:border-neutral-800 pt-8 mt-12 mb-6">
      <h4 class="text-xs font-bold uppercase tracking-wider text-neutral-400 dark:text-neutral-500 mb-4">Related Roofing Tools</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/calculators/roofing/shingles/" class="block p-4 border border-neutral-200 dark:border-neutral-800 rounded-md hover:border-black dark:hover:border-white transition-colors"><span class="block text-xs font-semibold text-neutral-800 dark:text-neutral-200 mb-1">Shingle Calculator</span><span class="text-[10px] text-neutral-450 dark:text-neutral-500">Estimate asphalt shingle bundles.</span></a>
        <a href="/calculators/roofing/metal/" class="block p-4 border border-neutral-200 dark:border-neutral-800 rounded-md hover:border-black dark:hover:border-white transition-colors"><span class="block text-xs font-semibold text-neutral-800 dark:text-neutral-200 mb-1">Metal Roof Calculator</span><span class="text-[10px] text-neutral-450 dark:text-neutral-500">Estimate metal panels and screws.</span></a>
        <a href="/calculators/roofing/plywood/" class="block p-4 border border-neutral-200 dark:border-neutral-800 rounded-md hover:border-black dark:hover:border-white transition-colors"><span class="block text-xs font-semibold text-neutral-800 dark:text-neutral-200 mb-1">Plywood Deck Calculator</span><span class="text-[10px] text-neutral-450 dark:text-neutral-500">Calculate roof sheathing sheets.</span></a>
      </div>
    </footer>
  </article>
</Layout>
