---
import Layout from "../../../layouts/Layout.astro";
import RoofPitchCalc from "../../../components/calculators/RoofPitchCalc";
import AdSlot from "../../../components/AdSlot.astro";
import { graphSchema, mathSolverSchema, howToSchema, faqPageSchema, breadcrumbListSchema } from "../../../lib/schema";
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro";

const canonical = "https://homeplanninghub.com/calculators/roofing/pitch/";

const title = "Roof Pitch Calculator";
const description = "Calculate roof pitch in degrees, percentage, and ratio. Find the pitch multiplier for material estimation and determine rafter length from building dimensions.";

const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");
const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Roofing Calculators", path: "/calculators/roofing/" },
    { name: title, path: PAGE_PATH },
  ]),
  mathSolverSchema({
    name: "Roof Pitch Calculator",
    description: "Converts roof pitch between ratio, degrees, and percentage. Calculates pitch multiplier and rafter length.",
    formula: "PitchMultiplier = √(1 + (rise/12)²)",
    url: canonical,
  }),
  howToSchema(
    "Calculate Roof Pitch",
    "Convert roof pitch between ratio, degrees, and percentage forms.",
    [
      {
        name: "Measure rise and run",
        text: "Measure vertical rise (inches) per 12 inches of horizontal run.",
      },
      {
        name: "Convert to degrees",
        text: "Degrees = arctan(rise / run) × (180 / π).",
      },
      {
        name: "Find pitch multiplier",
        text: "Multiplier = √(1 + (rise/run)²). Multiply building footprint by this to get true roof area.",
      },
    ]
  ),
  faqPageSchema([
    {
      q: "What is roof pitch?",
      a: "Roof pitch is the steepness ratio of vertical rise to horizontal run. A 6:12 pitch rises 6 inches per 12 inches of run. Also expressed in degrees or percentage.",
    },
    {
      q: "How do you convert roof pitch to degrees?",
      a: "degrees = arctan(rise / run) × (180/π). For 6:12: arctan(0.5) × (180/π) = 26.57°.",
    },
    {
      q: "What is a roof pitch multiplier?",
      a: "Converts building footprint to sloped roof area. √(1 + (rise/run)²). A 6:12 pitch has a 1.118 multiplier — 11.8% more surface than the footprint.",
    },
  ], canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/calculators/roofing/" class="hover:underline">roofing</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)]">pitch</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">Roof Pitch Calculator</h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Convert roof pitch between ratio, degrees, and percentage. Calculate the pitch multiplier for material estimation, determine rafter length, and find the actual roof surface area from your building footprint dimensions.
      </p>
    </header>

    <AdSlot slotId="ad-top-pitch" />

    <section><RoofPitchCalc client:visible /></section>

    <section>
      <h2 id="how-to-calculate" class="text-xl font-bold tracking-tight mb-4">How to Calculate Roof Pitch</h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Roof pitch describes the steepness of a roof and can be expressed three ways: as a ratio (rise:run), as an angle in degrees, or as a percentage slope.
      </p>
      <div class="flex flex-col gap-6">
        <div>
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-2">Pitch Ratio to Degrees</h3>
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">Degrees = arctan(Rise &divide; Run) &times; (180 &divide; &pi;)</div>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-2">Pitch Ratio to Percentage</h3>
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">Slope % = (Rise &divide; Run) &times; 100</div>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-2">Pitch Multiplier (for material estimation)</h3>
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">Multiplier = &radic;(1 + (Rise &divide; Run)&sup2;)</div>
        </div>
      </div>
    </section>

    <section>
      <h2 id="pitch-multiplier-table" class="text-xl font-bold tracking-tight mb-4">Common Pitch Multipliers</h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Use this table to quickly find the pitch multiplier for common roof pitches. Multiply your building footprint by the multiplier to get the actual roof surface area.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-xs text-left border border-[var(--border)] rounded-lg">
          <thead>
            <tr class="border-b border-[var(--border)] bg-[var(--bg-muted)] text-[var(--fg-secondary)]">
              <th class="p-3 font-semibold">Pitch</th>
              <th class="p-3 font-semibold">Angle</th>
              <th class="p-3 font-semibold">Multiplier</th>
              <th class="p-3 font-semibold">Slope %</th>
              <th class="p-3 font-semibold">Category</th>
            </tr>
          </thead>
          <tbody class="tabular-nums">
            <tr class="border-b border-[var(--border)]"><td class="p-3 font-mono font-bold">2:12</td><td class="p-3">9.46&deg;</td><td class="p-3">1.014</td><td class="p-3">16.7%</td><td class="p-3 text-[var(--fg-muted)]">Low Slope</td></tr>
            <tr class="border-b border-[var(--border)]"><td class="p-3 font-mono font-bold">4:12</td><td class="p-3">18.43&deg;</td><td class="p-3">1.054</td><td class="p-3">33.3%</td><td class="p-3 text-[var(--fg-muted)]">Conventional</td></tr>
            <tr class="border-b border-[var(--border)]"><td class="p-3 font-mono font-bold">6:12</td><td class="p-3">26.57&deg;</td><td class="p-3">1.118</td><td class="p-3">50.0%</td><td class="p-3 text-[var(--fg-muted)]">Conventional</td></tr>
            <tr class="border-b border-[var(--border)]"><td class="p-3 font-mono font-bold">8:12</td><td class="p-3">33.69&deg;</td><td class="p-3">1.202</td><td class="p-3">66.7%</td><td class="p-3 text-[var(--fg-muted)]">Steep</td></tr>
            <tr class="border-b border-[var(--border)]"><td class="p-3 font-mono font-bold">10:12</td><td class="p-3">39.81&deg;</td><td class="p-3">1.302</td><td class="p-3">83.3%</td><td class="p-3 text-[var(--fg-muted)]">Steep</td></tr>
            <tr><td class="p-3 font-mono font-bold">12:12</td><td class="p-3">45.00&deg;</td><td class="p-3">1.414</td><td class="p-3">100.0%</td><td class="p-3 text-[var(--fg-muted)]">Very Steep</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 id="example" class="text-xl font-bold tracking-tight mb-4">Example Pitch Calculation</h2>
      <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
        <p class="text-sm font-semibold text-[var(--fg)] mb-2">Calculating roof area for a 6:12 pitch, 40&prime; &times; 30&prime; building</p>
        <ul class="flex flex-col gap-1.5 text-xs text-[var(--fg-secondary)]">
          <li><strong>Step 1:</strong> Rise = 6 in per 12 in run &rarr; Ratio = 6/12 = 0.5</li>
          <li><strong>Step 2:</strong> Pitch angle = arctan(0.5) &times; (180/&pi;) = <strong>26.57&deg;</strong></li>
          <li><strong>Step 3:</strong> Pitch multiplier = &radic;(1 + 0.5&sup2;) = <strong>1.118</strong></li>
          <li><strong>Step 4:</strong> Building footprint = 40 &times; 30 = 1,200 sq ft</li>
          <li><strong>Step 5:</strong> Actual roof area = 1,200 &times; 1.118 = <strong>1,342 sq ft</strong></li>
          <li><strong>Step 6:</strong> Slope percentage = 0.5 &times; 100 = <strong>50%</strong></li>
        </ul>
      </div>
    </section>

    <section>
      <h2 id="common-mistakes" class="text-xl font-bold tracking-tight mb-4">Common Mistakes in Roof Pitch Measurement</h2>
      <div class="flex flex-col gap-3">
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-1">Measuring pitch from the attic ceiling</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">Pitch is measured from the roof sheathing, not the ceiling joists. Ceiling joists may have additional framing that changes the effective slope. Always measure directly on the rafters.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-1">Confusing pitch with slope percentage</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">A 6:12 pitch equals a 50% slope, not 6%. The pitch ratio is rise over 12 inches of run; the percentage is rise divided by run times 100. Mixing these up leads to ordering the wrong materials.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-1">Using the wrong multiplier for complex roofs</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">The pitch multiplier only works for simple gable roofs. Hip roofs, gambrels, and roofs with dormers have more complex geometry. Measure each roof plane separately and sum the areas.</p>
        </div>
      </div>
    </section>

    <AdSlot slotId="ad-mid-pitch" />

    <section>
      <h2 id="faq" class="text-xl font-bold tracking-tight mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is roof pitch?</h3></summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">Roof pitch is the steepness of a roof, expressed as a ratio of vertical rise to horizontal run. For example, a 6:12 pitch means the roof rises 6 inches for every 12 inches of horizontal distance. Pitch can also be expressed in degrees or as a percentage.</p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do you convert roof pitch to degrees?</h3></summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">To convert roof pitch to degrees, use the arctangent function: degrees = arctan(rise / run) x (180 / pi). For a 6:12 pitch, arctan(6/12) = 0.4636 radians, which equals 26.57 degrees.</p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is a roof pitch multiplier?</h3></summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">The roof pitch multiplier (or correction factor) converts a flat building footprint into the actual sloped roof area. It is calculated as the square root of (1 + (rise/run) squared). A 6:12 pitch has a multiplier of 1.118, meaning the roof surface is 11.8% larger than the footprint.</p>
        </details>
      </div>
    </section>

    <RelatedCalculators slug="roofing-pitch" />
  </article>
</Layout>
