---
import Layout from "../../../layouts/Layout.astro";
import MetalRoofCalc from "../../../components/calculators/MetalRoofCalc";
import AdSlot from "../../../components/AdSlot.astro";

const title = "Metal Roofing Calculator";
const description = "Calculate how many metal roofing panels you need. Accounts for roof pitch, panel dimensions, and waste factor. Includes screws, closure strips, and ridge cap estimates.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "MathSolver", "@id": "https://homeprojecthub.com/calculators/roofing/metal/#math-solver", "name": "Metal Roofing Panel Calculator", "description": "Calculates metal panel count, screws, and accessories for roofing projects.", "potentialAction": { "@type": "SolveAction", "target": "https://homeprojecthub.com/calculators/roofing/metal/?equation={equation}" } },
    { "@type": "FAQPage", "@id": "https://homeprojecthub.com/calculators/roofing/metal/#faq", "mainEntity": [
      { "@type": "Question", "name": "How many metal roof panels do I need?", "acceptedAnswer": { "@type": "Answer", "text": "Divide your total roof area (including waste) by the coverage area of one panel. A standard 36-inch wide, 12-foot long panel covers 36 square feet. For a 1,500 sq ft roof with 7% waste, you need 1,605 sq ft divided by 36, which equals approximately 45 panels." } },
      { "@type": "Question", "name": "How much waste should I add for metal roofing?", "acceptedAnswer": { "@type": "Answer", "text": "Metal roofing typically requires 5-10% waste factor. Simple gable roofs with few penetrations need 5%, while roofs with many valleys, dormers, or skylights need 10%. Always order a few extra panels for future repairs." } },
      { "@type": "Question", "name": "How many screws per square foot of metal roofing?", "acceptedAnswer": { "@type": "Answer", "text": "Standard corrugated metal roofing requires approximately 1.5 screws per square foot of roof area. This includes fasteners at every rib on the overlaps and every other rib in the field. A 1,000 sq ft roof needs approximately 1,500 screws." } }
    ]}
  ]
};
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/calculators/roofing/" class="hover:underline">roofing</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)]">metal</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">Metal Roofing Calculator</h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Calculate the number of metal roofing panels needed for your project. Enter your building dimensions, roof pitch, and panel size to get panel count, screw quantity, closure strips, and ridge cap length. Works for corrugated, standing seam, and ribbed metal panels.
      </p>
    </header>

    <AdSlot slotId="ad-top-metal" />

    <section><MetalRoofCalc client:visible /></section>

    <section>
      <h2 id="how-to-calculate" class="text-xl font-bold tracking-tight mb-4">How to Calculate Metal Roofing Panels</h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Metal roofing is sold in panels of specific widths and lengths. To calculate how many panels you need:
      </p>
      <ol class="list-decimal pl-5 flex flex-col gap-3 text-sm text-[var(--fg-secondary)]">
        <li><strong>Calculate Roof Area:</strong> Multiply the building footprint by the pitch multiplier.
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">Roof Area = Length &times; Width &times; &radic;(1 + (Pitch&divide;12)&sup2;)</div>
        </li>
        <li><strong>Add Waste Factor:</strong> Multiply roof area by (1 + waste percentage).
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">Total Area = Roof Area &times; (1 + Waste%)</div>
        </li>
        <li><strong>Calculate Panel Coverage:</strong> Multiply panel width (in feet) by panel length (in feet).
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">Panel Coverage = (Width (in) &divide; 12) &times; (Length (in) &divide; 12)</div>
        </li>
        <li><strong>Divide and Round Up:</strong> Divide total area by panel coverage and round up to the next whole panel.
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">Panels = &lceil;Total Area &divide; Panel Coverage&lceil;</div>
        </li>
      </ol>
    </section>

    <section>
      <h2 id="example-calculation" class="text-xl font-bold tracking-tight mb-4">Example Metal Roof Calculation</h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Let's calculate panels for a <strong>40x30 foot building</strong> with a <strong>6:12 pitch</strong>, using <strong>36-inch x 12-foot panels</strong> with <strong>7% waste</strong>:
      </p>
      <ul class="list-disc pl-5 flex flex-col gap-2 text-sm text-[var(--fg-secondary)]">
        <li><strong>Footprint:</strong> 40 ft &times; 30 ft = 1,200 sq ft</li>
        <li><strong>Pitch Multiplier:</strong> &radic;(1 + 0.5&sup2;) = 1.118</li>
        <li><strong>Roof Area:</strong> 1,200 &times; 1.118 = 1,342 sq ft</li>
        <li><strong>With 7% Waste:</strong> 1,342 &times; 1.07 = 1,436 sq ft</li>
        <li><strong>Panel Coverage:</strong> 3 ft &times; 12 ft = 36 sq ft per panel</li>
        <li><strong>Panels Needed:</strong> 1,436 &divide; 36 = 39.9 &rarr; <strong>40 panels</strong></li>
        <li><strong>Screws:</strong> 1,342 &times; 1.5 = <strong>2,013 screws</strong></li>
      </ul>
    </section>

    <AdSlot slotId="ad-mid-metal" />

    <section>
      <h2 id="common-mistakes" class="text-xl font-bold tracking-tight mb-4">Common Mistakes in Metal Roof Estimation</h2>
      <ul class="list-disc pl-5 flex flex-col gap-3 text-sm text-[var(--fg-secondary)] text-pretty">
        <li><strong>Using Nominal vs. Coverage Width:</strong> Metal panels have a nominal width (the physical sheet width) and a coverage width (the exposed width after overlapping). Always use the coverage width, which is typically 36 inches for corrugated panels even though the sheet is 38 inches wide.</li>
        <li><strong>Not Ordering Extra Panels:</strong> Metal panels are custom-cut to length. If you damage a panel during installation, you cannot easily get a replacement. Order 2-3 extra panels as spares.</li>
        <li><strong>Underestimating Screw Quantity:</strong> High-wind areas require more fasteners. In wind zones, use 2 screws per square foot instead of 1.5. Check your local building code for fastener spacing requirements.</li>
      </ul>
    </section>

    <section>
      <h2 id="faq" class="text-xl font-bold tracking-tight mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer">How many metal roof panels do I need?</summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">Divide your total roof area (including waste) by the coverage area of one panel. A standard 36-inch wide, 12-foot long panel covers 36 square feet. For a 1,500 sq ft roof with 7% waste, you need 1,605 sq ft divided by 36, which equals approximately 45 panels.</p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer">How much waste should I add for metal roofing?</summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">Metal roofing typically requires 5-10% waste factor. Simple gable roofs with few penetrations need 5%, while roofs with many valleys, dormers, or skylights need 10%. Always order a few extra panels for future repairs.</p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer">How many screws per square foot of metal roofing?</summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">Standard corrugated metal roofing requires approximately 1.5 screws per square foot of roof area. This includes fasteners at every rib on the overlaps and every other rib in the field. A 1,000 sq ft roof needs approximately 1,500 screws.</p>
        </details>
      </div>
    </section>

    <footer class="pt-8 mt-6 mb-6">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Roofing Tools</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/calculators/roofing/shingles/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="block text-xs font-semibold text-[var(--fg)] mb-1">Shingle Calculator</span><span class="text-[10px] text-[var(--fg-muted)]">Estimate asphalt shingle bundles.</span></a>
        <a href="/calculators/roofing/plywood/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="block text-xs font-semibold text-[var(--fg)] mb-1">Plywood Deck Calculator</span><span class="text-[10px] text-[var(--fg-muted)]">Calculate roof sheathing sheets.</span></a>
        <a href="/calculators/roofing/pitch/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="block text-xs font-semibold text-[var(--fg)] mb-1">Roof Pitch Calculator</span><span class="text-[10px] text-[var(--fg-muted)]">Find pitch, angle, and multiplier.</span></a>
      </div>
    </footer>
  </article>
</Layout>
