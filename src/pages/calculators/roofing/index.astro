---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import { breadcrumbListSchema, faqPageSchema } from "../../../lib/schema";

const title = "Roofing Calculators";
const description = "Free roofing calculators for shingles, metal panels, plywood sheathing, and roof pitch. Estimate materials, screws, underlayment, and accessories for any roofing project.";

const calculators = [
  { href: "/calculators/roofing/shingles/", title: "Shingles", desc: "Asphalt shingle bundles, squares, nails, and underlayment for any roof shape", tags: ["Gable", "Hip", "Waste"] },
  { href: "/calculators/roofing/metal/", title: "Metal Roof", desc: "Standing seam and corrugated metal panel counts, screws, and closures", tags: ["Panels", "Trim", "Fasteners"] },
  { href: "/calculators/roofing/plywood/", title: "Plywood Deck", desc: "Plywood and OSB sheathing sheets, fasteners, and H-clips for roof decks", tags: ["4x8", "4x10", "4x12"] },
  { href: "/calculators/roofing/pitch/", title: "Roof Pitch", desc: "Roof angle, slope percentage, pitch multiplier, and derived rafter values", tags: ["Angle", "Rafter", "Multiplier"] },
  { href: "/calculators/roofing/ice-water-shield/", title: "Ice & Water Shield", desc: "Ice and water shield underlayment for eaves, rakes, and valleys", tags: ["Membrane", "Eaves", "Valleys"] },
  { href: "/calculators/roofing/snow-load/", title: "Snow Load", desc: "Roof snow load analysis based on depth, density, and building code values", tags: ["psf", "Safety", "Code"] },
];

const guides = await getCollection("guide");
const roofingGuides = guides
  .filter(g => g.data.category === "roofing")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const faqs = [
  { q: "What is a roofing square?", a: "A roofing square is a standard unit of area measurement in the construction trade equal to 100 square feet of roof surface. For example, a 1,500 square foot roof is 15 squares." },
  { q: "How many bundles of shingles do I need per square?", a: "Standard 3-tab and architectural asphalt shingles are packaged such that 3 bundles cover exactly 1 roofing square (100 square feet) of roof surface area." },
  { q: "What waste factor should I calculate for a new roof?", a: "For a simple gable roof with few valleys or dormers, add a 10% waste factor. For a complex hip roof or a roof with multiple valleys, add a 15% to 20% waste factor to account for shingle cuts." },
  { q: "What is TPO roofing?", a: "TPO (Thermoplastic Polyolefin) is a single-ply, reflective fabric roofing membrane commonly used on flat or low-slope commercial and residential buildings. Made from a blend of polypropylene and ethylene-propylene rubber, it is hot-air welded at the seams to form a watertight seal. Its white surface is highly solar-reflective, lowering cooling bills by rejecting solar heat gain. TPO is extremely durable, resists algae growth, chemical exposure, and punctures, and is typically installed using mechanical fasteners, bonding adhesives, or ballast gravel systems." },
  { q: "How to choose a roofing style?", a: "Choosing a roofing style requires matching your home’s architectural design, local climate factors, and budget constraints. Classic gable roofs shed water and snow efficiently (ideal for snowy regions), while hip roofs provide superior wind resistance (great for hurricane zones). For flat or modern homes, single-ply systems like TPO are standard. Consider local guidelines, lifespan (asphalt lasts 20-30 years, metal lasts 50+), and use our Roofing Calculators to model different material square and underlayment costs before finalizing your architectural layout." },
];

const breadcrumbSchema = breadcrumbListSchema([
  { name: "Home", path: "/" },
  { name: "Roofing Calculators", path: "/calculators/roofing/" },
]);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    breadcrumbSchema,
    faqPageSchema(faqs, "https://homeplanninghub.com/calculators/roofing/"),
  ],
};
---

<Layout title={title} description={description} schema={schema}>
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Roofing</span>
  </nav>

  <header class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">Roofing Calculators</h1>
    <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty max-w-3xl mb-4">
      Estimate material quantities, fasteners, underlayment, and roof deck spacing. All roofing estimators apply pitch-corrected surface area multipliers to convert your building footprint into the actual sloped roof area.
    </p>
    <p class="text-sm text-[var(--fg-muted)] leading-relaxed text-pretty max-w-2xl">
      <strong>Pro tip:</strong> Roofing materials are sold by the square or by the bundle. Always verify local pitch using a pitch gauge or slope multiplier before purchasing underlayment, shingles, or metal panels.
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-12">
    {calculators.map((calc) => (
      <a href={calc.href} class="group rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-all">
        <div class="flex items-start justify-between mb-3">
          <h2 class="text-base font-semibold tracking-tight group-hover:text-[var(--fg)] transition-colors">{calc.title}</h2>
          <svg class="w-4 h-4 text-[var(--fg-muted)] group-hover:text-[var(--fg)] group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7-7 7m7-7H3" /></svg>
        </div>
        <p class="text-sm text-[var(--fg-secondary)] text-pretty mb-3">{calc.desc}</p>
        <div class="flex flex-wrap gap-1.5">
          {calc.tags.map((tag) => (
            <span class="text-[10px] font-mono px-2 py-0.5 rounded-md bg-[var(--bg-muted)] text-[var(--fg-muted)]">{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>

  {roofingGuides.length > 0 && (
    <section class="border-t border-[var(--border)] pt-8 mb-12">
      <h2 class="text-xl font-bold tracking-tight mb-6">Featured Roofing Guides</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {roofingGuides.map((guide) => (
          <a href={`/guides/${guide.id}/`} class="group rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-all">
            <span class="text-[9px] font-mono px-2 py-0.5 rounded bg-[var(--bg-muted)] text-[var(--fg-muted)] uppercase block self-start w-max mb-3">
              {guide.data.category}
            </span>
            <h3 class="text-sm font-semibold mb-2 group-hover:text-[var(--fg)] transition-colors">{guide.data.title}</h3>
            <p class="text-xs text-[var(--fg-secondary)] leading-relaxed line-clamp-3">{guide.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="border-t border-[var(--border)] pt-8 mb-12">
    <h2 class="text-xl font-bold tracking-tight mb-6">Frequently Asked Questions</h2>
    <div class="flex flex-col gap-4 max-w-3xl">
      {faqs.map((faq) => (
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
          <h3 class="text-sm font-semibold mb-2 text-[var(--fg)]">{faq.q}</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-[var(--border)] pt-8">
    <h2 class="text-lg font-bold tracking-tight mb-4">Pitch-corrected estimates</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
        <h3 class="text-sm font-semibold mb-1.5">Accurate surface area</h3>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">All roofing calculators apply the pitch multiplier to convert your building footprint into the actual sloped roof area. A 6:12 pitch adds 11.8% surface area; a 12:12 pitch adds 41.4%.</p>
      </div>
      <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
        <h3 class="text-sm font-semibold mb-1.5">Complete material lists</h3>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">Beyond the primary material, each calculator estimates screws, nails, underlayment, drip edge, H-clips, and closure strips so you can order everything in one trip.</p>
      </div>
    </div>
  </section>
</Layout>

