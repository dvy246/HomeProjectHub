---
import Layout from "../../../layouts/Layout.astro";

const title = "Roofing Calculators";
const description = "Free roofing calculators for shingles, metal panels, plywood sheathing, and roof pitch. Estimate materials, screws, underlayment, and accessories for any roofing project.";

const calculators = [
  { href: "/calculators/roofing/shingles/", title: "Shingles", desc: "Asphalt shingle bundles, squares, underlayment, nails", tags: ["Gable", "Hip", "Squares"] },
  { href: "/calculators/roofing/metal/", title: "Metal Roof", desc: "Panel count, screws, closure strips, ridge cap", tags: ["Panels", "Screws", "Ridge"] },
  { href: "/calculators/roofing/plywood/", title: "Plywood Deck", desc: "Plywood or OSB sheathing sheets for roof decking", tags: ["Sheathing", "H-Clips"] },
  { href: "/calculators/roofing/pitch/", title: "Roof Pitch", desc: "Convert pitch between ratio, degrees, and percentage", tags: ["Degrees", "Multiplier"] },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://homeprojecthub.com/" },
    { "@type": "ListItem", "position": 2, "name": "Roofing Calculators", "item": "https://homeprojecthub.com/calculators/roofing/" }
  ]
};
---

<Layout title={title} description={description} schema={schema}>
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Roofing</span>
  </nav>

  <header class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">Roofing Calculators</h1>
    <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty max-w-2xl">
      Professional roofing estimation tools for shingle, metal, and plywood deck projects. Calculate material quantities, fasteners, underlayment, and accessories with pitch-corrected surface area formulas.
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-12">
    {calculators.map((calc) => (
      <a href={calc.href} class="group rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-all">
        <div class="flex items-start justify-between mb-3">
          <h2 class="text-base font-semibold tracking-tight group-hover:text-[var(--fg)] transition-colors">{calc.title}</h2>
          <svg class="w-4 h-4 text-[var(--fg-muted)] group-hover:text-[var(--fg)] group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7-7 7m7-7H3" /></svg>
        </div>
        <p class="text-sm text-[var(--fg-secondary)] text-pretty mb-3">{calc.desc}</p>
        <div class="flex flex-wrap gap-1.5">
          {calc.tags.map((tag) => (
            <span class="text-[10px] font-mono px-2 py-0.5 rounded-md bg-[var(--bg-muted)] text-[var(--fg-muted)]">{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>

  <section class="border-t border-[var(--border)] pt-8">
    <h2 class="text-lg font-bold tracking-tight mb-4">Pitch-corrected estimates</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
        <h3 class="text-sm font-semibold mb-1.5">Accurate surface area</h3>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">All roofing calculators apply the pitch multiplier to convert your building footprint into the actual sloped roof area. A 6:12 pitch adds 11.8% surface area; a 12:12 pitch adds 41.4%.</p>
      </div>
      <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5">
        <h3 class="text-sm font-semibold mb-1.5">Complete material lists</h3>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">Beyond the primary material, each calculator estimates screws, nails, underlayment, drip edge, H-clips, and closure strips so you can order everything in one trip.</p>
      </div>
    </div>
  </section>
</Layout>
