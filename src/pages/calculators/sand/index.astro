---
import Layout from "../../../layouts/Layout.astro"
import AggregateCalc from "../../../components/calculators/AggregateCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/sand/";
const title = "Sand Calculator";
const description = "Calculate sand quantity for masonry, concrete, or play sand projects.";
const formula = "Tons = Cubic Yards x 1.35";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Landscaping", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How much sand for a sandbox?", a: "A 4x4 ft sandbox at 6\" deep needs: (48x48x6)/46,656 = 0.3 cu yd. At 1.35 t/cu yd: about 0.4 tons or 16 bags of 50 lb sand." },
    { q: "What type of sand for masonry?", a: "Masonry sand (fine, clean) is best for mortar and brickwork. Concrete sand is coarser and better for concrete mixes." },
    { q: "How many 50 lb bags of sand in a cubic yard?", a: "A cubic yard of sand weighs about 1.35 tons = 2,700 lbs. At 50 lbs per bag: about 54 bags per cubic yard." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Sand Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Sand Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate sand quantity for masonry, concrete, or play sand projects.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><AggregateCalc client:visible aggregates={[{ id: "sand", label: "Sand (1.35 t/cu yd)", tonsPerCuYd: 1.35 }, { id: "masonry_sand", label: "Masonry Sand (1.28 t/cu yd)", tonsPerCuYd: 1.28 }, { id: "concrete_sand", label: "Concrete Sand (1.35 t/cu yd)", tonsPerCuYd: 1.35 }, { id: "play_sand", label: "Play Sand (1.3 t/cu yd)", tonsPerCuYd: 1.3 }]} defaultKey="sand" calculatorLabel="Sand" /></section>
  <EstimateMethodology formula={formula} assumptions={["Sand density varies by type and moisture level.", "Dry sand density: ~1.35 tons per cubic yard.", "Wet sand can be 20-30% heavier.", "Masonry sand is finer and compacts more.", "Add 10% for compaction and waste."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much sand for a sandbox?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 4x4 ft sandbox at 6" deep needs: (48x48x6)/46,656 = 0.3 cu yd. At 1.35 t/cu yd: about 0.4 tons or 16 bags of 50 lb sand.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What type of sand for masonry?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Masonry sand (fine, clean) is best for mortar and brickwork. Concrete sand is coarser and better for concrete mixes.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many 50 lb bags of sand in a cubic yard?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A cubic yard of sand weighs about 1.35 tons = 2,700 lbs. At 50 lbs per bag: about 54 bags per cubic yard.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/gravel/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Gravel</span></a>
    <a href="/calculators/limestone/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Limestone</span></a>
    <a href="/calculators/cubic-yard/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Cubic Yard</span></a>
  </div></footer>
</article>
</Layout>
