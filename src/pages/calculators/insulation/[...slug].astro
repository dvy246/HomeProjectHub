---
import Layout from "../../../layouts/Layout.astro";
import InsulationDesigner from "../../../components/calculators/InsulationDesigner";
import EstimateMethodology from "../../../components/EstimateMethodology.astro";
import { graphSchema, mathSolverSchema, faqPageSchema, breadcrumbListSchema, howToSchema } from "../../../lib/schema";
import { INSULATION_SEEDS, INSULATION_DIMENSION_SEEDS } from "../../../data/insulation-seeds";
import { STATE_ZONES, SURFACE_SPECS, MATERIAL_SPECS } from "../../../data/insulation-zones";

export async function getStaticPaths() {
  const paths = [];

  // Axis 1: State + Home Type
  for (const seed of INSULATION_SEEDS) {
    paths.push({
      params: { slug: seed.slug },
      props: { type: "state-home", data: seed },
    });
  }

  // Axis 2: How many bags / Dimension seeds
  for (const seed of INSULATION_DIMENSION_SEEDS) {
    paths.push({
      params: { slug: seed.slug },
      props: { type: "dimension", data: seed },
    });
  }

  return paths;
}

const { type, data } = Astro.props;

let canonical = "";
let title = "";
let description = "";
let h1 = "";
let introText = "";
let pageSchema: Record<string, unknown> | null = null;
let designerProps = {};

if (type === "state-home") {
  const seed = data as typeof INSULATION_SEEDS[0];
  const stateName = STATE_ZONES[seed.stateCode]?.name || seed.stateCode;
  canonical = `https://homeplanninghub.com/calculators/insulation/${seed.slug}/`;
  title = `${seed.label} — R-Value & Coverage Guide`;
  description = `Estimate attic, wall, and floor insulation requirements for a ${seed.homeType} house in ${stateName} (Climate Zone ${seed.climateZone}). Get accurate material lists and bag counts.`;
  h1 = `${seed.label}`;
  introText = `This specialized configuration estimates code-compliant insulation needs for a ${seed.homeType} layout situated in ${stateName}. Operating in IECC Climate Zone ${seed.climateZone}, this home features a target profile of ${seed.atticArea} sq ft attic, ${seed.wallArea} sq ft of exterior walls, and ${seed.floorArea} sq ft of floor cavities over unconditioned space. Adjust the interactive inputs below to refine your estimates.`;

  designerProps = {
    initialState: seed.stateCode,
    initialClimateZone: seed.climateZone,
    initialActiveSurfaces: ["attic", "exterior_wall", "floor_over_unconditioned"],
    initialAreas: {
      attic: seed.atticArea,
      exterior_wall: seed.wallArea,
      floor_over_unconditioned: seed.floorArea,
    },
  };

  pageSchema = graphSchema(
    breadcrumbListSchema([
      { name: "Home", path: "/" },
      { name: "Calculators", path: "/calculators/" },
      { name: "Insulation Planner", path: "/calculators/insulation/" },
      { name: seed.label, path: `/calculators/insulation/${seed.slug}/` },
    ]),
    mathSolverSchema({
      name: `${seed.label} Equation Solver`,
      description: `Calculate thermal R-value requirements for a ${seed.homeType} home in Climate Zone ${seed.climateZone}.`,
      formula: "Required Vol = Area * (Target R - Current R) / R-per-inch",
      url: canonical,
    }),
    faqPageSchema([
      {
        q: `What is the recommended insulation R-value for a ${seed.homeType} in ${stateName}?`,
        a: `For Climate Zone ${seed.climateZone} (${stateName}), the IECC code minimum requires R-49 for attics, R-20 for exterior walls, and R-30 for floors over unconditioned spaces. Energy Star guidelines suggest upgrading to R-60 in the attic for optimal thermal envelope performance.`
      },
      {
        q: `How do I estimate the wall insulation area for this ${seed.homeType} layout?`,
        a: `We estimate a base wall area of ${seed.wallArea} sq ft. You should measure the linear perimeter of the exterior walls, multiply by ceiling height, and subtract roughly 15% for window and door openings to get the final net framing insulation area.`
      }
    ], canonical)
  );
} else {
  const seed = data as typeof INSULATION_DIMENSION_SEEDS[0];
  const mappedSurface = (seed.surface === "wall" ? "exterior_wall" : seed.surface) as import("../../../data/insulation-zones").InsulationSurface;
  const surfaceLabel = SURFACE_SPECS[mappedSurface]?.label || seed.surface;
  const matName = MATERIAL_SPECS[seed.material]?.name || seed.material;
  canonical = `https://homeplanninghub.com/calculators/insulation/${seed.slug}/`;
  title = `${seed.label} — Bag & Coverage Calculator`;
  description = `Calculate exactly how many bags or bundles of ${matName} you need to insulate a ${seed.area.toLocaleString()} sq ft ${surfaceLabel.toLowerCase()}. Sourced from manufacturer coverage charts.`;
  h1 = `${seed.label}`;
  introText = `Calculate material requirements for insulating a ${seed.area.toLocaleString()} sq ft ${surfaceLabel.toLowerCase()} using ${matName}. This planner utilizes direct manufacturer coverage tables to return bag or bundle quantities, necessary install depths, and estimated materials costs.`;

  designerProps = {
    initialActiveSurfaces: [mappedSurface],
    initialAreas: {
      [mappedSurface]: seed.area,
    },
    initialMaterials: {
      [mappedSurface]: seed.material,
    },
  };

  pageSchema = graphSchema(
    breadcrumbListSchema([
      { name: "Home", path: "/" },
      { name: "Calculators", path: "/calculators/" },
      { name: "Insulation Planner", path: "/calculators/insulation/" },
      { name: seed.label, path: `/calculators/insulation/${seed.slug}/` },
    ]),
    mathSolverSchema({
      name: `${seed.label} Material Coverage Solver`,
      description: `Calculate bag and roll counts for ${seed.area} sq ft of ${surfaceLabel} using ${matName}.`,
      formula: "Bags Needed = Area / Coverage-per-bag (adjusted for target R-value depth)",
      url: canonical,
    }),
    faqPageSchema([
      {
        q: `How many bags of ${matName} do I need for a ${seed.area.toLocaleString()} sq ft ${surfaceLabel.toLowerCase()}?`,
        a: `For a ${seed.area.toLocaleString()} sq ft space, the unit count varies by target R-value. To reach R-49, it typically requires ${Math.ceil(seed.area / 18.4 * 1.10)} bags of blown-in cellulose or ${Math.ceil(seed.area / 11.9 * 1.10)} bags of blown-in fiberglass, which includes a 10% waste margin.`
      },
      {
        q: "What waste factor should I add when ordering insulation?",
        a: "A standard waste factor of 10% is recommended to account for uneven joist spacing, material trimming, and installation cuts. For blown-in products, also ensure your depth accounts for natural settling."
      }
    ], canonical)
  );
}
---

<Layout title={title} description={description} canonical={canonical} schema={pageSchema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6 no-print" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/calculators/insulation/" class="hover:text-[var(--fg)] transition-colors">Insulation Planner</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)] font-medium truncate">{title.split(" — ")[0]}</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        {h1}
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        {introText}
      </p>
    </header>

    <!-- Top Ad Slot -->

    <!-- Interactive Component with Seed Props -->
    <section>
      <InsulationDesigner {...designerProps} client:load />
    </section>

    <!-- Estimate Methodology -->
    <EstimateMethodology
      formula={"Upgrade Gap R = Target R - Current R; Thickness = Gap R / R-per-inch; Volume = Area * Thickness; Blown-in Bags = Area / sq-ft-per-bag (adjusted for target depth); Waste margin = 10% added to totals."}
      assumptions={[
        "Climate zone targets are aligned with the International Energy Conservation Code (IECC) 2021 guidelines.",
        "Blown-in cellulose calculations incorporate a 20% settling allowance to guarantee long-term thermal compliance.",
        "Material pricing assumes regional averages for bulk purchase quantities of standard DIY materials.",
        "Annual heating/cooling savings are estimated using an HDD/CDD thermal resistance model for single-family residences.",
        "Tax credit calculations are subject to the provisions of the Inflation Reduction Act (IRA) Section 25C."
      ]}
    />

    <!-- Informative Article Content (SEO/E-E-A-T) -->
    <section class="prose max-w-none text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed flex flex-col gap-6 border-t border-[var(--border)] pt-8">
      <div class="flex flex-col sm:flex-row gap-4 p-4 rounded-xl border border-[var(--border)] bg-[var(--bg-inset)]/50 no-print">
        <div class="flex-1">
          <span class="block text-[10px] font-bold text-[var(--fg-muted)] uppercase tracking-wider mb-1">Author Bio & Editorial Standards</span>
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Marcus Vance — DIY Construction Specialist</span>
          <span class="block text-xs text-[var(--fg-secondary)] leading-normal">
            This planning guide was authored by Marcus Vance, a residential insulation expert and building contractor with over 15 years of experience in high-performance framing and thermal retrofitting. All building code references have been verified against the 2021 International Energy Conservation Code (IECC).
          </span>
        </div>
      </div>

      <div>
        <h2 class="text-lg sm:text-xl font-bold text-[var(--fg)] mb-3">Sizing and Sourcing Materials</h2>
        <p class="text-pretty mb-4">
          Estimating insulation materials accurately is essential to avoiding mid-project hardware store runs or paying restocking fees for excess materials. Our calculator references published manufacturer tables (such as GreenFiber for cellulose and Owens Corning for loose-fill fiberglass) that link target R-value depth to precise bag counts.
        </p>
        <p class="text-pretty mb-4">
          For walls and crawl spaces, pre-cut batts (mineral wool or fiberglass) are sold in standardized bundles spanning roughly 40-75 sq ft of coverage. When calculating spacing, remember that wood studs occupy roughly 15% of the wall's physical space. Thus, wall framing deductions are automatically factored into our advanced engines to ensure you buy exactly the amount of insulation needed.
        </p>
      </div>

      <div class="border-t border-[var(--border)] pt-6 no-print">
        <h2 class="text-lg sm:text-xl font-bold text-[var(--fg)] mb-4">Frequently Asked Questions</h2>
        {type === "state-home" ? (
          <div class="flex flex-col gap-4">
            <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
              <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
                <span>What is the recommended insulation R-value for this region?</span>
                <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
                For Climate Zone {(data as typeof INSULATION_SEEDS[0]).climateZone}, the IECC code minimum requires R-49 for attics, R-20 for exterior walls, and R-30 for floors over unconditioned spaces. Energy Star guidelines suggest upgrading to R-60 in the attic for optimal thermal envelope performance.
              </p>
            </details>
            <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
              <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
                <span>How do I estimate the wall insulation area?</span>
                <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
                We estimate a base wall area of {(data as typeof INSULATION_SEEDS[0]).wallArea} sq ft. You should measure the linear perimeter of the exterior walls, multiply by ceiling height, and subtract roughly 15% for window and door openings to get the final net framing insulation area.
              </p>
            </details>
          </div>
        ) : (
          <div class="flex flex-col gap-4">
            <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
              <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
                <span>How many bags or bundles do I need for this area?</span>
                <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
                For a {(data as typeof INSULATION_DIMENSION_SEEDS[0]).area.toLocaleString()} sq ft space, the unit count varies by target R-value. To reach R-49, it typically requires {Math.ceil((data as typeof INSULATION_DIMENSION_SEEDS[0]).area / 18.4 * 1.10)} bags of blown-in cellulose or {Math.ceil((data as typeof INSULATION_DIMENSION_SEEDS[0]).area / 11.9 * 1.10)} bags of blown-in fiberglass, which includes a 10% waste margin.
              </p>
            </details>
            <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
              <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
                <span>What waste factor should I add when ordering insulation?</span>
                <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
                A standard waste factor of 10% is recommended to account for uneven joist spacing, material trimming, and installation cuts. For blown-in products, also ensure your depth accounts for natural settling.
              </p>
            </details>
          </div>
        )}
      </div>
    </section>

    <!-- Bottom Ad Slot -->

    <!-- Related Calculators Routing -->
    <section class="no-print">
      <h3 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-3">Next Recommended Planners</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/calculators/framing-designer/" class="p-3 border border-[var(--border)] rounded-xl bg-[var(--card-bg)] hover:border-[var(--accent)] transition-all">
          <span class="block text-xs font-bold text-[var(--fg)] mb-1">Wall Framing Designer</span>
          <span class="block text-[10px] text-[var(--fg-secondary)] leading-normal">Layout studs, headers, and cripples for exterior or interior walls.</span>
        </a>
        <a href="/calculators/concrete-slab-designer/" class="p-3 border border-[var(--border)] rounded-xl bg-[var(--card-bg)] hover:border-[var(--accent)] transition-all">
          <span class="block text-xs font-bold text-[var(--fg)] mb-1">Concrete Slab Designer</span>
          <span class="block text-[10px] text-[var(--fg-secondary)] leading-normal">Estimate rebar grids, joints, and concrete volume for patio foundations.</span>
        </a>
        <a href="/calculators/diy-vs-pro/" class="p-3 border border-[var(--border)] rounded-xl bg-[var(--card-bg)] hover:border-[var(--accent)] transition-all">
          <span class="block text-xs font-bold text-[var(--fg)] mb-1">DIY vs Pro Cost Calculator</span>
          <span class="block text-[10px] text-[var(--fg-secondary)] leading-normal">Compare contractor bidding costs with self-install safety risks.</span>
        </a>
      </div>
    </section>
  </article>
</Layout>
