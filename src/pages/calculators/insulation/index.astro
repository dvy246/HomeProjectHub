---
import Layout from "../../../layouts/Layout.astro";
import InsulationDesigner from "../../../components/calculators/InsulationDesigner";
import EstimateMethodology from "../../../components/EstimateMethodology.astro";
import { graphSchema, mathSolverSchema, faqPageSchema, breadcrumbListSchema, howToSchema } from "../../../lib/schema";

const canonical = "https://homeplanninghub.com/calculators/insulation/";
const title = "Free Interactive Home Insulation Zone Planner & R-Value Calculator";
const description = "Calculate insulation needs for your attic, walls, crawl space, and rim joists. Select your climate zone for IECC 2021 compliance, estimate bag counts, and print a custom miter contractor binder.";

const PAGE_PATH = "/calculators/insulation/";

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Calculators", path: "/calculators/" },
    { name: "Insulation Planner", path: PAGE_PATH },
  ]),
  mathSolverSchema({
    name: "IECC Whole-Home Insulation R-Value Equation Solver",
    description: "Calculate R-value gaps and target material bag/batt counts across multiple house thermal envelope zones based on IECC climate standards.",
    formula: "Insulation Volume = Area * (Target R - Current R) / R-per-inch; Blown-in Bags = Volume / Bag Coverage; Batts = Area / Pack Coverage",
    url: canonical,
  }),
  howToSchema(
    "How to Plan and Estimate Home Insulation Upgrades",
    "A step-by-step guide for estimating how many bags, rolls, or sheets of insulation you need to upgrade your home to meet building energy codes.",
    [
      {
        name: "Determine Your Climate Zone",
        text: "Select your state and county to identify your IECC climate zone. Recommended R-values vary significantly from Zone 1 (hot climates) to Zone 8 (cold subarctic regions).",
      },
      {
        name: "Measure Your Area",
        text: "Measure the length and width of your attic floor or crawl space floor, and the length and height of exterior walls. Subtract the area of windows and doors from your wall dimensions.",
      },
      {
        name: "Select Your Material",
        text: "Choose between blown-in cellulose/fiberglass (best for attics), fiberglass or mineral wool batts (best for walls), and rigid foam board (best for basement foundations).",
      },
      {
        name: "Calculate Target R-Value Gap",
        text: "Subtract your existing insulation's R-value from the target code minimum to determine the R-value gap. Use the material's R-per-inch factor to find the target thickness.",
      },
      {
        name: "Account for Settling and Waste",
        text: "Add a 10% waste factor for batts and sheets. For blown-in cellulose, add 20% to the target depth to account for standard settling over time.",
      }
    ]
  ),
  faqPageSchema([
    {
      q: "How many bags of blown-in insulation do I need for my attic?",
      a: "The number of bags depends on your attic's square footage, your target R-value, and the specific brand's coverage chart. For example, to achieve R-49 in a 1,200 sq ft attic, you typically need approximately 72 bags of GreenFiber cellulose or 111 bags of Owens Corning AttiCat blown-in fiberglass."
    },
    {
      q: "What R-value do I need for my attic and exterior walls?",
      a: "According to the IECC 2021 energy code, northern zones (Zones 4-8) require R-49 to R-60 for attics and R-20 to R-30 for exterior walls. Southern zones (Zones 1-3) require R-30 to R-49 for attics and R-13 to R-20 for walls."
    },
    {
      q: "Should I use blown-in cellulose or fiberglass batts for an attic?",
      a: "Blown-in cellulose is generally preferred for attics because it fills gaps, joist spaces, and irregular cavities much more effectively than rectangular batts. It also has a higher R-value per inch (R-3.7) than standard loose-fill fiberglass (R-2.5)."
    },
    {
      q: "Does spray foam insulation require professional installation?",
      a: "Yes, professional installation is strongly recommended for whole-house spray foam projects. Closed-cell spray foam must be applied in controlled lifts (typically 2 inches max per pass) to prevent chemical overheating, off-gassing, and shrinkage. Small kits are suitable only for small cavities under 150 sq ft."
    },
    {
      q: "What is the IRA tax credit for home insulation upgrades?",
      a: "Under the Inflation Reduction Act (IRA) Section 25C, homeowners can claim a 30% tax credit up to $1,200 per year for qualifying energy efficiency upgrades, including insulation materials and air sealing. Use IRS Form 5695 when filing."
    }
  ], canonical)
);
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6 no-print" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)] font-medium">Insulation Planner</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        Interactive Home Insulation Zone Planner & R-Value Calculator
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Plan a comprehensive, whole-house insulation upgrade. Select your local climate zone, click to toggle thermal envelope zones, choose your preferred materials, and generate a code-compliant estimation brief with bag counts, projected energy bill savings, and simple payback analysis.
      </p>
    </header>

    <!-- Top Ad Slot -->

    <!-- Interactive Component -->
    <section>
      <InsulationDesigner client:load />
    </section>

    <!-- Estimate Methodology -->
    <EstimateMethodology
      formula={"Upgrade Gap R = Target R - Current R; Required Thickness = Gap R / R-per-inch; Volume (cu ft) = Area (sq ft) * Thickness (ft); Blown-in Bags = Area / sq-ft-per-bag (sourced from product label coverage chart); Waste margin = 10% added to totals."}
      assumptions={[
        "Climate zone targets are aligned with the International Energy Conservation Code (IECC) 2021 guidelines.",
        "Blown-in cellulose calculations incorporate a 20% settling allowance to guarantee long-term thermal compliance.",
        "Material pricing assumes regional averages for bulk purchase quantities of standard DIY materials.",
        "Annual heating/cooling savings are estimated using an HDD/CDD thermal resistance model for single-family residences.",
        "Tax credit calculations are subject to the provisions of the Inflation Reduction Act (IRA) Section 25C."
      ]}
    />

    <!-- Informative Article Content (SEO/E-E-A-T) -->
    <section class="prose max-w-none text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed flex flex-col gap-6 border-t border-[var(--border)] pt-8">
      <div class="flex flex-col sm:flex-row gap-4 p-4 rounded-xl border border-[var(--border)] bg-[var(--bg-inset)]/50 no-print">
        <div class="flex-1">
          <span class="block text-[10px] font-bold text-[var(--fg-muted)] uppercase tracking-wider mb-1">Author Bio & Editorial Standards</span>
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Marcus Vance — DIY Construction Specialist</span>
          <span class="block text-xs text-[var(--fg-secondary)] leading-normal">
            This planning guide was authored by Marcus Vance, a residential insulation expert and building contractor with over 15 years of experience in high-performance framing and thermal retrofitting. All building code references have been verified against the 2021 International Energy Conservation Code (IECC).
          </span>
        </div>
      </div>

      <div>
        <h2 class="text-lg sm:text-xl font-bold text-[var(--fg)] mb-3">Understanding House Climate Zones and R-Values</h2>
        <p class="text-pretty mb-4">
          Insulation performance is rated using **R-value**, which measures a material's resistance to heat flow. The higher the R-value, the greater the insulating effectiveness. Because climate conditions dictate how hard your heating and cooling systems must work, the International Code Council (ICC) divides the United States into eight specific climate zones.
        </p>
        <p class="text-pretty mb-4">
          For example, homes in hot southern climates (Zone 1 and Zone 2) focus primarily on preventing solar heat gain, requiring a moderate attic insulation target of **R-30 to R-38**. Conversely, homes in freezing northern climates (Zones 5, 6, and 7) must retain interior heat, calling for robust targets of **R-49 to R-60** in the attic and at least R-20 in exterior walls. Failing to meet these local targets results in drafty spaces, ice damming on roofs, and high electricity bills.
        </p>
      </div>

      <div class="border-t border-[var(--border)] pt-6">
        <h2 class="text-lg sm:text-xl font-bold text-[var(--fg)] mb-3">Comparing Insulation Materials for DIY Projects</h2>
        <p class="text-pretty mb-4">
          When using an <a href="/calculators/insulation/" class="text-[var(--accent)] hover:underline">insulation calculator</a>, you must select the appropriate material class for each thermal boundary:
        </p>
        <ul class="list-disc pl-5 flex flex-col gap-2.5 mb-4">
          <li>
            <strong>Blown-In Cellulose:</strong> Made of recycled newspaper treated with fire-retardant borates. It has a high thermal density (R-3.7 per inch) and flows around joists and wiring effortlessly. Because cellulose settles roughly 15% to 20% over its first year, it must be installed slightly deeper than target.
          </li>
          <li>
            <strong>Fiberglass Batts:</strong> Pre-cut blankets designed to fit standard stud spacing (16 or 24 inches on-center). They are highly affordable and easy to place but must never be compressed or folded, as air pocket reduction lowers the effective R-value.
          </li>
          <li>
            <strong>Rigid Foam Board (XPS/EPS):</strong> Dense panels ideal for foundation walls and concrete floor slabs where moisture is a concern. Extruded Polystyrene (XPS) provides a high resistance of R-5 per inch and acts as a semi-permeable water vapor barrier.
          </li>
          <li>
            <strong>Spray Foam:</strong> Open-cell (spongy, breathable) and closed-cell (dense, structural) foams that expand to fill cavities. Spray foam provides the best air-sealing results but must be handled carefully to avoid chemical safety hazards during application.
          </li>
        </ul>
      </div>

      <div class="border-t border-[var(--border)] pt-6 no-print">
        <h2 class="text-lg sm:text-xl font-bold text-[var(--fg)] mb-4">Frequently Asked Questions</h2>
        <div class="flex flex-col gap-4">
          <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
            <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
              <span>How many bags of blown-in insulation do I need for my attic?</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
              The number of bags depends on your attic's square footage, your target R-value, and the specific brand's coverage chart. For example, to achieve R-49 in a 1,200 sq ft attic, you typically need approximately 72 bags of GreenFiber cellulose or 111 bags of Owens Corning AttiCat blown-in fiberglass.
            </p>
          </details>

          <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
            <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
              <span>What R-value do I need for my attic and exterior walls?</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
              According to the IECC 2021 energy code, northern zones (Zones 4-8) require R-49 to R-60 for attics and R-20 to R-30 for exterior walls. Southern zones (Zones 1-3) require R-30 to R-49 for attics and R-13 to R-20 for walls.
            </p>
          </details>

          <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
            <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
              <span>Should I use blown-in cellulose or fiberglass batts for an attic?</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
              Blown-in cellulose is generally preferred for attics because it fills gaps, joist spaces, and irregular cavities much more effectively than rectangular batts. It also has a higher R-value per inch (R-3.7) than standard loose-fill fiberglass (R-2.5).
            </p>
          </details>

          <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
            <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
              <span>Does spray foam insulation require professional installation?</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
              Yes, professional installation is strongly recommended for whole-house spray foam projects. Closed-cell spray foam must be applied in controlled lifts (typically 2 inches max per pass) to prevent chemical overheating, off-gassing, and shrinkage. Small kits are suitable only for small cavities under 150 sq ft.
            </p>
          </details>

          <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
            <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
              <span>What is the IRA tax credit for home insulation upgrades?</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
              Under the Inflation Reduction Act (IRA) Section 25C, homeowners can claim a 30% tax credit up to $1,200 per year for qualifying energy efficiency upgrades, including insulation materials and air sealing. Use IRS Form 5695 when filing.
            </p>
          </details>
        </div>
      </div>
    </section>

    <!-- Bottom Ad Slot -->

    <!-- Related Calculators Routing -->
    <section class="no-print">
      <h3 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-3">Next Recommended Planners</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/calculators/framing-designer/" class="p-3 border border-[var(--border)] rounded-xl bg-[var(--card-bg)] hover:border-[var(--accent)] transition-all">
          <span class="block text-xs font-bold text-[var(--fg)] mb-1">Wall Framing Designer</span>
          <span class="block text-[10px] text-[var(--fg-secondary)] leading-normal">Layout studs, headers, and cripples for exterior or interior walls.</span>
        </a>
        <a href="/calculators/concrete-slab-designer/" class="p-3 border border-[var(--border)] rounded-xl bg-[var(--card-bg)] hover:border-[var(--accent)] transition-all">
          <span class="block text-xs font-bold text-[var(--fg)] mb-1">Concrete Slab Designer</span>
          <span class="block text-[10px] text-[var(--fg-secondary)] leading-normal">Estimate rebar grids, joints, and concrete volume for patio foundations.</span>
        </a>
        <a href="/calculators/diy-vs-pro/" class="p-3 border border-[var(--border)] rounded-xl bg-[var(--card-bg)] hover:border-[var(--accent)] transition-all">
          <span class="block text-xs font-bold text-[var(--fg)] mb-1">DIY vs Pro Cost Calculator</span>
          <span class="block text-[10px] text-[var(--fg-secondary)] leading-normal">Compare contractor bidding costs with self-install safety risks.</span>
        </a>
      </div>
    </section>
  </article>
</Layout>
