---
import Layout from "../../../layouts/Layout.astro"
import AggregateCalc from "../../../components/calculators/AggregateCalc"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro"

const canonical = "https://homeplanninghub.com/calculators/gravel/";
const title = "Gravel Calculator";
const description = "Calculate how much gravel, crushed stone, or sand you need for driveways, paths, and landscaping beds. Get cubic yards, tons, and truckload estimates.";
const formula = "Tons = Cubic Yards × Material Density (tons/cu yd)";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Gravel Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How much gravel for a driveway?",
      a: "A 12x50 ft driveway at 6\" depth needs about 11 cu yd. At 1.4 tons/cu yd, that's 15.4 tons.",
    },
    {
      q: "How deep should gravel be?",
      a: "Driveways 4-6\", walkways 2-3\", drainage 12\"+. Always compact in layers.",
    },
    {
      q: "How many tons in a cubic yard of gravel?",
      a: "Most gravel weighs 1.3-1.7 tons per cubic yard depending on stone size and moisture.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Gravel Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Gravel Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate how much gravel, crushed stone, or sand you need for driveways, paths, and landscaping beds. Get cubic yards, tons, and truckload estimates.</p>
    <section><AggregateCalc client:visible aggregates={[
      {
            id: "gravel",
            label: "Gravel (1.4 t/cu yd)",
            tonsPerCuYd: 1.4
      },
      {
            id: "crushed_stone",
            label: "Crushed Stone (1.6 t/cu yd)",
            tonsPerCuYd: 1.6
      },
      {
            id: "sand",
            label: "Sand (1.2 t/cu yd)",
            tonsPerCuYd: 1.2
      },
      {
            id: "decomposed_granite",
            label: "Decomposed Granite (1.45 t/cu yd)",
            tonsPerCuYd: 1.45
      }
]} defaultKey="gravel" calculatorLabel="Gravel" /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Density varies by material type and moisture content.",
        "Compacted material may settle 10-15%.",
        "Depth should be 4-6 inches for driveways."
      ]}
    />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much gravel for a driveway?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 12x50 ft driveway at 6" depth needs about 11 cu yd. At 1.4 tons/cu yd, that's 15.4 tons.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How deep should gravel be?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Driveways 4-6", walkways 2-3", drainage 12"+. Always compact in layers.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many tons in a cubic yard of gravel?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Most gravel weighs 1.3-1.7 tons per cubic yard depending on stone size and moisture.</p></details>
      </div>
    </section>
    <RelatedCalculators slug="gravel" />
  </article>
</Layout>
