---
import Layout from "../../../layouts/Layout.astro"
import SpiralStaircaseCalc from "../../../components/calculators/SpiralStaircaseCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/spiral-staircase/";
const title = "Spiral Staircase Calculator";
const description = "Design a spiral staircase with accurate dimensions. Calculate riser height, tread width, stringer length, and check IRC compliance for your stair project.";
const formula = "Riser = Total Rise / Tread Count | Walk Line Tread Width = (Diameter - 1) x Pi / Tread Count x 12 | Stringer approx = sqrt((Walk Circ x 12)^2 + Rise^2) / 12";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Specialty", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "What is the minimum diameter for a spiral staircase?", a: "IRC requires minimum 60 inches diameter (5 ft) for a spiral staircase to allow 26 inch clear tread width at the walk line." },
    { q: "What is the maximum riser height for a spiral staircase?", a: "IRC allows maximum 9.5 inch riser height for spiral staircases, compared to 7.75 inches for standard stairs." },
    { q: "How many treads do I need for a 10 ft ceiling?", a: "A 10 ft ceiling (120 inches) with 9 inch risers needs about 14 treads. Always round up and check headroom clearance." },
    { q: "Do spiral staircases need a landing?", a: "Spiral staircases are considered one continuous flight and do not require intermediate landings. They must meet minimum tread depth requirements." },
    { q: "Can a spiral staircase be a primary egress?", a: "Yes, spiral staircases can serve as a required egress if they meet IRC minimums: 60\" diameter, 9.5\" max riser, 26\" walk line tread, and 6'6\" headroom." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Spiral Staircase Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Spiral Staircase Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Design a spiral staircase with accurate dimensions. Calculate riser height, tread width, stringer length, and check IRC compliance for your stair project.</p>
  <AdSlot slotId="ad-top-leaderboard" />

  <section><SpiralStaircaseCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Walk line calculated at 12 inches from inner handrail.", "IRC 2018 code minimums applied for compliance checks.", "Stringer length is approximate — verify with manufacturer specs.", "Headroom clearance assumes minimum 6 ft 6 inches."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the minimum diameter for a spiral staircase?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">IRC requires minimum 60 inches diameter (5 ft) for a spiral staircase to allow 26 inch clear tread width at the walk line.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the maximum riser height for a spiral staircase?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">IRC allows maximum 9.5 inch riser height for spiral staircases, compared to 7.75 inches for standard stairs.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many treads do I need for a 10 ft ceiling?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 10 ft ceiling (120 inches) with 9 inch risers needs about 14 treads. Always round up and check headroom clearance.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Do spiral staircases need a landing?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Spiral staircases are considered one continuous flight and do not require intermediate landings. They must meet minimum tread depth requirements.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Can a spiral staircase be a primary egress?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Yes, spiral staircases can serve as a required egress if they meet IRC minimums: 60" diameter, 9.5" max riser, 26" walk line tread, and 6'6" headroom.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/board-foot/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Board Foot</span></a>
    <a href="/calculators/square-footage/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Square Footage</span></a>
    <a href="/calculators/framing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Framing</span></a>
  </div></footer>
</article>
</Layout>
