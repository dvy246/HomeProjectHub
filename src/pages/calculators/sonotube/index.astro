---
import Layout from "../../../layouts/Layout.astro"
import SonotubeCalc from "../../../components/calculators/SonotubeCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/sonotube/";
const title = "Sonotube Calculator";
const description = "Calculate how many bags of concrete you need for Sonotube piers and columns. Enter tube diameter, height, and quantity for accurate concrete volume estimates.";
const formula = "Cubic Yards = π × r² × h × Quantity / 27";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Sonotube Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How many bags for a 10\" sonotube?",
      a: "A 10\" diameter × 48\" tall sonotube requires 2.4 cu ft of concrete = 4 bags of 80 lb mix (0.6 cu ft per bag).",
    },
    {
      q: "How deep should a sonotube be?",
      a: "Minimum 48\" deep below grade for frost protection in most climates. Check local building codes for exact depth.",
    },
    {
      q: "Do I need rebar in sonotubes?",
      a: "Yes. Use #4 rebar vertically (2-4 bars per tube depending on load) and a J-bolt at the top for anchoring.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Sonotube Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Sonotube Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate how many bags of concrete you need for Sonotube piers and columns. Enter tube diameter, height, and quantity for accurate concrete volume estimates.</p>
    <AdSlot slotId="ad-top-leaderboard" />
    <section><SonotubeCalc client:visible /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Standard 80 lb bag yields 0.6 cu ft of concrete.",
        "Tube diameters: 6\", 8\", 10\", 12\", 14\", 18\", 24\", 36\".",
        "Add 5-10% waste for spillage and uneven ground."
      ]}
    />
    <AdSlot slotId="ad-in-content-mid" />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many bags for a 10" sonotube?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 10" diameter × 48" tall sonotube requires 2.4 cu ft of concrete = 4 bags of 80 lb mix (0.6 cu ft per bag).</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How deep should a sonotube be?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Minimum 48" deep below grade for frost protection in most climates. Check local building codes for exact depth.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Do I need rebar in sonotubes?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Yes. Use #4 rebar vertically (2-4 bars per tube depending on load) and a J-bolt at the top for anchoring.</p></details>
      </div>
    </section>
    <footer class="pt-8 mt-6 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/calculators/concrete/slab/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Concrete Slab</span></a>
      <a href="/calculators/concrete/footing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Footing</span></a>
      </div>
    </footer>
  </article>
</Layout>
