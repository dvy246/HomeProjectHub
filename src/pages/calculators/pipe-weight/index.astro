---
import Layout from "../../../layouts/Layout.astro"
import PipeWeightCalc from "../../../components/calculators/PipeWeightCalc"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/pipe-weight/";
const title = "Pipe Weight Calculator";
const description = "Calculate pipe weight per foot based on outer diameter and wall thickness.";
const formula = "Weight/ft = pi x (OD - WT) x WT x Density / 144";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Weight", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How much does 1 ft of 4 inch Schedule 40 steel pipe weigh?", a: "A 4\" Schedule 40 pipe (4.5\" OD, 0.237\" wall) weighs 10.79 lb/ft. For 20 ft: 215.8 lbs." },
    { q: "What is Schedule 80 vs Schedule 40 weight?", a: "Schedule 80 has thicker walls than Schedule 40 for the same OD. For 2\" pipe: Sch 40 = 3.65 lb/ft, Sch 80 = 5.02 lb/ft." },
    { q: "Does pipe weight include the contents?", a: "No, this calculator computes empty pipe weight only. For filled pipe weight, add the weight of the internal fluid volume." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Pipe Weight Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Pipe Weight Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate pipe weight per foot based on outer diameter and wall thickness.</p>
  <section><PipeWeightCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Formula calculates weight of the pipe wall material only.", "Steel density: 0.2836 lb/cu in (490 lb/cu ft).", "Does not include fittings, flanges, or valves.", "Schedule designations follow ANSI/ASME B36.10 standard."]} />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does 1 ft of 4 inch Schedule 40 steel pipe weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 4" Schedule 40 pipe (4.5" OD, 0.237" wall) weighs 10.79 lb/ft. For 20 ft: 215.8 lbs.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is Schedule 80 vs Schedule 40 weight?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Schedule 80 has thicker walls than Schedule 40 for the same OD. For 2" pipe: Sch 40 = 3.65 lb/ft, Sch 80 = 5.02 lb/ft.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Does pipe weight include the contents?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">No, this calculator computes empty pipe weight only. For filled pipe weight, add the weight of the internal fluid volume.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/metal-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Metal Weight</span></a>
    <a href="/calculators/steel-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Steel Weight</span></a>
    <a href="/calculators/square-footage/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Square Footage</span></a>
  </div></footer>
</article>
</Layout>
