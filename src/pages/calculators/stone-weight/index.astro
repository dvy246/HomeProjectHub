---
import Layout from "../../../layouts/Layout.astro"
import StoneWeightCalc from "../../../components/calculators/StoneWeightCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/stone-weight/";
const title = "Stone Weight Calculator";
const description = "Estimate the weight of natural stone slabs and countertops — granite, marble, limestone, sandstone, and concrete. Input dimensions for accurate weight.";
const formula = "Weight = Volume × Material Density";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Stone Weight Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How much does a granite countertop weigh?",
      a: "A 6×2 ft granite slab at 3 cm thick (~1.18\") weighs about 225 lbs. Granite density is 190 lb/cu ft.",
    },
    {
      q: "Can I use this for monument stone?",
      a: "Yes. This calculator works for any stone slab. For irregular shapes, use average dimensions and add 15-20%.",
    },
    {
      q: "Is concrete the same as stone?",
      a: "No. Concrete density is about 150 lb/cu ft while granite is 190 lb/cu ft. This calculator provides separate options.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Stone Weight Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Stone Weight Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Estimate the weight of natural stone slabs and countertops — granite, marble, limestone, sandstone, and concrete. Input dimensions for accurate weight.</p>
    <AdSlot slotId="ad-top-leaderboard" />
    <section><StoneWeightCalc client:visible /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Stone densities vary by quarry and composition.",
        "Granite average: 190 lb/cu ft, Marble: 170 lb/cu ft.",
        "Slab thickness typically 2-3 cm for countertops."
      ]}
    />
    <AdSlot slotId="ad-in-content-mid" />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does a granite countertop weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 6×2 ft granite slab at 3 cm thick (~1.18") weighs about 225 lbs. Granite density is 190 lb/cu ft.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Can I use this for monument stone?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Yes. This calculator works for any stone slab. For irregular shapes, use average dimensions and add 15-20%.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Is concrete the same as stone?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">No. Concrete density is about 150 lb/cu ft while granite is 190 lb/cu ft. This calculator provides separate options.</p></details>
      </div>
    </section>
    <footer class="pt-8 mt-6 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/calculators/plate-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Plate Weight</span></a>
      <a href="/calculators/concrete/slab/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Concrete Slab</span></a>
      </div>
    </footer>
  </article>
</Layout>
