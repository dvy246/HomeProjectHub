---
import Layout from "../../../layouts/Layout.astro"
import BrickCalc from "../../../components/calculators/BrickCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro"

const canonical = "https://homeplanninghub.com/calculators/brick/";
const title = "Brick Calculator";
const description = "Calculate how many bricks you need for a wall or structure. Get brick counts, mortar estimates, and waste factors for modular, standard, jumbo, and roman bricks.";
const formula = "Bricks = Wall Area (sq ft) × Bricks per sq ft";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Brick Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How many bricks per square foot?",
      a: "With standard modular bricks (2.25\" × 7.625\") and 3/8\" mortar joints, you need about 6.9 bricks per sq ft.",
    },
    {
      q: "How many bricks for a 10x10 wall?",
      a: "A 10×10 ft wall (100 sq ft) needs about 690 modular bricks plus 10% waste = 760 bricks.",
    },
    {
      q: "What mortar mix for brick walls?",
      a: "Type N mortar (1:1:6 ratio of cement:lime:sand) is standard for most brick walls. Type S for below-grade applications.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Brick Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Brick Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate how many bricks you need for a wall or structure. Get brick counts, mortar estimates, and waste factors for modular, standard, jumbo, and roman bricks.</p>
    <AdSlot slotId="ad-top-leaderboard" />
    <section><BrickCalc client:visible /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Modular brick: 2.25\" × 7.625\" with 3/8\" mortar joint.",
        "Standard brick: 2.25\" × 8\" with 3/8\" mortar joint.",
        "Add 10% for breakage and cuts."
      ]}
    />
    <AdSlot slotId="ad-in-content-mid" />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many bricks per square foot?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">With standard modular bricks (2.25" × 7.625") and 3/8" mortar joints, you need about 6.9 bricks per sq ft.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many bricks for a 10x10 wall?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 10×10 ft wall (100 sq ft) needs about 690 modular bricks plus 10% waste = 760 bricks.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What mortar mix for brick walls?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Type N mortar (1:1:6 ratio of cement:lime:sand) is standard for most brick walls. Type S for below-grade applications.</p></details>
      </div>
    </section>
    <RelatedCalculators slug="brick" />
  </article>
</Layout>
