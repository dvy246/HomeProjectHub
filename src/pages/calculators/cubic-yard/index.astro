---
import Layout from "../../../layouts/Layout.astro"
import CubicYardCalc from "../../../components/calculators/CubicYardCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/cubic-yard/";
const title = "Cubic Yard Calculator";
const description = "Calculate cubic yards for any project. Enter length, width, and depth.";
const formula = "Cubic Yards = (Length (ft) x Width (ft) x Depth (in)) / 324";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Construction Converters", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How many cubic yards is 1000 sq ft at 4 inches?", a: "(1000 x 4) / 324 = 12.35 cubic yards. Always order 10% extra for compaction and waste." },
    { q: "How many cubic feet in a cubic yard?", a: "27 cubic feet = 1 cubic yard. A cubic yard is 3 ft x 3 ft x 3 ft." },
    { q: "How much does a cubic yard of dirt weigh?", a: "Topsoil weighs about 1.1 tons per cubic yard. Fill dirt is 1.2-1.4 tons. Sand is 1.2-1.4 tons." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Cubic Yard Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Cubic Yard Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate cubic yards for any project. Enter length, width, and depth.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><CubicYardCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Formula: (Length (ft) x Width (ft) x Depth (in)) / 324.", "Add 10-15% waste for compaction and irregular shapes.", "Result rounded to 2 decimal places."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many cubic yards is 1000 sq ft at 4 inches?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">(1000 x 4) / 324 = 12.35 cubic yards. Always order 10% extra for compaction and waste.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many cubic feet in a cubic yard?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">27 cubic feet = 1 cubic yard. A cubic yard is 3 ft x 3 ft x 3 ft.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does a cubic yard of dirt weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Topsoil weighs about 1.1 tons per cubic yard. Fill dirt is 1.2-1.4 tons. Sand is 1.2-1.4 tons.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/sq-ft-to-cu-yd/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Sq Ft to Cu Yd</span></a>
    <a href="/calculators/square-footage/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Square Footage</span></a>
    <a href="/calculators/sand/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Sand</span></a>
  </div></footer>
</article>
</Layout>
