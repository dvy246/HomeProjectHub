---
import Layout from "../../../layouts/Layout.astro"
import SealantCalc from "../../../components/calculators/SealantCalc"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/sealant/";
const title = "Sealant Calculator";
const description = "Calculate how many tubes of caulk or sealant you need for construction joints. Enter joint dimensions and tube size for accurate material estimates.";
const formula = "Tubes = (Joint Length × Cross Section Area) / Tube Volume";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Sealant Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How many tubes of caulk for 100 ft?",
      a: "For a 1/2\"×1/2\" joint, 100 ft needs about 5 tubes of 10 oz sealant (100 × 0.25 cu in/tube).",
    },
    {
      q: "What size sealant joint do I need?",
      a: "Width = 2× expected movement (minimum 1/4\"). Depth = width (up to 1/2\"). For wider joints, use a backer rod.",
    },
    {
      q: "What sealant for concrete joints?",
      a: "Use self-leveling polyurethane for horizontal joints, non-sag polyurethane for vertical joints. Silicone for non-porous surfaces.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Sealant Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Sealant Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate how many tubes of caulk or sealant you need for construction joints. Enter joint dimensions and tube size for accurate material estimates.</p>
    <section><SealantCalc client:visible /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Standard tube size: 10 oz (295 ml).",
        "Joint width should be 2× the expected movement.",
        "Joint depth typically = width for sealant joints."
      ]}
    />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many tubes of caulk for 100 ft?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">For a 1/2"×1/2" joint, 100 ft needs about 5 tubes of 10 oz sealant (100 × 0.25 cu in/tube).</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What size sealant joint do I need?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Width = 2× expected movement (minimum 1/4"). Depth = width (up to 1/2"). For wider joints, use a backer rod.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What sealant for concrete joints?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Use self-leveling polyurethane for horizontal joints, non-sag polyurethane for vertical joints. Silicone for non-porous surfaces.</p></details>
      </div>
    </section>
    <footer class="pt-8 mt-6 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/calculators/concrete/slab/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Concrete Slab</span></a>
      <a href="/calculators/framing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Framing</span></a>
      </div>
    </footer>
  </article>
</Layout>
