---
import Layout from "../../../layouts/Layout.astro"
import WeightCalc from "../../../components/calculators/WeightCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/glass-weight/";
const title = "Glass Weight Calculator";
const description = "Calculate glass weight for annealed, tempered, and laminated glass.";
const formula = "Weight = Volume x Glass Density";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Weight", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How much does a square foot of 1/4 glass weigh?", a: "Standard 1/4\" glass weighs about 3.28 lbs per sq ft. For a 4x8 sheet: 12.8 sq ft x 3.28 = 42 lbs." },
    { q: "Is tempered glass heavier than annealed?", a: "Tempered and annealed glass have the same density (0.09 lb/cu in). Tempered glass is heat-treated for strength but the weight is identical." },
    { q: "What is the weight of laminated glass?", a: "Laminated glass is slightly heavier due to the PVB interlayer — add about 0.5 lbs per sq ft for standard 0.030\" PVB film." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Glass Weight Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Glass Weight Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate glass weight for annealed, tempered, and laminated glass.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><WeightCalc client:visible materials={[{ id: "glass_annealed", label: "Annealed Glass (0.09 lb/cu in)" }, { id: "glass_tempered", label: "Tempered Glass (0.09 lb/cu in)" }, { id: "glass_laminated", label: "Laminated Glass (0.092 lb/cu in)" }]} defaultMaterial="glass_annealed" /></section>
  <EstimateMethodology formula={formula} assumptions={["Glass density: ~0.09 lb/cu in (160 lb/cu ft).", "Laminated glass weight includes PVB interlayer.", "Weight calculated for flat glass panels only.", "Curved or drilled glass may vary in actual weight."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does a square foot of 1/4 glass weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Standard 1/4" glass weighs about 3.28 lbs per sq ft. For a 4x8 sheet: 12.8 sq ft x 3.28 = 42 lbs.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Is tempered glass heavier than annealed?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Tempered and annealed glass have the same density (0.09 lb/cu in). Tempered glass is heat-treated for strength but the weight is identical.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the weight of laminated glass?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Laminated glass is slightly heavier due to the PVB interlayer — add about 0.5 lbs per sq ft for standard 0.030" PVB film.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/aluminum-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Aluminum Weight</span></a>
    <a href="/calculators/metal-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Metal Weight</span></a>
    <a href="/calculators/stone-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Stone Weight</span></a>
  </div></footer>
</article>
</Layout>
