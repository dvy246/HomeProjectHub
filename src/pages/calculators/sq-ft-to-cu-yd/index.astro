---
import Layout from "../../../layouts/Layout.astro"
import SqFtToCuYdCalc from "../../../components/calculators/SqFtToCuYdCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/sq-ft-to-cu-yd/";
const title = "Square Feet to Cubic Yards Calculator";
const description = "Convert square footage to cubic yards at any depth.";
const formula = "Cubic Yards = (Square Feet x Depth (in)) / 324";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Construction Converters", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How many cubic yards is 500 sq ft at 4 inches?", a: "(500 x 4) / 324 = 6.17 cubic yards. Order 6.8 yards with 10% waste for compaction." },
    { q: "What is the formula to convert sq ft to cu yd?", a: "Multiply area (sq ft) by depth in inches, divide by 324. This converts to cubic yards directly." },
    { q: "How deep is 1 cubic yard spread over 100 sq ft?", a: "1 cubic yard = 27 cubic ft. Spread over 100 sq ft: 27/100 = 0.27 ft = 3.24 inches deep." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Square Feet to Cubic Yards Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Square Feet to Cubic Yards Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Convert square footage to cubic yards at any depth.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><SqFtToCuYdCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Formula: (sq ft x depth in inches) / 324 = cubic yards.", "Add 10-15% waste for compaction and irregular shapes.", "Result rounded to 2 decimal places for accuracy."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many cubic yards is 500 sq ft at 4 inches?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">(500 x 4) / 324 = 6.17 cubic yards. Order 6.8 yards with 10% waste for compaction.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the formula to convert sq ft to cu yd?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Multiply area (sq ft) by depth in inches, divide by 324. This converts to cubic yards directly.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How deep is 1 cubic yard spread over 100 sq ft?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">1 cubic yard = 27 cubic ft. Spread over 100 sq ft: 27/100 = 0.27 ft = 3.24 inches deep.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/cubic-yard/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Cubic Yard</span></a>
    <a href="/calculators/square-footage/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Square Footage</span></a>
    <a href="/calculators/square-yards/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Square Yards</span></a>
  </div></footer>
</article>
</Layout>
