---
import Layout from "../../../../layouts/Layout.astro";
import StairStringerDesigner from "../../../../components/calculators/StairStringerDesigner";
import EstimateMethodology from "../../../../components/EstimateMethodology.astro";
import RelatedCalculators from "../../../../components/ui/RelatedCalculators.astro";
import { graphSchema, mathSolverSchema, faqPageSchema, breadcrumbListSchema, webApplicationSchema, howToSchema } from "../../../../lib/schema";

export async function getStaticPaths() {
  const structures = [
    "deck-stairs",
    "basement-stairs",
    "porch-stairs",
    "attic-stairs",
    "loft-stairs",
    "shed-stairs",
    "garage-stairs",
    "dock-stairs",
    "cabin-stairs",
    "playhouse-stairs",
    "pool-deck-stairs",
    "bunk-bed-stairs"
  ];

  const paths = [];
  for (const structure of structures) {
    // Generate heights from 12 to 120 inches in 1-inch increments
    for (let h = 12; h <= 120; h++) {
      paths.push({
        params: {
          structure,
          height: h.toString()
        }
      });
    }
  }
  return paths;
}

const { structure, height } = Astro.params;

// Helper to format structure slug to human-readable label
const getStructureLabel = (slug: string) => {
  return slug
    .split("-")
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
};

const structureLabel = getStructureLabel(structure || "");
const canonical = `https://homeplanninghub.com/calculators/stair-stringer-designer/${structure}/${height}-inch-rise/`;
const title = `${height}" Rise ${structureLabel} Riser & Run Calculator | Stair Planner`;
const description = `Plan and layout your DIY ${structureLabel} with a total vertical rise height of ${height} inches. View scaled 2x12 lumber cutting blueprints andComfort configurations.`;

const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Calculators", path: "/calculators/" },
    { name: "Stair Stringer Designer", path: "/calculators/stair-stringer-designer/" },
    { name: `${height}" Rise ${structureLabel}`, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: `Comfort Stair Spacing Equation for ${height}" Rise`,
    description: `Determinecomfort step count and unit riser height for a ${height} inch total stair rise.`,
    formula: `Riser Height = ${height} / Stair Count; Comfort Coefficient = 2 * Riser Height + Tread Run`,
    url: canonical,
  }),
  howToSchema(title, description, [
    { name: "Measure total rise", text: `Verify that your total vertical height from the floor to landing is exactly ${height} inches.` },
    { name: "Determine step count", text: `Divide ${height} by 7.5 to get the optimal comfort step count.` },
    { name: "Cut bottom riser", text: "Subtract tread thickness from the bottom riser cut on your stringer board." },
    { name: "Place framing square", text: "Align framing square markings along the 2x12 lumber to cut the stair notches." },
  ]),
  faqPageSchema([
    {
      q: `How many steps do I need for a ${height}-inch vertical rise?`,
      a: `For a ${height}-inch total rise, you will need approximately ${Math.round(parseFloat(height || "0") / 7.5)} steps to maintain a comfortable riser height between 7 and 7.75 inches.`
    },
    {
      q: `What is the individual step riser height for a ${height}-inch stair rise?`,
      a: `Dividing ${height} inches by the optimal step count of ${Math.round(parseFloat(height || "0") / 7.5)} gives an individual step riser height of ${(parseFloat(height || "0") / Math.round(parseFloat(height || "0") / 7.5)).toFixed(2)} inches.`
    },
    {
      q: "Should I use 2x12 pressure-treated lumber for outdoor stair stringers?",
      a: "Yes. Outdoor stair stringers (such as deck or dock stairs) must use ground-contact pressure-treated 2x12 lumber to resist rot and fungal decay."
    },
    {
      q: "Can I cut stair stringers out of a 2x10 board?",
      a: "No. After cutting the steps out of a 2x10, the remaining solid throat width is too narrow and will not safely support the load. Always use 2x12 lumber."
    },
    {
      q: "Why does the bottom riser need to be cut shorter than the others?",
      a: "Because the bottom step rests on the floor, adding a tread board on top would make it taller than all the other steps. Cutting the bottom riser shorter by the thickness of the tread keeps all riser heights uniform."
    },
    {
      q: `What is the stair incline angle for a ${height}-inch rise?`,
      a: `For a ${height}-inch rise, the incline angle depends on the tread run. With a standard 10.5-inch run, the stair incline angle is approximately ${(Math.atan2(parseFloat(height || "0") / Math.round(parseFloat(height || "0") / 7.5), 10.5) * (180 / Math.PI)).toFixed(1)} degrees.`
    },
    {
      q: "Are open risers permitted by building codes?",
      a: "Under the IRC, open risers are permitted provided they do not allow the passage of a 4-inch diameter sphere (to prevent child falls). Many builders install solid riser boards for compliance and strength."
    },
    {
      q: "What is the minimum headroom clearance for stairways?",
      a: "The IRC requires a minimum headroom clearance of 6 feet 8 inches (80 inches) measured vertically from the leading edge of the stair tread to the ceiling above."
    }
  ], canonical)
);
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6 no-print" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/calculators/stair-stringer-designer/" class="hover:text-[var(--fg)] transition-colors">Stair Stringer Designer</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)] font-medium">{height}&quot; Rise {structureLabel}</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        {height}&quot; Rise {structureLabel} Riser &amp; Run Calculator
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Design and layout a custom set of {structureLabel} for a total vertical rise height of exactly {height} inches. This interactive planner calculates step Comfort riser heights, wood tread drops, and provides a dimensioned cutting blueprint.
      </p>
    </header>

    <!-- Top Ad Slot -->

    <!-- Interactive React Component prefilled with height param -->
    <section>
      <StairStringerDesigner client:visible initialRise={height} initialStructure={structure} />
    </section>

    <!-- Estimate Methodology -->
    <EstimateMethodology
      formula={`Riser Height = ${height} / Stair Count; Comfort Score = 2 * Riser Height + Tread Run; Stringer Length = Sqrt(${height}^2 + Run^2)`}
      assumptions={[
        `Designed specifically for ${structureLabel} construction spanning a vertical elevation change of ${height} inches.`,
        "Bottom riser cut height is adjusted to maintain uniform step rise heights after treads are placed.",
        "Calculations assume standard 2x12 lumber is used for layout and cutting.",
        "All layout estimates are subject to our engineering disclaimer. Read the full disclaimer at /disclaimer/."
      ]}
    />

    <!-- Informative Article Content -->
    <section class="prose max-w-none text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed flex flex-col gap-6 border-t border-[var(--border)] pt-8">
      <div>
        <h2 class="text-lg sm:text-xl font-bold text-[var(--fg)] mb-3">Carpentry Layout for {height}-Inch Stairways</h2>
        <p class="text-pretty mb-4">
          When constructing {structureLabel} to span a vertical rise height of {height} inches, the layout must be carefully calibrated to ensure comfortable climbing. The optimal comfort slope angle is achieved when each individual step rise is around 7.5 inches, coupled with a 10.5-inch tread run.
        </p>
        <h3 class="text-base font-semibold text-[var(--fg)] mb-2">Calculating Optimal Step Count</h3>
        <p class="text-pretty mb-4">
          To find the best step count for a {height}-inch rise:
        </p>
        <ul class="list-disc pl-5 flex flex-col gap-2 mb-4">
          <li>
            Target 7.5 inches per riser: ${height} / 7.5 = {(parseFloat(height || "0") / 7.5).toFixed(2)} steps.
          </li>
          <li>
            Round to the nearest whole step count: <strong>{Math.round(parseFloat(height || "0") / 7.5)} steps</strong>.
          </li>
          <li>
            Calculate exact riser spacing: ${height} / {Math.round(parseFloat(height || "0") / 7.5)} = <strong>{(parseFloat(height || "0") / Math.round(parseFloat(height || "0") / 7.5)).toFixed(2)} inches</strong>.
          </li>
        </ul>
      </div>

      <div class="border-t border-[var(--border)] pt-6 no-print">
        <h2 class="text-lg sm:text-xl font-bold text-[var(--fg)] mb-4">Frequently Asked Questions</h2>
        <div class="flex flex-col gap-4">
          <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
            <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
              <span>How many steps do I need for a {height}-inch rise?</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
              For a {height}-inch total rise, you will need approximately {Math.round(parseFloat(height || "0") / 7.5)} steps to maintain a comfortable riser height between 7 and 7.75 inches.
            </p>
          </details>

          <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
            <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
              <span>What is the individual step riser height for a {height}-inch rise?</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
              Dividing {height} inches by the optimal step count of {Math.round(parseFloat(height || "0") / 7.5)} gives an individual step riser height of {(parseFloat(height || "0") / Math.round(parseFloat(height || "0") / 7.5)).toFixed(2)} inches.
            </p>
          </details>

          <details class="group border border-[var(--border)] rounded-xl p-3.5 bg-[var(--bg-subtle)] cursor-pointer">
            <summary class="flex justify-between items-center text-xs sm:text-sm font-semibold text-[var(--fg)] list-none">
              <span>Why must the bottom rise be shorter than the others?</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="text-xs sm:text-sm text-[var(--fg-secondary)] leading-relaxed mt-2.5 text-pretty">
              Because the bottom step rests on the floor, adding a tread board on top would make it taller than all the other steps. Cutting the bottom riser shorter by the thickness of the tread keeps all riser heights uniform.
            </p>
          </details>
        </div>
      </div>
    </section>

    <!-- Related Planners Routing -->
    <RelatedCalculators slug="stair-stringer-designer" />
  </article>
</Layout>
