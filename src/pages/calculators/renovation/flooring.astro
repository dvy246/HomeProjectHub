---
import Layout from "../../../layouts/Layout.astro";
import FlooringCostCalc from "../../../components/calculators/renovation/FlooringCostCalc";
import { graphSchema, webPageSchema, faqPageSchema, webApplicationSchema, mathSolverSchema, howToSchema, breadcrumbListSchema } from "../../../lib/schema";

const title = "Flooring Cost Calculator";
const description = "Free flooring cost calculator. Estimate hardwood, luxury vinyl plank LVP, tile, and carpet materials, underlayment rolls, and contractor labor.";
const canonical = "https://homeplanninghub.com/calculators/renovation/flooring/";

// SEO FAQ Structured Data
const faqItems = [
  {
    q: "How much does it cost to install flooring per square foot?",
    a: "On average, flooring installation costs between $5 and $15 per square foot. DIY laminate or LVP costs $2 to $4 per square foot in materials, while premium solid hardwood or porcelain tile installed by contractors ranges from $8 to $22+ per square foot."
  },
  {
    q: "Do I need underlayment padding under vinyl flooring?",
    a: "Yes. Underlayment padding provides sound dampening, adds thermal comfort, acts as a vapor barrier on concrete subgrades, and covers minor subfloor height imperfections to prevent plank shifts."
  },
  {
    q: "What is a standard waste margin for flooring boards?",
    a: "A 10% safety waste factor is recommended. For rooms with diagonal tile runs, narrow stair treads, or odd bay windows, purchase a 15% safety waste margin to cover trim cuts."
  },
  {
    q: "What is LVP flooring?",
    a: "LVP stands for Luxury Vinyl Plank flooring. It is a highly durable, multi-layered synthetic flooring product designed to mimic the texture, color, and grain of natural solid wood planks. It typically consists of a waterproof vinyl core, a high-resolution decorative print layer, and a clear protective wear layer that resists scratches, dents, and stains. Many LVP options also feature a pre-attached foam or cork underlayment pad. Use our Flooring Cost Calculator to estimate LVP boards, vapor barrier pads, and contractor installation labor fees for your next remodel."
  }
];

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Calculators", path: "/calculators/" },
    { name: "Renovation", path: "/calculators/renovation/" },
    { name: "Flooring Cost", path: "/calculators/renovation/flooring/" },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: "Flooring Cost Estimator Formula",
    description,
    formula: "Total Flooring Cost = Board/Plank Cost + Underlayment Cost + Subfloor OSB Cost + Labor Cost + Contingency Buffer",
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure room dimensions",
      text: "Determine length and width of the room in feet to calculate overall square footage.",
    },
    {
      name: "Select material and underlayment options",
      text: "Choose wood, laminate, LVP, tile, or carpet styles, underlayment rolls, and waste buffers.",
    },
    {
      name: "Apply installation labor and regional multipliers",
      text: "Choose professional installation labor surcharges, regional cost offsets, and contingency buffers.",
    },
  ]),
  faqPageSchema(faqItems)
);
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-8 max-w-3xl">
      <nav class="flex items-center gap-2 text-xs text-[var(--fg-muted)] mb-3" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">Home</a>
        <span>&bull;</span>
        <a href="/calculators/" class="hover:underline">Calculators</a>
        <span>&bull;</span>
        <a href="/calculators/renovation/" class="hover:underline">Renovation</a>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-[var(--fg)] mb-3">{title}</h1>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed">
        Remodeling or building new room floors? Input your room dimensions below to instantly estimate premium solid hardwood, luxury vinyl plank LVP, ceramic tiles, underlayment padding, subfloor sheeting, and builder labor rates.
      </p>
    </header>

    <main id="main-content" class="mb-12">
      <FlooringCostCalc client:visible />
    </main>

    {/* SEO Rich Editorial Guide Content */}
    <section class="max-w-3xl border-t border-[var(--border)] pt-10 mt-10">
      <h2 class="text-2xl font-bold tracking-tight mb-4">How to Calculate and Plan Flooring Costs</h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4">
        Upgrading your finished floorboards is one of the quickest ways to elevate a home. Successful planning requires calculating subfloor requirements and material waste margins.
      </p>

      <h3 class="text-lg font-semibold mb-3">1. Subfloor Stability & Plywood OSB</h3>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4">
        Finished floorboards are only as good as the subfloor underneath. If your floors squeak or sag, inspect the subfloor for moisture rot or loose panels. Replacing squeaky subfloor OSB panels (usually 3/4-inch sheets) adds structural strength and prevents tile grout lines from cracking.
      </p>

      <h3 class="text-lg font-semibold mb-3">2. Underlayments & Concrete Vapor Barriers</h3>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4">
        When laying laminate, engineered wood, or vinyl flooring on subgrade concrete (like basement slabs), a vapor barrier membrane is critical. It prevents rising dampness from swelling wood boards or breaking adhesive bonds.
      </p>

      <h3 class="text-lg font-semibold mb-3">3. Acclimation and expansion joints</h3>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4">
        Wood and laminate floorboards must acclimate to the home's relative humidity for 48 to 72 hours before installation. During installation, leave a 1/4-inch expansion gap along the walls. Cover this gap using shoe moldings or baseboards to allow the floor to expand and contract naturally without buckling.
      </p>
    </section>

    <section class="max-w-3xl border-t border-[var(--border)] pt-10 mt-10">
      <h2 class="text-xl font-bold tracking-tight mb-6">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        {faqItems.map((faq) => (
          <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
            <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">{faq.q}</h3></summary>
            <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>
  </div>
</Layout>
