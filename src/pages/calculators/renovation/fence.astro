---
import Layout from "../../../layouts/Layout.astro";
import FenceCostCalc from "../../../components/calculators/renovation/FenceCostCalc";
import { graphSchema, webPageSchema, faqPageSchema } from "../../../lib/schema";

const title = "Fence Cost Calculator — Materials & Labor";
const description = "Free fence cost calculator. Estimate wood, vinyl, or metal line posts, pickets, rails, concrete bags, gates, and builder installation labor.";
const canonical = "https://homeplanninghub.com/calculators/renovation/fence/";

// SEO FAQ Structured Data
const faqItems = [
  {
    q: "How much does it cost to build a fence per linear foot?",
    a: "On average, building a residential fence costs between $20 and $45 per linear foot. DIY wood privacy fences start around $12 to $18 per linear foot in materials, while premium vinyl or metal fencing installed by contractors ranges from $35 to $75+ per linear foot."
  },
  {
    q: "How deep should fence posts be set in concrete?",
    a: "As a general rule, fence posts should be buried in the ground to a depth equal to 1/3 to 1/2 of the height of the fence above ground (minimum 2 feet deep, or below the local winter frost line to prevent shifting)."
  },
  {
    q: "What is the standard spacing for fence posts?",
    a: "The standard spacing for residential fence posts is 6 feet or 8 feet. Spacing posts closer (e.g. 6 feet OC) increases structural wind-load durability but requires buying more lumber posts and concrete footing bags."
  }
];

const schema = graphSchema([
  webPageSchema({
    url: canonical,
    topicName: title,
    description,
  }),
  faqPageSchema(faqItems)
]);
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-8 max-w-3xl">
      <nav class="flex items-center gap-2 text-xs text-[var(--fg-muted)] mb-3" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">Home</a>
        <span>&bull;</span>
        <a href="/calculators/" class="hover:underline">Calculators</a>
        <span>&bull;</span>
        <a href="/calculators/renovation/" class="hover:underline">Renovation</a>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-[var(--fg)] mb-3">{title}</h1>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed">
        Building a new privacy or perimeter fence? Input your line length, post spacing, gates, and material unit costs below to instantly calculate post footings, rails, pickets, concrete bag counts, and contractor labor rates.
      </p>
    </header>

    <main id="main-content" class="mb-12">
      <FenceCostCalc client:load />
    </main>

    {/* SEO Rich Editorial Guide Content */}
    <section class="max-w-3xl border-t border-[var(--border)] pt-10 mt-10">
      <h2 class="text-2xl font-bold tracking-tight mb-4">Step-by-Step Fence Material & Budget Estimation</h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4">
        A new privacy fence outlines property boundaries and secures pets, but estimating posts and picket panels requires matching your layout to structural wind-load parameters.
      </p>

      <h3 class="text-lg font-semibold mb-3">1. Calculating Fence Post Count</h3>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4">
        To estimate your total line posts, divide the total fence length by the desired post spacing, round up, and add one post for the terminating end:
      </p>
      <div class="bg-[var(--bg-subtle)] px-4 py-3 rounded-lg border border-[var(--border)] font-mono text-xs mb-4">
        Posts = ceil(Length / Spacing) + 1
      </div>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4">
        Remember to buy extra posts if your fence has multiple corners or gates, as each gate requires two heavy hinge posts.
      </p>

      <h3 class="text-lg font-semibold mb-3">2. Horizontal Rails & Vertical Pickets</h3>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4">
        A standard 6-foot tall privacy fence requires three horizontal rail lines (typically 2x4 lumber) running between posts to prevent the pickets from bowing. Pickets are typically 5.5 inches wide, which means you need approximately 2.2 pickets per linear foot, assuming no gaps.
      </p>

      <h3 class="text-lg font-semibold mb-3">3. Concrete Post Footing Requirements</h3>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4">
        To prevent posts from tilting under heavy wind loads, each post hole should be dug to at least 10 inches in diameter for a 4x4 post. Fill each hole with 2 bags of pre-mixed 80lb concrete concrete, sloping the top above ground level to shed rainwater away from the wood.
      </p>
    </section>
  </div>
</Layout>
