---
import Layout from "../../../layouts/Layout.astro";
import FlooringCalc from "../../../components/calculators/FlooringCalc";
import AdSlot from "../../../components/AdSlot.astro";
import EstimateMethodology from "../../../components/EstimateMethodology.astro";
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro";
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema";

const canonical = "https://homeplanninghub.com/calculators/flooring/";
const title = "Flooring Calculator — Estimate Planks, Boxes, Rolls & Costs";
const description = "Free flooring calculator. Calculate solid hardwood boards, luxury vinyl plank LVP boxes, laminate planks, carpet, underlayment rolls, and project weights.";
const formula = "Planks: Boxes = ceil([Area * (1 + waste%)] / BoxCoverage); Rolls: Linear Yards = ceil([Runs * Length * (1 + waste%)] / 3)";

const faqItems = [
  {
    q: "How many boxes of flooring do I need?",
    a: "To calculate flooring boxes, multiply the room length by the width to get the square footage. Add a 10% waste factor, then divide this total by the square footage covered in one retail box of your chosen product and round up to the nearest whole box.",
  },
  {
    q: "How much extra flooring should I buy for waste?",
    a: "A 10% safety waste factor is recommended for standard rectangular rooms. For rooms with diagonal placements, complex cuts around pillars, fireplace hearths, or herringbone patterns, purchase a 15% to 20% waste margin to prevent running short.",
  },
  {
    q: "What is LVP flooring and is underlayment required?",
    a: "LVP stands for Luxury Vinyl Plank flooring. It is a highly durable, waterproof synthetic plank designed to look like wood. Most LVP products feature a pre-attached underlayment pad. If your LVP does not have a pad, or if you are installing over a subgrade concrete floor, you must purchase a separate underlayment vapor barrier roll.",
  },
  {
    q: "How to calculate flooring linear yards for carpet?",
    a: "Carpet rolls are typically sold in standard 12-foot widths. Determine the number of 12-foot wide runs needed to cover the width of your room, multiply by the room length, add your waste cushion, and divide by 3 to convert from linear feet to linear yards.",
  }
];

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Calculators", path: "/calculators/" },
    { name: "Flooring Calculator", path: "/calculators/flooring/" },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: "Flooring Quantity Material Formulas",
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure room dimensions",
      text: "Determine length and width of the room using a tape measure. Convert to consistent feet or meters.",
    },
    {
      name: "Select flooring material and box sizes",
      text: "Select plank styles (LVP, hardwood, laminate) or roll styles (carpet, sheet vinyl) and check box coverages.",
    },
    {
      name: "Specify waste buffers and calculate",
      text: "Add a 10% waste buffer (15% for odd angles) and compute total boxes, linear yards, and shipping weight.",
    },
  ]),
  faqPageSchema(faqItems, canonical)
);
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/calculators/" class="hover:underline">calculators</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)]">flooring</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">{title}</h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Estimate how many flooring boxes or rolls you need for home renovations. Supports Solid Hardwood, LVP, Laminate, Engineered Wood, Carpet, and Vinyl Sheet. Include local unit prices, contractor installation labor, and contingency costs.
      </p>
    </header>

    <AdSlot slotId="ad-top-flooring" />

    <section>
      <FlooringCalc client:visible />
    </section>

    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Standard hardwood, engineered wood, laminate, and LVP box yields vary. Always check product packaging for exact coverage.",
        "Underlayment rolls assume 100 square feet per roll coverage.",
        "Carpet and vinyl sheet calculations assume a standard roll width of 12 feet.",
        "Carpet padding rolls assume a standard coverage of 30 square yards (270 square feet)."
      ]}
    />

    <section>
      <h2 id="how-to-calculate" class="text-xl font-bold tracking-tight mb-4">How to Calculate Flooring Material Needs</h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Calculating flooring boxes or roll lengths is critical to avoid under-buying. Follow these standard formulas to get exact estimates.
      </p>
      <ol class="list-decimal pl-5 flex flex-col gap-3 text-sm text-[var(--fg-secondary)]">
        <li>
          <strong>Calculate base square footage:</strong> Multiply length by width of each rectangular space. Sum them for irregular areas.
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Area (sq ft) = Length (ft) &times; Width (ft)
          </div>
        </li>
        <li>
          <strong>Apply safety waste factor:</strong> Add 10% for layout cuts and board defects:
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Target Sq Ft = Area &times; 1.10
          </div>
        </li>
        <li>
          <strong>Convert to boxes (Planks):</strong> Divide the waste-adjusted square footage by the box coverage (e.g. 24 sq ft per box for LVP) and round up.
        </li>
        <li>
          <strong>Compute rolls (Carpet):</strong> Carpet is cut from 12-foot wide rolls. Determine runs across the room width and multiply by room length to get total roll yardage.
        </li>
      </ol>
    </section>

    <section>
      <h2 id="common-mistakes" class="text-xl font-bold tracking-tight mb-4">Common Flooring Estimation Mistakes</h2>
      <div class="flex flex-col gap-3">
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-1">Forgetting the subfloor inspection</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">New flooring requires a flat, sturdy subfloor. Installing LVP or hardwood over uneven concrete slabs or rotted plywood OSB subfloors will cause boards to separate and crack. Factor in underlayment or leveling compounds.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-1">Buying exactly to the floor square footage</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">You will always lose material during trimming and fitting boards around corners or entryways. Always order at least 10% extra, or 15% if doing a complex herringbone layout pattern.</p>
        </div>
      </div>
    </section>

    <section>
      <h2 id="faq" class="text-xl font-bold tracking-tight mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        {faqItems.map((faq) => (
          <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
            <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">{faq.q}</h3></summary>
            <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators slug="compare-flooring" />
  </article>
</Layout>
