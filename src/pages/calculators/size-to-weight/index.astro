---
import Layout from "../../../layouts/Layout.astro"
import SizeToWeightCalc from "../../../components/calculators/SizeToWeightCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/size-to-weight/";
const title = "Size to Weight Calculator";
const description = "Convert material dimensions to weight for any material.";
const formula = "Weight = Length x Width x Thickness x Density";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Construction Converters", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How do I convert size to weight?", a: "Multiply length x width x thickness in consistent units, then multiply by the material density. Use our calculator for quick results." },
    { q: "What materials can I calculate?", a: "Steel, aluminum, copper, brass, wood (multiple species), glass, concrete, and stone — all with built-in density values." },
    { q: "How accurate is size-to-weight conversion?", a: "Accuracy depends on material density values. Most engineering metals are within 1%. Natural materials like wood vary 10-15% by moisture content." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Size to Weight Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Size to Weight Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Convert material dimensions to weight for any material.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><SizeToWeightCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Material densities from standard engineering references.", "Weight is for solid rectangular plates only.", "Actual weight varies by alloy, moisture, and composition.", "Steel: 0.2836 lb/cu in, Aluminum: 0.0975, Wood: varies by species."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do I convert size to weight?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Multiply length x width x thickness in consistent units, then multiply by the material density. Use our calculator for quick results.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What materials can I calculate?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Steel, aluminum, copper, brass, wood (multiple species), glass, concrete, and stone — all with built-in density values.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How accurate is size-to-weight conversion?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Accuracy depends on material density values. Most engineering metals are within 1%. Natural materials like wood vary 10-15% by moisture content.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/board-foot/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Board Foot</span></a>
    <a href="/calculators/metal-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Metal Weight</span></a>
    <a href="/calculators/log-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Log Weight</span></a>
  </div></footer>
</article>
</Layout>
