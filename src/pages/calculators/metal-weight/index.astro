---
import Layout from "../../../layouts/Layout.astro"
import WeightCalc from "../../../components/calculators/WeightCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/metal-weight/";
const title = "Metal Weight Calculator";
const description = "Calculate metal weight for steel, aluminum, brass, and copper.";
const formula = "Weight = Volume x Material Density";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Weight", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How much does steel weigh per cubic inch?", a: "Steel weighs 0.2836 lb per cubic inch (490 lb/cu ft). A 1\" x 1\" x 1\" cube of steel weighs 0.28 lbs." },
    { q: "Is brass heavier than steel?", a: "Brass at 0.315 lb/cu in is about 11% heavier than steel at 0.284 lb/cu in. Copper at 0.324 lb/cu in is even heavier." },
    { q: "How much does a cubic foot of copper weigh?", a: "Copper weighs 559 lb/cu ft (8.96 g/cm³). It's about 14% heavier than steel and more than 3x heavier than aluminum." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Metal Weight Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Metal Weight Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate metal weight for steel, aluminum, brass, and copper.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><WeightCalc client:visible materials={[{ id: "steel_a36", label: "Steel A36 (0.2836 lb/cu in)" }, { id: "aluminum_6061", label: "Aluminum 6061 (0.0975 lb/cu in)" }, { id: "brass", label: "Brass (0.315 lb/cu in)" }, { id: "copper", label: "Copper (0.324 lb/cu in)" }]} defaultMaterial="steel_a36" /></section>
  <EstimateMethodology formula={formula} assumptions={["Material densities from standard engineering references.", "Weight calculated for solid rectangular shapes only.", "Actual weight varies by alloy composition and temper.", "Steel A36: 0.2836 lb/cu in, Aluminum 6061: 0.0975, Brass: 0.315, Copper: 0.324."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does steel weigh per cubic inch?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Steel weighs 0.2836 lb per cubic inch (490 lb/cu ft). A 1" x 1" x 1" cube of steel weighs 0.28 lbs.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Is brass heavier than steel?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Brass at 0.315 lb/cu in is about 11% heavier than steel at 0.284 lb/cu in. Copper at 0.324 lb/cu in is even heavier.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does a cubic foot of copper weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Copper weighs 559 lb/cu ft (8.96 g/cm³). It's about 14% heavier than steel and more than 3x heavier than aluminum.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/aluminum-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Aluminum Weight</span></a>
    <a href="/calculators/steel-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Steel Weight</span></a>
    <a href="/calculators/pipe-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Pipe Weight</span></a>
  </div></footer>
</article>
</Layout>
