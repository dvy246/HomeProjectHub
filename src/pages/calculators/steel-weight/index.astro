---
import Layout from "../../../layouts/Layout.astro"
import WeightCalc from "../../../components/calculators/WeightCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/steel-weight/";
const title = "Steel Weight Calculator";
const description = "Calculate steel weight for A36, 1018, 4140, and stainless steels.";
const formula = "Weight = Volume x Density";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Weight", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How much does a cubic inch of steel weigh?", a: "Carbon steel (A36, 1018, 4140) weighs 0.2836 lb per cubic inch. Stainless steel is slightly heavier at 0.289-0.290 lb/cu in." },
    { q: "What is the weight of a 1 inch steel plate per sq ft?", a: "A 1\" thick A36 steel plate weighs 40.8 lbs per square foot. That's 0.2836 lb/cu in x 144 cu in = 40.8 lbs." },
    { q: "Is stainless steel heavier than carbon steel?", a: "Stainless steel is about 2% heavier — 0.289 vs 0.284 lb/cu in. The difference is due to chromium and nickel content." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Steel Weight Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Steel Weight Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate steel weight for A36, 1018, 4140, and stainless steels.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><WeightCalc client:visible materials={[{ id: "steel_a36", label: "Steel A36 (0.2836 lb/cu in)" }, { id: "steel_1018", label: "Steel 1018 (0.2836 lb/cu in)" }, { id: "steel_4140", label: "Steel 4140 (0.2836 lb/cu in)" }, { id: "steel_stainless_304", label: "Stainless 304 (0.289 lb/cu in)" }, { id: "steel_stainless_316", label: "Stainless 316 (0.290 lb/cu in)" }]} defaultMaterial="steel_a36" /></section>
  <EstimateMethodology formula={formula} assumptions={["Carbon steel density: 0.2836 lb/cu in (490 lb/cu ft).", "Stainless 304: 0.289 lb/cu in, Stainless 316: 0.290 lb/cu in.", "Weight calculated for solid rectangular shapes only.", "Actual weight varies slightly by specific alloy composition."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does a cubic inch of steel weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Carbon steel (A36, 1018, 4140) weighs 0.2836 lb per cubic inch. Stainless steel is slightly heavier at 0.289-0.290 lb/cu in.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the weight of a 1 inch steel plate per sq ft?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 1" thick A36 steel plate weighs 40.8 lbs per square foot. That's 0.2836 lb/cu in x 144 cu in = 40.8 lbs.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Is stainless steel heavier than carbon steel?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Stainless steel is about 2% heavier — 0.289 vs 0.284 lb/cu in. The difference is due to chromium and nickel content.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/metal-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Metal Weight</span></a>
    <a href="/calculators/aluminum-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Aluminum Weight</span></a>
    <a href="/calculators/pipe-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Pipe Weight</span></a>
  </div></footer>
</article>
</Layout>
