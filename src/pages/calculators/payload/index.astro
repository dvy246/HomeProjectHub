---
import Layout from "../../../layouts/Layout.astro";
import PayloadCalc from "../../../components/calculators/PayloadCalc";
import EstimateMethodology from "../../../components/EstimateMethodology.astro";
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro";
import { graphSchema, mathSolverSchema, faqPageSchema, breadcrumbListSchema } from "../../../lib/schema";

const canonical = "https://homeplanninghub.com/calculators/payload/";
const title = "Will It Fit? Vehicle Payload & Material Weight Safety Calculator";
const description = "Calculate if concrete bags, gravel, sand, drywall sheets, or lumber studs will fit in your pickup truck, SUV, or sedan. Estimate cargo weights, trips, and payload safety.";

const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Calculators", path: "/calculators/" },
    { name: "Payload Safety", path: PAGE_PATH },
  ]),
  mathSolverSchema({
    name: "Vehicle Payload Safety Equation",
    description: "Determine transport safety by comparing total material weight against manufacturer vehicle payload capacities.",
    formula: "Weight (lbs) = Quantity × Material Unit Weight; Safety Ratio = (Material Weight / Vehicle Payload Capacity) × 100",
    url: canonical,
  }),
  faqPageSchema([
    {
      q: "What is vehicle payload capacity?",
      a: "Payload capacity represents the maximum weight of passengers and cargo that can be safely loaded into a vehicle's bed, cabin, or roof rack. It is determined by the manufacturer and is listed on the tire and loading information sticker inside the driver-side door jamb.",
    },
    {
      q: "How many 80lb bags of concrete can fit in an F-150?",
      a: "An F-150 half-ton truck has a typical cargo payload capacity of 1,500 to 2,000 lbs depending on configuration. Therefore, it can safely carry 18 to 25 bags of 80lb concrete in the bed. Exceeding this limit bottom-outs suspension and compromises steering control.",
    },
    {
      q: "How much does a cubic yard of gravel weigh?",
      a: "A cubic yard of dry gravel weighs approximately 2,800 lbs. If wet, it can exceed 3,200 lbs. Since standard consumer half-ton pickups are rated for 1,500–2,000 lbs, carrying a full cubic yard of gravel will overload the vehicle; order delivery or use a dual-axle trailer instead.",
    },
    {
      q: "Can you fit drywall sheets in an SUV?",
      a: "Standard 4x8 drywall sheets weigh about 50 lbs each. While an SUV's payload capacity (typically 1,100 lbs) can carry up to 22 sheets, fitting their 4-foot by 8-foot dimensions inside the cabin is usually physically impossible without damaging the panels or vehicle trim. A utility trailer or pickup truck is recommended.",
    },
  ], canonical)
);
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6 no-print" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)] font-medium">Payload Safety</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        Will It Fit in My Truck? Payload Safety Calculator
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Avoid broken axles, blown tires, and safety hazards at the lumber yard. Select your vehicle class and input your required home improvement materials (bags of concrete, gravel yards, drywall sheets, studs, or bricks) to estimate total weight, calculate suspension compression, and check payload limits before driving.
      </p>
    </header>

    <!-- Top Ad Slot -->

    <!-- Interactive Calculator Component -->
    <section>
      <PayloadCalc client:visible />
    </section>

    <!-- Methodology Section -->
    <EstimateMethodology
      formula="Cargo Weight = Material Quantity × Item Unit Weight; Load Ratio = Cargo Weight ÷ Vehicle Payload Capacity"
      assumptions={[
        "Standard half-ton pickup payload: ~1,850 lbs (F-150, Silverado 1500).",
        "Dry concrete bag yields: 80lb bag = 80 lbs, 60lb bag = 60 lbs.",
        "Aggregate density parameters: Gravel = 2,800 lbs/cy, Sand = 2,700 lbs/cy.",
        "Drywall sheet dimensions & mass: standard 1/2-inch thickness = 1.6 lbs/sqft (50 lbs total).",
        "Lumber densities: standard kiln-dried Douglas Fir/SPF 2x4 = 1.5 lbs/ft (12 lbs per 8ft stud)."
      ]}
    />

    <!-- Contextual Information & FAQs -->
    <section class="border-t border-[var(--border)] pt-8 mt-4 flex flex-col gap-6">
      <div>
        <h2 id="safety-guidelines" class="text-lg font-bold tracking-tight mb-3 text-[var(--fg)]">
          Safety Guidelines for Hauling Construction Materials
        </h2>
        <p class="text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
          Hauling heavy building supplies in a passenger vehicle or standard pickup truck requires caution. Exceeding your vehicle's payload rating shifts the center of gravity, degrades stopping power, stresses the transmission, and is a major safety violation in most states. Follow these core procedures:
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-xs text-[var(--fg-secondary)] leading-relaxed">
        <div>
          <h3 class="font-semibold text-[var(--fg)] text-sm mb-1.5">1. Know Payload vs. Towing Capacity</h3>
          <p>
            Many drivers confuse towing capacity with payload capacity. <strong>Payload</strong> is the maximum weight you can put *inside* the truck cabin and cargo bed. <strong>Towing</strong> is the capacity of a trailed weight pulled behind. Tongue weight of a trailer (usually 10-15% of total trailer weight) directly subtracts from your available payload limit.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-[var(--fg)] text-sm mb-1.5">2. Secure & Tie Down Cargo</h3>
          <p>
            Loose materials can shift during sudden braking. Always block concrete bags together, secure drywall panels flat against the bed with ratchet straps, and flag overhanging framing lumber extending more than 4 feet beyond the tailgate with a red safety flag.
          </p>
        </div>
      </div>
    </section>

    <!-- Bottom Ad Slot -->
  </article>
</Layout>
