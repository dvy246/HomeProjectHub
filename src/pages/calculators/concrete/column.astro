---
import Layout from "../../../layouts/Layout.astro";
import ConcreteColumnCalc from "../../../components/calculators/ConcreteColumnCalc";
import AdSlot from "../../../components/AdSlot.astro";
import { graphSchema, mathSolverSchema, faqPageSchema, howToSchema, breadcrumbListSchema } from "../../../lib/schema";

const canonical = "https://homeplanninghub.com/calculators/concrete/column/";

const title = "Concrete Column Calculator";
const description = "Calculate concrete volume for round and square columns. Computes cubic yards, bag counts, and weight for any number of structural columns.";

const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");
const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Concrete Calculators", path: "/calculators/concrete/" },
    { name: title, path: PAGE_PATH },
  ]),
  mathSolverSchema({
    name: "Concrete Column Volume Calculator",
    description: "Calculates round and square column volume for concrete pours.",
    formula: "V = π × r² × h (round) or V = w² × h (square)",
    url: canonical,
  }),
  howToSchema(
    "Calculate Concrete for a Column",
    "Determine the volume of concrete needed for round or square structural columns.",
    [
      {
        name: "Choose the column shape",
        text: "Select round or square. For round columns, measure the diameter. For square, measure the side length.",
      },
      {
        name: "Measure height and calculate area",
        text: "For round: area = π × (diameter/2)². For square: area = side × side. All in feet.",
      },
      {
        name: "Multiply by height and quantity",
        text: "Volume = area × height (ft) × number of columns. Convert cubic feet to cubic yards by dividing by 27.",
      },
    ]
  ),
  faqPageSchema([
    {
      q: "How do you calculate concrete volume for a round column?",
      a: "Use the cylinder volume formula: V = π × r² × h. Convert the diameter to feet by dividing by 12, take half for the radius, square it, multiply by π, then multiply by the height in feet.",
    },
    {
      q: "How much concrete does a 12-inch round column need per foot?",
      a: "A 12-inch diameter round column has a cross-sectional area of 0.785 sq ft. For each foot of height, it needs 0.785 cu ft of concrete, or about 1.3 bags of 80lb mix.",
    },
    {
      q: "What is the standard size for concrete porch columns?",
      a: "Residential porch columns typically range from 10-12 inches diameter for round, or 12x12 inches for square. Load-bearing columns may need 14-16 inches depending on structural requirements.",
    },
    {
      q: "How many bags of concrete for a 12x12 square column?",
      a: "A 12x12 inch square column has a cross-section of 1 sq ft. For an 8-foot height, that's 8 cu ft. With an 80lb bag yielding 0.6 cu ft, you need about 14 bags per column.",
    },
  ], canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/calculators/concrete/" class="hover:underline">concrete</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)]">column</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">
        Concrete Column Calculator
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Calculate the exact volume of concrete needed for round or square structural columns. Enter your column dimensions and quantity to get cubic yards, bag counts across all standard sizes, and total estimated weight for delivery planning.
      </p>
    </header>

    <AdSlot slotId="ad-top-column" />


    <section>
      <ConcreteColumnCalc client:visible />
    </section>

    <section>
      <h2 id="how-to-calculate" class="text-xl font-bold tracking-tight mb-4">
        How to Calculate Concrete Column Volume
      </h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Columns are vertical structural members that transfer loads from the roof down to the foundation. They are typically either round (poured using cardboard tubes or forms) or square (poured using lumber forms).
      </p>

      <div class="flex flex-col gap-6">
        <div>
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-2">Round Columns (Cylinders)</h3>
          <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-2 text-pretty">
            Convert the diameter from inches to feet (divide by 12), then halve it for the radius. Use the cylinder volume formula:
          </p>
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Volume (cu ft) = &pi; &times; Radius&sup2; (ft) &times; Height (ft)
          </div>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-2">Square Columns</h3>
          <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-2 text-pretty">
            Convert the side length from inches to feet (divide by 12), then multiply all three dimensions:
          </p>
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Volume (cu ft) = Side (ft) &times; Side (ft) &times; Height (ft)
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2 id="example-calculation" class="text-xl font-bold tracking-tight mb-4">
        Example Column Calculation
      </h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Let's calculate the concrete needed for <strong>4 round porch columns</strong> that are <strong>12 inches in diameter and 8 feet tall</strong>:
      </p>
      <ul class="list-disc pl-5 flex flex-col gap-2 text-sm text-[var(--fg-secondary)]">
        <li><strong>Radius:</strong> 12 in &divide; 2 = 6 in = 0.5 ft</li>
        <li><strong>Cross-section Area:</strong> &pi; &times; 0.5&sup2; = 0.785 sq ft</li>
        <li><strong>Volume per Column:</strong> 0.785 sq ft &times; 8 ft = 6.28 cu ft</li>
        <li><strong>Total Volume (4 columns):</strong> 6.28 &times; 4 = 25.13 cu ft (~0.93 cubic yards)</li>
        <li><strong>Bags Needed (80lb):</strong> 25.13 &divide; 0.6 = 41.9 &rarr; <strong>42 bags</strong> (with 10% waste)</li>
      </ul>
    </section>

    <AdSlot slotId="ad-mid-column" />

    <section>
      <h2 id="common-mistakes" class="text-xl font-bold tracking-tight mb-4">
        Common Mistakes in Column Pours
      </h2>
      <ul class="list-disc pl-5 flex flex-col gap-3 text-sm text-[var(--fg-secondary)] text-pretty">
        <li>
          <strong>Underestimating Column Height:</strong> Columns often extend from the footing below grade to the beam above. Measure the full height including the below-grade portion, not just the visible section.
        </li>
        <li>
          <strong>Not Vibrating the Concrete:</strong> Tall, narrow column forms trap air bubbles against the form walls. Use a concrete vibrator or tap the forms with a hammer during the pour to release trapped air and prevent voids (honeycombing).
        </li>
        <li>
          <strong>Ignoring Rebar Volume:</strong> Vertical rebar inside the column displaces concrete. For columns with heavy rebar cages, reduce the calculated volume by 2-3% to account for steel displacement.
        </li>
      </ul>
    </section>

    <section>
      <h2 id="faq" class="text-xl font-bold tracking-tight mb-4">
        Frequently Asked Questions
      </h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do you calculate concrete volume for a round column?</h3></summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            For a round column, use the cylinder volume formula: V = pi x radius squared x height. Convert the diameter to feet by dividing by 12, then halve it for the radius. Square the radius, multiply by pi (3.14159), then multiply by the column height in feet to get cubic feet.
          </p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much concrete does a 12-inch round column need per foot of height?</h3></summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            A 12-inch diameter round column has a cross-sectional area of 0.785 square feet. For each foot of height, it requires 0.785 cubic feet of concrete, which equals approximately 1.3 bags of 80lb concrete mix.
          </p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the standard size for concrete porch columns?</h3></summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            Residential porch columns typically range from 10 to 12 inches in diameter for round columns, or 12x12 inches for square columns. Load-bearing columns may need to be 14-16 inches depending on the span and roof weight they support.
          </p>
        </details>
      </div>
    </section>

    <footer class="pt-8 mt-6 mb-6">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/calculators/concrete/slab/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Concrete Slab Calculator</span>
          <span class="text-[10px] text-[var(--fg-muted)]">Estimate concrete for flat pours and patios.</span>
        </a>
        <a href="/calculators/concrete/tube/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Concrete Tube Calculator</span>
          <span class="text-[10px] text-[var(--fg-muted)]">Calculate concrete for cardboard tube forms.</span>
        </a>
        <a href="/calculators/concrete/footing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Concrete Footing Calculator</span>
          <span class="text-[10px] text-[var(--fg-muted)]">Estimate concrete for post footings and piers.</span>
        </a>
      </div>
    </footer>
  </article>
</Layout>
