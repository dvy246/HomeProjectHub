---
import Layout from "../../../layouts/Layout.astro";
import ConcreteFootingCalc from "../../../components/calculators/ConcreteFootingCalc";
import AdSlot from "../../../components/AdSlot.astro";
import { graphSchema, mathSolverSchema, faqPageSchema, howToSchema } from "../../../lib/schema";

const canonical = "https://homeprojecthub.com/calculators/concrete/footing/";

const title = "Concrete Footing Calculator";
const description = "Calculate concrete requirements for post hole foundations, deck footings, or fence posts. Computes total volume in yards and bag counts for square and cylinder holes.";

const schema = graphSchema(
  mathSolverSchema({
    name: "Concrete Footing Volume Formula",
    description: "Calculate cylinder pier footing and square structural block footing volume.",
    formula: "Volume = Area × Depth",
    url: canonical,
  }),
  howToSchema(
    "Calculate Concrete for a Footing",
    "Determine the volume of concrete needed for deck footings or pier holes.",
    [
      {
        heading: "Determine the footing shape",
        text: "Identify whether your footing is cylindrical (round post hole) or rectangular (block footing).",
      },
      {
        heading: "Measure the dimensions",
        text: "For cylindrical: measure the diameter and depth. For rectangular: measure length, width, and depth.",
      },
      {
        heading: "Calculate volume per footing",
        text: "For cylinders: V = π × r² × depth. For rectangles: V = length × width × depth. Multiply by the number of footings.",
      },
    ]
  ),
  faqPageSchema([
    {
      q: "How deep should a concrete deck footing be?",
      a: "Footings must extend below your local frost line to prevent shifting during freeze-thaw cycles. In most northern regions, this means a minimum depth of 36 to 48 inches. Always consult local municipal building codes.",
    },
    {
      q: "What diameter hole do I need for a 4x4 post?",
      a: "The diameter of your post hole footing should be three times the width of the post. For a standard 4x4 post (3.5 inches actual), you need a minimum hole diameter of 10 to 12 inches.",
    },
  ], canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/calculators/concrete/" class="hover:underline">concrete</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)]">footing</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">
        Concrete Footing Calculator
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Determine the exact volume of concrete needed for structural post foundations, deck piers, and fence supports. Supporting both cylindrical pier holes and rectangular columns, this estimator lists total volume in cubic yards or meters, along with bag configurations adjusted for standard job site wastage.
      </p>
    </header>

    <!-- Top Ad Slot -->
    <AdSlot slotId="ad-top-leaderboard-footing" />

    <!-- Interactive Calculator -->
    <section>
      <ConcreteFootingCalc client:visible />
    </section>

    <!-- How to Calculate -->
    <section>
      <h2 id="how-to-calculate" class="text-xl font-bold tracking-tight mb-4">
        How to Calculate Concrete Footing Volume
      </h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Structural footings are usually cylindrical (for posts and decks) or square/rectangular (for wall footings and column foundations).
      </p>

      <div class="flex flex-col gap-6">
        <div>
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-2">
            1. Cylindrical Pier Holes (Circular Columns)
          </h3>
          <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-2 text-pretty">
            First, find the radius in feet (diameter in inches divided by 2, then divided by 12). Use the circle area formula, then multiply by depth:
          </p>
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Volume (cu ft) = &pi; &times; Radius&sup2; (ft) &times; Depth (ft)
          </div>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-2">
            2. Rectangular Block Footings
          </h3>
          <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-2 text-pretty">
            Convert length, width, and depth to feet (divide inches by 12) and multiply them together:
          </p>
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Volume (cu ft) = Length (ft) &times; Width (ft) &times; Depth (ft)
          </div>
        </div>
      </div>
    </section>

    <!-- Worked Example -->
    <section>
      <h2 id="example-calculation" class="text-xl font-bold tracking-tight mb-4">
        Example Footing Calculation
      </h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Let&rsquo;s calculate the concrete required to set <strong>four deck post footings</strong> that are <strong>12 inches in diameter and 3 feet (36 inches) deep</strong>:
      </p>
      <ul class="list-disc pl-5 flex flex-col gap-2 text-sm text-[var(--fg-secondary)] text-pretty">
        <li><strong>Hole Radius:</strong> 12 inches diameter &divide; 2 = 6 inches = 0.5 feet</li>
        <li><strong>Area of Circle:</strong> &pi; &times; 0.5&sup2; = 3.14159 &times; 0.25 = 0.785 sq ft</li>
        <li><strong>Volume per Footing:</strong> 0.785 sq ft &times; 3 ft depth = 2.356 cu ft</li>
        <li><strong>Total Volume (4 footings):</strong> 2.356 &times; 4 = 9.424 cu ft (~0.35 cubic yards)</li>
        <li><strong>Bags Needed (80lb):</strong> 9.424 &divide; 0.6 cu ft yield = 15.7 &rarr; <strong>16 bags</strong></li>
      </ul>
    </section>

    <!-- Mid Ad Slot -->
    <AdSlot slotId="ad-in-content-mid-footing" />

    <!-- Common Mistakes -->
    <section>
      <h2 id="common-mistakes" class="text-xl font-bold tracking-tight mb-4">
        Common Mistakes with Foundation Posts
      </h2>
      <ul class="list-disc pl-5 flex flex-col gap-3 text-sm text-[var(--fg-secondary)] text-pretty">
        <li>
          <strong>Not Digging Below the Frost Line:</strong> If the concrete post is set in shallow soil, cold winter weather will freeze the groundwater beneath it. The expanding ice pushes the footing upward, cracking your deck framing.
        </li>
        <li>
          <strong>Leaving Loose Dirt in the Hole:</strong> Shovels leave loose, aerated soil at the bottom of the excavation. If you pour directly over this, the heavy concrete will sink and settle over time. Compact the bottom of the hole thoroughly before pouring.
        </li>
        <li>
          <strong>Forgetting Post-hole Bell Flare:</strong> Flaring the bottom of the hole slightly wider than the top (making a bell shape) increases structural load capacity and prevents frost-heaving forces from squeezing the footing upward.
        </li>
      </ul>
    </section>

    <!-- FAQ -->
    <section>
      <h2 id="faq" class="text-xl font-bold tracking-tight mb-4">
        Frequently Asked Questions
      </h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer">How deep should a concrete deck footing be?</summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            Footings must extend below your local frost line to prevent shifting during freeze-thaw cycles. In most northern regions, this means a minimum depth of 36 to 48 inches. Always consult local municipal building codes.
          </p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer">What diameter hole do I need for a 4x4 post?</summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            As a rule of thumb, the diameter of your post hole footing should be three times the width of the post. For a standard 4x4 structural wood post (which actually measures 3.5 inches), you need a minimum hole diameter of 10 to 12 inches.
          </p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer">How much concrete does a 12-inch by 3-foot footing hold?</summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            A cylindrical footing with a 12-inch diameter and a 3-foot depth has a volume of approximately 2.36 cubic feet. This requires about 4 bags of 80lb concrete mix (yielding 0.6 cu ft per bag) or 5.2 bags of 60lb mix.
          </p>
        </details>
      </div>
    </section>

    <!-- Footer Related Links -->
    <footer class="pt-8 mt-6 mb-6">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">
        Related Construction Tools
      </h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a
          href="/calculators/concrete/slab/"
          class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"
        >
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Concrete Slab Calculator</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-normal">Estimate concrete needed for flat rectangular pads, patios, and slabs.</span>
        </a>
        <a
          href="/calculators/concrete/steps/"
          class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"
        >
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Concrete Steps Calculator</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-normal">Estimate concrete required for steps, staircases, and entranceways.</span>
        </a>
        <a
          href="/compare/concrete-vs-pavers/"
          class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"
        >
          <span class="block text-xs font-semibold text-[var(--fg)] mb-1">Concrete vs Pavers</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-normal">Evaluate durability, DIY complexity, maintenance, and lifetime values.</span>
        </a>
      </div>
    </footer>
  </article>
</Layout>
