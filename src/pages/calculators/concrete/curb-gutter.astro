---
import Layout from "../../../layouts/Layout.astro";
import CurbGutterCalc from "../../../components/calculators/CurbGutterCalc";
import { graphSchema, mathSolverSchema, faqPageSchema, howToSchema, webApplicationSchema, breadcrumbListSchema } from "../../../lib/schema";
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro";

const canonical = "https://homeplanninghub.com/calculators/concrete/curb-gutter/";

const title = "Curb & Gutter Calculator";
const description = "Calculate concrete volume for curbs and gutters. Estimate cubic yards, cubic feet, and bag counts for street curbs, driveway transitions, and drainage channels.";

const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");
const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Concrete Calculators", path: "/calculators/concrete/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: "Curb & Gutter Concrete Volume Formula",
    description: "Calculate concrete volume by summing curb and gutter cross-sections along the length.",
    formula: "Volume = (Curb Area + Gutter Area) × Length",
    url: canonical,
  }),
  howToSchema(
    "Calculate Curb & Gutter Concrete",
    "Follow these steps to estimate concrete needed for a combined curb and gutter section.",
    [
      {
        name: "Measure the cross-section dimensions",
        text: "The curb is typically 6 inches wide and 18 inches tall. The gutter pan extends behind the curb, usually 24-36 inches wide and 6 inches deep. Measure each in inches.",
      },
      {
        name: "Convert to feet and find volumes",
        text: "Convert all dimensions to feet (divide by 12). Curb volume = width × height × length. Gutter volume = width × depth × length. Add them for the total.",
      },
      {
        name: "Apply waste and convert to yards",
        text: "Add 5-10% for waste and form overflow. Divide cubic feet by 27 to get cubic yards for ordering ready-mix concrete.",
      },
    ]
  ),
  faqPageSchema([
    {
      q: "How much concrete is needed for a standard curb and gutter?",
      a: "A standard curb (6 in wide × 18 in tall) with gutter (24 in wide × 6 in deep) requires approximately 0.37 cubic yards per 10 linear feet. For 100 linear feet, that is about 3.7 cubic yards.",
    },
    {
      q: "What is the standard size of a curb and gutter?",
      a: "Standard curb dimensions are 6 inches wide and 18 inches tall (6 × 18 curb). Standard gutter sections are 24-36 inches wide and 6 inches deep. The combined section is typically 30-42 inches wide overall.",
    },
    {
      q: "How much does curb and gutter concrete cost?",
      a: "Curb and gutter concrete costs $12-$25 per linear foot installed (2026). Material cost is $8-$12 per linear foot for the concrete itself. Labor and formwork account for the remainder.",
    },
  ], canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6">
    <header class="mb-2">
      <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">home</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/calculators/concrete/" class="hover:underline">concrete</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <span class="text-[var(--fg-secondary)]">curb &amp; gutter</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3">
        Curb & Gutter Calculator
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Estimate the concrete volume needed for curb and gutter sections. Whether you are planning a driveway transition, street curb, or parking lot drainage channel, this calculator handles the combined curb and gutter cross-section with adjustable dimensions.
      </p>
    </header>



    <section>
      <CurbGutterCalc client:visible />
    </section>

    <section>
      <h2 id="how-to-calculate" class="text-xl font-bold tracking-tight mb-4">
        How to Calculate Curb & Gutter Concrete
      </h2>
      <p class="text-sm text-[var(--fg-secondary)] leading-relaxed mb-4 text-pretty">
        Calculating concrete for a combined curb and gutter section requires treating each part of the cross-section separately.
      </p>
      <ol class="list-decimal pl-5 flex flex-col gap-3 text-sm text-[var(--fg-secondary)]">
        <li>
          <strong>Calculate Curb Cross-Section:</strong> Convert curb width and height from inches to feet, then multiply. This gives the cross-sectional area of the curb in square feet.
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Curb Volume (cu ft) = (Width in &divide; 12) &times; (Height in &divide; 12) &times; Length (ft)
          </div>
        </li>
        <li>
          <strong>Calculate Gutter Cross-Section:</strong> Do the same for the gutter width and depth.
          <div class="my-2 p-3 bg-[var(--bg-muted)] rounded-lg font-mono text-center text-xs">
            Gutter Volume (cu ft) = (Width in &divide; 12) &times; (Depth in &divide; 12) &times; Length (ft)
          </div>
        </li>
        <li>
          <strong>Total Volume:</strong> Add the two volumes together. Convert to cubic yards by dividing by 27. Apply 5-10% waste for form overflow and grade variations.
        </li>
      </ol>
    </section>

    <section>
      <h2 id="example" class="text-xl font-bold tracking-tight mb-4">Example Calculation</h2>
      <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
        <p class="text-sm font-semibold text-[var(--fg)] mb-2">Standard curb and gutter section &mdash; 50 linear feet</p>
        <ul class="flex flex-col gap-1.5 text-xs text-[var(--fg-secondary)]">
          <li><strong>Curb:</strong> 6 in wide &times; 18 in tall = 0.75 &times; 1.5 = 1.125 sq ft cross-section</li>
          <li><strong>Gutter:</strong> 24 in wide &times; 6 in deep = 2 &times; 0.5 = 1.0 sq ft cross-section</li>
          <li><strong>Combined volume per foot:</strong> 1.125 + 1.0 = 2.125 cu ft per linear foot</li>
          <li><strong>Total for 50 ft:</strong> 2.125 &times; 50 = 106.25 cu ft &divide; 27 = <strong>3.94 cu yd</strong></li>
          <li><strong>With 8% waste:</strong> 3.94 &times; 1.08 = <strong>4.25 cu yd</strong> &mdash; order 4.5 yards</li>
        </ul>
      </div>
    </section>

    <section>
      <h2 id="common-mistakes" class="text-xl font-bold tracking-tight mb-4">Common Mistakes in Curb &amp; Gutter Estimation</h2>
      <div class="flex flex-col gap-3">
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-1">Ignoring the curb-gutter transition radius</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">The angled transition between the curb and gutter adds extra volume that simple rectangular calculations miss. Add 5-8% or model the transition as a right triangle for greater accuracy.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-1">Forgetting form overfill and spillage</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">Curb and gutter pours often have minor form leakage, overfill, and spillage. Unlike slab pours, these forms are narrow and harder to finish cleanly. Always include at least 8% waste.</p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <h3 class="text-sm font-semibold text-[var(--fg)] mb-1">Mixing up curb height vs total section height</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">Standard curb height is measured from the gutter flow line, not from the subgrade. Measure from the finished gutter surface to the top of the curb, not from the bottom of the form.</p>
        </div>
      </div>
    </section>

    <section>
      <h2 id="faq" class="text-xl font-bold tracking-tight mb-4">
        Frequently Asked Questions
      </h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much concrete is needed for a standard curb and gutter?</h3></summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            A standard 6×18 curb with a 24×6 gutter requires about 0.37 cubic yards per 10 linear feet. For 100 feet, plan on 3.7 cubic yards including 5% waste.
          </p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the standard size of a curb and gutter?</h3></summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            Standard dimensions are curb: 6 inches wide × 18 inches tall, gutter: 24-36 inches wide × 6 inches deep. The combined width is typically 30-42 inches. Local DOT specifications may vary.
          </p>
        </details>
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
          <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does curb and gutter concrete cost?</h3></summary>
          <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
            Installed curb and gutter costs $12-$25 per linear foot (2026). Material is $8-$12 per foot for ready-mix concrete. The remainder covers form setup, labor, and finishing. For small DIY projects, bagged concrete may be cheaper.
          </p>
        </details>
      </div>
    </section>

    <RelatedCalculators slug="concrete-curb-gutter" />
  </article>
</Layout>
