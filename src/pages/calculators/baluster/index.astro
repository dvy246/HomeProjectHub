---
import Layout from "../../../layouts/Layout.astro"
import SpacingCalc from "../../../components/calculators/SpacingCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/baluster/";
const title = "Baluster Spacing Calculator";
const description = "Calculate the number of balusters needed for railings and decks. Enter railing length, baluster spacing, and thickness for equal spacing layout.";
const formula = "Number = Rail Length / (Spacing + Baluster Thickness)";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Baluster Spacing Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How many balusters for 10 ft of railing?",
      a: "With 4\" max spacing and 1.5\" balusters: (120\" / 5.5\") = 22 balusters. Round to 22.",
    },
    {
      q: "What is the maximum baluster spacing?",
      a: "Per IRC R312.2, a 4\" sphere must not pass through any opening. This means max clear space between balusters is 4\".",
    },
    {
      q: "How do I space balusters evenly?",
      a: "Use this formula: (rail length - n × thickness) / (n + 1) = spacing. Adjust n until spacing is ≤ 4\".",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Baluster Spacing Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Baluster Spacing Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate the number of balusters needed for railings and decks. Enter railing length, baluster spacing, and thickness for equal spacing layout.</p>
    <AdSlot slotId="ad-top-leaderboard" />
    <section><SpacingCalc client:visible labelSingular="baluster" labelPlural="balusters" defaultSpacing="4" defaultThickness="1.5" /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Max spacing between balusters: 4\" per IRC code.",
        "Standard baluster thickness: 1.5\".",
        "Balusters should be placed such that a 4\" sphere cannot pass through."
      ]}
    />
    <AdSlot slotId="ad-in-content-mid" />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many balusters for 10 ft of railing?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">With 4" max spacing and 1.5" balusters: (120" / 5.5") = 22 balusters. Round to 22.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the maximum baluster spacing?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Per IRC R312.2, a 4" sphere must not pass through any opening. This means max clear space between balusters is 4".</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do I space balusters evenly?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Use this formula: (rail length - n × thickness) / (n + 1) = spacing. Adjust n until spacing is ≤ 4".</p></details>
      </div>
    </section>
    <footer class="pt-8 mt-6 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/calculators/spindle-spacing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Spindle Spacing</span></a>
      <a href="/calculators/framing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Framing</span></a>
      </div>
    </footer>
  </article>
</Layout>
