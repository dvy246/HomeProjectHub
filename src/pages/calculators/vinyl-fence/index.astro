---
import Layout from "../../../layouts/Layout.astro"
import VinylFenceCalc from "../../../components/calculators/VinylFenceCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/vinyl-fence/";
const title = "Vinyl Fence Calculator";
const description = "Calculate vinyl fence materials including panels, posts, and gates.";
const formula = "Panels = Fence Length / Panel Width | Posts = Panels + 1 + Gates | Gates = Count specified by user";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Wall & Fence", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How many vinyl fence panels do I need for 100 ft?", a: "For standard 8 ft wide panels: 100/8 = 12.5, so 13 panels. Plus 14 posts (panels + 1) plus any gate posts." },
    { q: "What is the standard vinyl fence panel width?", a: "Standard vinyl fence panels are 6 ft or 8 ft wide. Custom widths may be available from some manufacturers." },
    { q: "How deep should vinyl fence posts be set?", a: "Post holes should be 1/3 the post height above ground. For a 6 ft fence, dig 24-30 inches deep. Use concrete for all corner and gate posts." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Vinyl Fence Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Vinyl Fence Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate vinyl fence materials including panels, posts, and gates.</p>
  <AdSlot slotId="ad-top-leaderboard" />

  <section><VinylFenceCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Standard panel width: 8 ft.", "Post hole depth: 1/3 of post height.", "Corner and gate posts require concrete footings.", "Gates require additional support posts on each side.", "Add 1 post per gate for proper support."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many vinyl fence panels do I need for 100 ft?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">For standard 8 ft wide panels: 100/8 = 12.5, so 13 panels. Plus 14 posts (panels + 1) plus any gate posts.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the standard vinyl fence panel width?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Standard vinyl fence panels are 6 ft or 8 ft wide. Custom widths may be available from some manufacturers.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How deep should vinyl fence posts be set?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Post holes should be 1/3 the post height above ground. For a 6 ft fence, dig 24-30 inches deep. Use concrete for all corner and gate posts.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/vinyl-siding/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Vinyl Siding</span></a>
    <a href="/calculators/decking/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Decking</span></a>
    <a href="/calculators/framing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Framing</span></a>
  </div></footer>
</article>
</Layout>
