---
import Layout from "../../../layouts/Layout.astro"
import BoardFootCalc from "../../../components/calculators/BoardFootCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/board-foot/";
const title = "Board Foot Calculator";
const description = "Calculate board feet for lumber. Enter length, width, thickness, and quantity.";
const formula = "Board Feet = (Length (ft) x Width (in) x Thickness (in)) / 12 x Quantity";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Construction Converters", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "What is a board foot?", a: "A board foot is a unit of lumber volume equal to 1 ft x 1 ft x 1 inch thick (144 cubic inches)." },
    { q: "How many board feet in a 2x4x8?", a: "(8 x 2 x 4) / 12 = 5.33 board feet. Note: uses nominal dimensions." },
    { q: "What's the difference between board foot and linear foot?", a: "Board foot measures volume (length x width x thickness). Linear foot measures only length." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Board Foot Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Board Foot Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate board feet for lumber. Enter length, width, thickness, and quantity.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><BoardFootCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["Uses nominal lumber dimensions.", "Board foot = (L x W x T) / 12.", "Quantity multiplies: bd ft x qty.", "Hardwood often sold by board foot, softwood by linear ft."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is a board foot?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A board foot is a unit of lumber volume equal to 1 ft x 1 ft x 1 inch thick (144 cubic inches).</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many board feet in a 2x4x8?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">(8 x 2 x 4) / 12 = 5.33 board feet. Note: uses nominal dimensions.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What's the difference between board foot and linear foot?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Board foot measures volume (length x width x thickness). Linear foot measures only length.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/lumber/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Lumber</span></a>
    <a href="/calculators/square-footage/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Square Footage</span></a>
    <a href="/calculators/size-to-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Size to Weight</span></a>
  </div></footer>
</article>
</Layout>
