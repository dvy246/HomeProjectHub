---
import Layout from "../../../layouts/Layout.astro"
import SizeToWeightCalc from "../../../components/calculators/SizeToWeightCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/steel-plate-weight/";
const title = "Steel Plate Weight Calculator";
const description = "Calculate the weight of steel plates by dimensions. Get pounds, kilograms, and tons for A36 steel and other metals.";
const formula = "Weight = Length (in) × Width (in) × Thickness (in) × Material Density";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Steel Plate Weight Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How much does a 4x8 sheet of 1/4\" steel weigh?",
      a: "A 4x8 (48x96\") sheet of 1/4\" A36 steel weighs about 326 lbs. That's 48 × 96 × 0.25 × 0.2836 = 326.4 lbs.",
    },
    {
      q: "How thick is 10-gauge steel?",
      a: "10-gauge steel is 0.1345\" (3.42 mm). Standard Steel gauge is different from galvanized steel gauge.",
    },
    {
      q: "What's the difference between A36 and mild steel?",
      a: "A36 is a standard mild steel grade with 36,000 psi yield strength. It's the most common structural steel in the US.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Steel Plate Weight Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Steel Plate Weight Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate the weight of steel plates by dimensions. Get pounds, kilograms, and tons for A36 steel and other metals.</p>
    <AdSlot slotId="ad-top-leaderboard" />
    <section><SizeToWeightCalc client:visible /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Steel A36 density: 0.2836 lb/cu in.",
        "Calculator assumes solid rectangular plates.",
        "Actual weight may vary slightly by alloy."
      ]}
    />
    <AdSlot slotId="ad-in-content-mid" />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does a 4x8 sheet of 1/4" steel weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 4x8 (48x96") sheet of 1/4" A36 steel weighs about 326 lbs. That's 48 × 96 × 0.25 × 0.2836 = 326.4 lbs.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How thick is 10-gauge steel?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">10-gauge steel is 0.1345" (3.42 mm). Standard Steel gauge is different from galvanized steel gauge.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What's the difference between A36 and mild steel?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A36 is a standard mild steel grade with 36,000 psi yield strength. It's the most common structural steel in the US.</p></details>
      </div>
    </section>
    <footer class="pt-8 mt-6 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/calculators/plate-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Plate Weight</span></a>
      <a href="/calculators/steel-plate-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Steel Weight</span></a>
      </div>
    </footer>
  </article>
</Layout>
