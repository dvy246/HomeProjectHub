---
import Layout from "../../../layouts/Layout.astro"
import WeightCalc from "../../../components/calculators/WeightCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeprojecthub.com/calculators/aluminum-weight/";
const title = "Aluminum Weight Calculator";
const description = "Calculate aluminum weight by dimensions. Enter length, width, and thickness for 6061, 7075, or 2024 aluminum.";
const formula = "Weight = Volume x Density";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Weight", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "What is the weight of 6061 aluminum?", a: "6061 aluminum weighs 0.0975 lb/cu in (169 lb/cu ft). It is about 1/3 the weight of steel, making it ideal for aerospace and automotive applications." },
    { q: "How much does a 4x8 sheet of 1/8 aluminum weigh?", a: "A 4x8 (48x96) sheet of 1/8\" 6061 aluminum weighs about 45 lbs: 48 x 96 x 0.125 x 0.0975 = 56.2 lbs." },
    { q: "Is 7075 aluminum heavier than 6061?", a: "7075 aluminum density is 0.101 lb/cu in vs 6061 at 0.0975 lb/cu in. 7075 is about 3.5% heavier but significantly stronger." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Aluminum Weight Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Aluminum Weight Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate aluminum weight by dimensions. Enter length, width, and thickness for 6061, 7075, or 2024 aluminum.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><WeightCalc client:visible materials={[{ id: "aluminum_6061", label: "Aluminum 6061 (0.0975 lb/cu in)" }, { id: "aluminum_7075", label: "Aluminum 7075 (0.101 lb/cu in)" }, { id: "aluminum_2024", label: "Aluminum 2024 (0.100 lb/cu in)" }]} defaultMaterial="aluminum_6061" /></section>
  <EstimateMethodology formula={formula} assumptions={["Aluminum densities from standard engineering references.", "Weight calculated for solid rectangular shapes only.", "Actual weight varies by alloy composition and temper.", "Alloy 6061: 0.0975 lb/cu in, 7075: 0.101 lb/cu in, 2024: 0.100 lb/cu in."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What is the weight of 6061 aluminum?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">6061 aluminum weighs 0.0975 lb/cu in (169 lb/cu ft). It is about 1/3 the weight of steel, making it ideal for aerospace and automotive applications.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does a 4x8 sheet of 1/8 aluminum weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 4x8 (48x96) sheet of 1/8" 6061 aluminum weighs about 45 lbs: 48 x 96 x 0.125 x 0.0975 = 56.2 lbs.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Is 7075 aluminum heavier than 6061?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">7075 aluminum density is 0.101 lb/cu in vs 6061 at 0.0975 lb/cu in. 7075 is about 3.5% heavier but significantly stronger.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/metal-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Metal Weight</span></a>
    <a href="/calculators/steel-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Steel Weight</span></a>
    <a href="/calculators/glass-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Glass Weight</span></a>
  </div></footer>
</article>
</Layout>
