---
import Layout from "../../../layouts/Layout.astro"
import BoardBattenCalc from "../../../components/calculators/BoardBattenCalc"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro"

const canonical = "https://homeplanninghub.com/calculators/board-batten/";
const title = "Board and Batten Calculator";
const description = "Calculate how many boards and battens you need for a vertical siding or accent wall project. Enter wall dimensions and board/batten widths.";
const formula = "Boards = (Wall Width / (Board Width + Batten Width)) + 1";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Board and Batten Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How many boards for a 10 ft wall?",
      a: "A 10 ft (120\") wide wall with 5.5\" boards and 1.5\" battens needs 18 boards and 17 battens plus 10% waste.",
    },
    {
      q: "What spacing for board and batten?",
      a: "Batten spacing equals board width. For 5.5\" boards with 1.5\" battens, center-to-center spacing is 7\".",
    },
    {
      q: "Do I need a vapor barrier?",
      a: "Yes. Install house wrap or vapor barrier behind board and batten siding. Use furring strips for drainage plane.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Board and Batten Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Board and Batten Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate how many boards and battens you need for a vertical siding or accent wall project. Enter wall dimensions and board/batten widths.</p>
    <section><BoardBattenCalc client:visible /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Standard board width: 5.5\" (nominal 1×6).",
        "Standard batten width: 1.5\" (nominal 1×2).",
        "Board edges meet batten centers. Add 10% waste."
      ]}
    />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many boards for a 10 ft wall?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 10 ft (120") wide wall with 5.5" boards and 1.5" battens needs 18 boards and 17 battens plus 10% waste.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What spacing for board and batten?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Batten spacing equals board width. For 5.5" boards with 1.5" battens, center-to-center spacing is 7".</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Do I need a vapor barrier?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Yes. Install house wrap or vapor barrier behind board and batten siding. Use furring strips for drainage plane.</p></details>
      </div>
    </section>
    <RelatedCalculators slug="board-batten" />
  </article>
</Layout>
