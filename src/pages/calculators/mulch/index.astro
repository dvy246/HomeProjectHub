---
import Layout from "../../../layouts/Layout.astro"
import MulchCalc from "../../../components/calculators/MulchCalc"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"
import RelatedCalculators from "../../../components/ui/RelatedCalculators.astro"

const canonical = "https://homeplanninghub.com/calculators/mulch/";
const title = "Mulch Calculator";
const description = "Calculate how many bags or cubic yards of mulch you need for garden beds and landscaping. Compare bark, cedar, rubber, and dyed mulch.";
const formula = "Bags = Cubic Yards × 13.5 (for 2 cu ft bags)";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Mulch Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How many bags of mulch per yard?",
      a: "13.5 bags of 2-cu-ft mulch equals 1 cubic yard. Bulk delivery is often cheaper for large areas.",
    },
    {
      q: "How deep should mulch be?",
      a: "2-3\" is ideal. Too thin won't suppress weeds; too thick can rot plant stems and prevent water penetration.",
    },
    {
      q: "How much mulch for a 10x10 bed?",
      a: "At 3\" depth, a 10x10 ft bed needs about 0.93 cu yd which is about 13 bags of 2-cu-ft mulch.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Mulch Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Mulch Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate how many bags or cubic yards of mulch you need for garden beds and landscaping. Compare bark, cedar, rubber, and dyed mulch.</p>
    <section><MulchCalc client:visible /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Mulch settles 1-2 inches over time.",
        "Bag sizes vary; calculator assumes 2 cu ft bags.",
        "Rubber mulch is significantly heavier."
      ]}
    />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many bags of mulch per yard?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">13.5 bags of 2-cu-ft mulch equals 1 cubic yard. Bulk delivery is often cheaper for large areas.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How deep should mulch be?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">2-3" is ideal. Too thin won't suppress weeds; too thick can rot plant stems and prevent water penetration.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much mulch for a 10x10 bed?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">At 3" depth, a 10x10 ft bed needs about 0.93 cu yd which is about 13 bags of 2-cu-ft mulch.</p></details>
      </div>
    </section>
    <RelatedCalculators slug="mulch" />
  </article>
</Layout>
