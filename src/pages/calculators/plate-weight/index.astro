---
import Layout from "../../../layouts/Layout.astro"
import SizeToWeightCalc from "../../../components/calculators/SizeToWeightCalc"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/plate-weight/";
const title = "Plate Weight Calculator";
const description = "Calculate weight of any flat plate material — steel, aluminum, copper, glass, wood, or concrete. Enter dimensions for precise weight estimates.";
const formula = "Weight = Length × Width × Thickness × Density";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Plate Weight Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How do I calculate plate weight?",
      a: "Multiply length × width × thickness in inches, then multiply by the material density in lb/cu in.",
    },
    {
      q: "What's the density of aluminum?",
      a: "Aluminum 6061 density is 0.0975 lb/cu in (2,700 kg/m³). It's about 1/3 the weight of steel.",
    },
    {
      q: "How much does a 1\" steel plate weigh?",
      a: "A 1\" thick A36 steel plate weighs 40.8 lbs per square foot (0.2836 lb/cu in × 144 sq in/sq ft × 1\").",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Plate Weight Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Plate Weight Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate weight of any flat plate material — steel, aluminum, copper, glass, wood, or concrete. Enter dimensions for precise weight estimates.</p>
    <section><SizeToWeightCalc client:visible /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Material densities from standard engineering references.",
        "Weight is for solid rectangular plates only.",
        "Actual weight varies by alloy and composition."
      ]}
    />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do I calculate plate weight?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Multiply length × width × thickness in inches, then multiply by the material density in lb/cu in.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What's the density of aluminum?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Aluminum 6061 density is 0.0975 lb/cu in (2,700 kg/m³). It's about 1/3 the weight of steel.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much does a 1" steel plate weigh?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 1" thick A36 steel plate weighs 40.8 lbs per square foot (0.2836 lb/cu in × 144 sq in/sq ft × 1").</p></details>
      </div>
    </section>
    <footer class="pt-8 mt-6 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/calculators/steel-plate-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Steel Plate Weight</span></a>
      <a href="/calculators/stone-weight/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Stone Weight</span></a>
      </div>
    </footer>
  </article>
</Layout>
