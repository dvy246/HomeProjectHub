---
import Layout from "../../../layouts/Layout.astro"
import SquareFootageCalc from "../../../components/calculators/SquareFootageCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/square-footage/";
const title = "Square Footage Calculator";
const description = "Calculate square footage for rectangles, circles, triangles, and L-shapes.";
const formula = "Rectangle: L x W | Circle: pi x R^2 | Triangle: 0.5 x B x H | L-shape: divide into rectangles and sum";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Construction Converters", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({ name: title, description, formula, url: canonical }),
  howToSchema(title, description, [
    { name: "Measure area", text: "Review your project measurements." },
    { name: "Enter dimensions", text: "Input your project dimensions into the calculator." },
    { name: "Get estimate", text: "Review your material estimate and adjust as needed." },
  ]),
  faqPageSchema([
    { q: "How do I calculate square footage of a room?", a: "Measure length and width in feet, then multiply. For L-shaped rooms, divide into rectangles and add each area." },
    { q: "What's the square footage of a 12x12 room?", a: "A 12x12 room is 144 sq ft. This is wall-to-wall floor area — wall paint needs perimeter x ceiling height." },
    { q: "How many square feet in an acre?", a: "43,560 square feet = 1 acre. A 209 ft x 209 ft square is roughly one acre." },
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
<article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
  <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
    <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-[var(--fg-secondary)] font-medium">Square Footage Calculator</span>
  </nav>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Square Footage Calculator</h1>
  <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate square footage for rectangles, circles, triangles, and L-shapes.</p>
  <AdSlot slotId="ad-top-leaderboard" />
  <section><SquareFootageCalc client:visible /></section>
  <EstimateMethodology formula={formula} assumptions={["All measurements in feet.", "L-shape areas calculated by dividing into rectangles.", "Circle area uses radius (half the diameter).", "Triangle area uses base x height / 2.", "Results rounded to 2 decimal places."]} />
  <AdSlot slotId="ad-in-content-mid" />
  <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do I calculate square footage of a room?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Measure length and width in feet, then multiply. For L-shaped rooms, divide into rectangles and add each area.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What's the square footage of a 12x12 room?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">A 12x12 room is 144 sq ft. This is wall-to-wall floor area — wall paint needs perimeter x ceiling height.</p></details>
    <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many square feet in an acre?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">43,560 square feet = 1 acre. A 209 ft x 209 ft square is roughly one acre.</p></details>
  </div></section>
  <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/calculators/sq-ft-to-cu-yd/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Sq Ft to Cu Yd</span></a>
    <a href="/calculators/square-yards/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Square Yards</span></a>
    <a href="/calculators/cubic-yard/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Cubic Yard</span></a>
  </div></footer>
</article>
</Layout>
