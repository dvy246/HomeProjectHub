---
import Layout from "../../../layouts/Layout.astro"
import SpacingCalc from "../../../components/calculators/SpacingCalc"
import AdSlot from "../../../components/AdSlot.astro"
import EstimateMethodology from "../../../components/EstimateMethodology.astro"
import { graphSchema, webApplicationSchema, faqPageSchema, howToSchema, mathSolverSchema, breadcrumbListSchema } from "../../../lib/schema"

const canonical = "https://homeplanninghub.com/calculators/spindle-spacing/";
const title = "Spindle Spacing Calculator";
const description = "Calculate the number of spindles for stair railings and deck railings. Enter rail length, spindle size, and spacing for code-compliant layout.";
const formula = "Number = Rail Length / (Spacing + Spindle Thickness)";
const PAGE_PATH = canonical.replace("https://homeplanninghub.com", "");

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Spindle Spacing Calculator", path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Review your project measurements.",
    },
    {
      name: "Enter dimensions",
      text: "Input your project dimensions into the calculator.",
    },
    {
      name: "Get estimate",
      text: "Review your material estimate and adjust as needed.",
    },
  ]),
  faqPageSchema([
    {
      q: "How many spindles for a 12 ft railing?",
      a: "With 4\" max spacing and 1.5\" spindles: (144\" / 5.5\") = 26 spindles. Round to 26.",
    },
    {
      q: "Are stair spindles different?",
      a: "Yes. Stair spindles follow the stair angle. Measure along the slope and use the same 4\" sphere rule projected vertically.",
    },
    {
      q: "What code governs spindle spacing?",
      a: "IRC R312.2 requires a 4\" sphere not pass through. IBC 1015.2 requires 4\" for commercial. Check local amendments.",
    }
  ], canonical)
);
---
<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Spindle Spacing Calculator</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Spindle Spacing Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Calculate the number of spindles for stair railings and deck railings. Enter rail length, spindle size, and spacing for code-compliant layout.</p>
    <AdSlot slotId="ad-top-leaderboard" />
    <section><SpacingCalc client:visible labelSingular="spindle" labelPlural="spindles" defaultSpacing="4" defaultThickness="1.5" calculatorSlug="spindle-spacing" calculatorName="Spindle Spacing Calculator" /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Max spacing between spindles: 4\" per IRC code.",
        "Standard spindle thickness: 1.5\".",
        "Stair railings use angled top and bottom rails."
      ]}
    />
    <AdSlot slotId="ad-in-content-mid" />
    <section>
      <h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How many spindles for a 12 ft railing?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">With 4" max spacing and 1.5" spindles: (144" / 5.5") = 26 spindles. Round to 26.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Are stair spindles different?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Yes. Stair spindles follow the stair angle. Measure along the slope and use the same 4" sphere rule projected vertically.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">What code governs spindle spacing?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">IRC R312.2 requires a 4" sphere not pass through. IBC 1015.2 requires 4" for commercial. Check local amendments.</p></details>
      </div>
    </section>
    <footer class="pt-8 mt-6 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/calculators/baluster/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Baluster Spacing</span></a>
      <a href="/calculators/framing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Framing</span></a>
      </div>
    </footer>
  </article>
</Layout>
