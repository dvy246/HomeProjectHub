---
import Layout from "../../../layouts/Layout.astro";
import AggregateCalc from "../../../components/calculators/AggregateCalc";
import AdSlot from "../../../components/AdSlot.astro";
import EstimateMethodology from "../../../components/EstimateMethodology.astro";
import { graphSchema, mathSolverSchema, faqPageSchema, howToSchema, webApplicationSchema, breadcrumbListSchema } from "../../../lib/schema";

const canonical = "https://homeprojecthub.com/calculators/rip-rap/";
const title = "Rip Rap Calculator";
const description = "Calculate rip rap stone needed for erosion control. Enter area and depth to get cubic yards and tons of rip rap for shoreline and slope protection.";
const formula = "Tons = Cubic Yards × 1.55";
const PAGE_PATH = canonical.replace("https://homeprojecthub.com", "");
const aggs = [
  {
    id: "rip_rap",
    label: "Rip Rap",
    tonsPerCuYd: 1.55,
  },
];

const schema = graphSchema(
  breadcrumbListSchema([
    { name: "Home", path: "/" },
    { name: "Landscaping", path: "/calculators/" },
    { name: title, path: PAGE_PATH },
  ]),
  webApplicationSchema(title, description, canonical),
  mathSolverSchema({
    name: title,
    description,
    formula,
    url: canonical,
  }),
  howToSchema(title, description, [
    {
      name: "Measure area",
      text: "Area to cover in sq ft.",
    },
    {
      name: "Set depth",
      text: "Typical rip rap depth is 12-24 inches.",
    },
    {
      name: "Calculate",
      text: "Get tons and cubic yards.",
    },
  ]),
  faqPageSchema([
    {
      q: "How much rip rap do I need?",
      a: "Calculate area × depth for cubic feet, divide by 27 for cubic yards. Multiply by 1.55 for tons.",
    },
    {
      q: "What is rip rap used for?",
      a: "Rip rap is used for erosion control on shorelines, slopes, drainage channels, and around culverts and bridge abutments.",
    },
    {
      q: "How deep should rip rap be?",
      a: "Typical rip rap depth is 12-24 inches, depending on water flow velocity and slope steepness.",
    },
  ], canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/calculators/" class="hover:text-[var(--fg)] transition-colors">Calculators</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Rip Rap</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Rip Rap Calculator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Estimate rip rap for erosion control projects. Get cubic yards and tons for shoreline and slope protection.</p>
    <AdSlot slotId="ad-top-leaderboard" />
    <section><AggregateCalc client:visible aggregates={aggs} defaultKey="rip_rap" calculatorLabel="Rip Rap" /></section>
    <EstimateMethodology
      formula={formula}
      assumptions={[
        "Rip rap density: 1.55 tons per cu yd.",
        "Depth should account for the largest stone size.",
        "Rip rap is typically placed over filter fabric.",
      ]}
    />
    <AdSlot slotId="ad-in-content-mid" />
    <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3"><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How much rip rap?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">(sq ft × depth/12)/27 = cu yd. × 1.55 = tons.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Rip rap uses?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Erosion control on shorelines, slopes, channels.</p></details><details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">Rip rap depth?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">12-24" depending on water flow and slope.</p></details></div></section>
    <footer class="pt-8 mt-6 border-t border-[var(--border)]"><h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4><div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/calculators/river-rock/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">River Rock</span></a>
      <a href="/calculators/gravel/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Gravel Calculator</span></a>
      <a href="/calculators/limestone/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors"><span class="text-sm font-semibold">Limestone</span></a>
    </div></footer>
  </article>
</Layout>
