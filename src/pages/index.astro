---
import Layout from "../layouts/Layout.astro";
import HeroQuickCalc from "../components/HeroQuickCalc";
import InteractiveHouseExplorer from "../components/InteractiveHouseExplorer";
import { graphSchema, webSiteSchema, faqPageSchema, webPageSchema } from "../lib/schema";

const SITE_URL = "https://homeplanninghub.com";

const title = "HomePlanningHub — Professional-Grade Construction Calculators";
const description = "Free material calculators for concrete, roofing, paint, tile, and more. Get precise estimation lists with transparent math formulas and zero sign-up.";

const concreteCalcs = [
  { href: "/calculators/concrete/slab/", title: "Slab", desc: "Patios, driveways, sidewalks" },
  { href: "/calculators/concrete/footing/", title: "Footing", desc: "Pier holes, deck foundations" },
  { href: "/calculators/concrete/column/", title: "Column", desc: "Round & square columns" },
  { href: "/calculators/concrete/wall/", title: "Wall", desc: "Walls with opening deductions" },
  { href: "/calculators/concrete/tube/", title: "Tube Form", desc: "Sonotubes & cylindrical piers" },
  { href: "/calculators/concrete/steps/", title: "Steps", desc: "Staircases with landings" },
];

const roofingCalcs = [
  { href: "/calculators/roofing/shingles/", title: "Shingles", desc: "Bundles, squares, nails" },
  { href: "/calculators/roofing/metal/", title: "Metal Roof", desc: "Panels, screws, ridge cap" },
  { href: "/calculators/roofing/plywood/", title: "Plywood Deck", desc: "Sheathing sheets & H-clips" },
  { href: "/calculators/roofing/pitch/", title: "Roof Pitch", desc: "Degrees, multiplier, rafter" },
];

const paintCalcs = [
  { href: "/calculators/paint/", title: "Interior Paint", desc: "Gallons for walls & ceilings" },
];

const tileCalcs = [
  { href: "/calculators/tile/", title: "Tile Flooring", desc: "Counts, boxes, patterns" },
];

const moreCalcs = [
  { href: "/calculators/drywall/", title: "Drywall", desc: "Sheets, tape, joint compound" },
  { href: "/calculators/gravel/", title: "Gravel", desc: "Driveways, pathways, drainage" },
  { href: "/calculators/mulch/", title: "Mulch", desc: "Bags, yards, coverage depth" },
  { href: "/calculators/sand/", title: "Sand", desc: "Patio base, paver joints" },
  { href: "/calculators/brick/", title: "Brick & Block", desc: "Wall counts, mortar" },
];

const faqs = [
  { q: "Are these calculators free to use?", a: "Yes. Every calculator on HomePlanningHub is completely free. No sign-up, no paywall, no data collection. Your dimensions are stored locally in your browser and never sent to a server." },
  { q: "What is the formula for calculating concrete?", a: "Concrete volume is calculated by multiplying length (in feet) by width (in feet) by thickness (in feet), then dividing by 27 to convert cubic feet to cubic yards. The formula is: Volume (cu\u00a0yd) = Length\u00a0(ft) × Width\u00a0(ft) × Thickness\u00a0(ft) ÷ 27. Our concrete calculator handles this automatically and also computes bag counts for 40\u00a0lb, 60\u00a0lb, and 80\u00a0lb mixes." },
  { q: "How much paint do I need for a 12×12 room?", a: "A standard 12×12 foot bedroom with 8-foot ceilings has roughly 320\u00a0square feet of wall area after subtracting one door (21\u00a0sq\u00a0ft) and two windows (24\u00a0sq\u00a0ft). One gallon of paint covers about 350\u00a0square feet, so a single gallon is usually enough for one coat. Two gallons are recommended for two coats or if painting over a darker color." },
  { q: "How do I calculate square footage of a room?", a: "Measure the length and width of the room in feet, then multiply them: Area = Length × Width. For an L-shaped room, divide it into two rectangles, calculate each area, and add them together. All of our calculators that accept dimensions perform this square footage calculation automatically before applying material-specific formulas." },
  { q: "How accurate are the calculations?", a: "All formulas use standard engineering math: geometric volume calculations, pitch-corrected surface area for roofs, and manufacturer-published bag yields and coverage rates. Every calculator shows its formula and a worked example so you can verify the math yourself. Final quantities should always be compared against the specific products you purchase." },
  { q: "Can I save my project dimensions?", a: "Yes. Use the Save Measurement feature on any calculator to store your room or slab dimensions in-browser via localStorage. Visit the Saved Measurements page to manage and reload them instantly into any calculator. Your data never leaves your device." },
];

const schema = graphSchema(
  webSiteSchema("HomePlanningHub", "Free home improvement calculators and material estimation tools for homeowners and DIY builders."),
  webPageSchema({
    url: SITE_URL,
    topicName: "Home Improvement",
    topicUrl: "https://en.wikipedia.org/wiki/Home_improvement",
  }),
  faqPageSchema(faqs, SITE_URL),
);
---

<Layout title={title} description={description} canonical={SITE_URL} schema={schema}>
  <!-- HERO — Fix #1: Tighter copy, better breathing room -->
  <section class="relative overflow-hidden -mx-4 sm:-mx-6 px-4 sm:px-6 -mt-8 md:-mt-12 pt-16 md:pt-24 pb-20">
    <div class="absolute inset-0 bg-grid opacity-50"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[400px] bg-[radial-gradient(ellipse_at_top,var(--border-strong),transparent_60%)] opacity-30 pointer-events-none -z-10"></div>
    <div class="relative grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="flex flex-col gap-5 lg:col-span-5">
        <div class="inline-flex items-center gap-2 self-start px-3 py-1 rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] text-xs font-medium text-[var(--fg-secondary)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--success)]"></span>
          Free &middot; No sign-up &middot; Open formulas
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-gradient leading-[1.05] text-balance">
          Build with Precision,<br class="hidden sm:block" /> Estimate with Confidence
        </h1>
        <p class="text-base sm:text-lg text-[var(--fg-secondary)] text-pretty leading-relaxed max-w-lg">
          Professional-grade calculators for concrete, roofing, paint, and tile&mdash;with transparent math you can verify.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mt-1">
          <a href="#project-types" class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold rounded-lg bg-[var(--accent)] text-[var(--accent-fg)] hover:bg-[var(--accent-hover)] border border-[var(--accent)] shadow-sm transition-colors active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--ring)]/50">
            Start Calculating
            <svg class="w-4 h-4 ml-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
          <a href="/planner/" class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold rounded-lg border border-[var(--border-strong)] text-[var(--fg)] hover:border-[var(--border-hover)] hover:bg-[var(--bg-muted)] transition-colors active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--ring)]/50">
            Plan a Project
          </a>
        </div>
      </div>
      <div class="w-full lg:col-span-7">
        <InteractiveHouseExplorer client:load />
      </div>
    </div>
  </section>

  <!-- TRUST BAR — Fix #2: Static badges, no expanding, no layout shifts -->
  <section class="border-y border-[var(--border)] -mx-4 sm:-mx-6 px-4 sm:px-6 py-5 mb-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
      <div class="group relative flex flex-col items-center text-center">
        <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--bg-muted)] mb-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="text-xs font-semibold text-[var(--fg)]">Open Formulas</div>
        <div class="text-[11px] text-[var(--fg-muted)]">Every formula visible</div>
        <!-- Tooltip on hover -->
        <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 w-52 p-3 rounded-lg border border-[var(--border)] bg-[var(--bg)] shadow-lg text-[11px] text-[var(--fg-secondary)] leading-relaxed opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity duration-150 pointer-events-none z-20" role="tooltip">
          Every calculation shows its formula and a worked example. Verify the math yourself&mdash;no black box.
        </div>
      </div>
      <div class="group relative flex flex-col items-center text-center">
        <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--bg-muted)] mb-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
        </div>
        <div class="text-xs font-semibold text-[var(--fg)]">No Sign-Up</div>
        <div class="text-[11px] text-[var(--fg-muted)]">Start calculating now</div>
        <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 w-52 p-3 rounded-lg border border-[var(--border)] bg-[var(--bg)] shadow-lg text-[11px] text-[var(--fg-secondary)] leading-relaxed opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity duration-150 pointer-events-none z-20" role="tooltip">
          All calculations run in your browser. No account, no email, no data collection.
        </div>
      </div>
      <div class="group relative flex flex-col items-center text-center">
        <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--bg-muted)] mb-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
        </div>
        <div class="text-xs font-semibold text-[var(--fg)]">Mobile Friendly</div>
        <div class="text-[11px] text-[var(--fg-muted)]">Works on any device</div>
        <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 w-52 p-3 rounded-lg border border-[var(--border)] bg-[var(--bg)] shadow-lg text-[11px] text-[var(--fg-secondary)] leading-relaxed opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity duration-150 pointer-events-none z-20" role="tooltip">
          Responsive layout with touch-friendly inputs and numeric keypad support on mobile.
        </div>
      </div>
      <div class="group relative flex flex-col items-center text-center">
        <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--bg-muted)] mb-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
        </div>
        <div class="text-xs font-semibold text-[var(--fg)]">Privacy First</div>
        <div class="text-[11px] text-[var(--fg-muted)]">Data stays in browser</div>
        <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 w-52 p-3 rounded-lg border border-[var(--border)] bg-[var(--bg)] shadow-lg text-[11px] text-[var(--fg-secondary)] leading-relaxed opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity duration-150 pointer-events-none z-20" role="tooltip">
          Dimensions stored in localStorage on your device. Nothing is sent to a server.
        </div>
      </div>
    </div>
  </section>

  <!-- Planning Workflow — Moved above for immediate step-by-step clarity -->
  <section class="mb-16">
    <h2 class="text-xl font-bold tracking-tight mb-8 text-balance">A planning workflow, not just formulas</h2>
    <div class="relative">
      <!-- Connecting line behind the steps (desktop only) -->
      <div class="hidden md:block absolute top-9 left-[calc(12.5%+14px)] right-[calc(12.5%+14px)] h-px bg-[var(--border)]" aria-hidden="true"></div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        {[
          ["1", "Measure", "Save rooms, slabs, roof areas, and project dimensions in your browser. Use them across any calculator."],
          ["2", "Estimate", "Apply calculator formulas with visible assumptions, waste factors, and unit conversions."],
          ["3", "Compare", "Check material tradeoffs: poured concrete vs. pavers, shingles vs. standing-seam metal."],
          ["4", "Shop", "Turn the final estimate into a practical shopping list. Verify dimensions before purchasing."],
        ].map(([step, heading, copy]) => (
          <div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 relative">
            <div class="w-7 h-7 rounded-full bg-[var(--accent)] text-[var(--accent-fg)] flex items-center justify-center text-xs font-bold mb-3 tabular-nums relative z-10">{step}</div>
            <h3 class="text-sm font-semibold mb-1">{heading}</h3>
            <p class="text-xs text-[var(--fg-secondary)] leading-relaxed">{copy}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CATEGORY HUB — Fix #3: Spotlight cards for top categories, accent icon colors -->
  <section id="project-types" class="mb-14">
    <h2 class="text-xl font-bold tracking-tight mb-6 text-balance">Choose a project type to get started</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <!-- Spotlight: Concrete -->
      <a href="/calculators/concrete/" class="group relative p-6 card-elevated overflow-hidden rounded-2xl">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center shrink-0 text-amber-600 group-hover:bg-amber-500 group-hover:text-white transition-colors duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16v4H4zM4 10h16v10H4z" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Concrete &amp; Masonry</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed line-clamp-2">Slabs, footings, walls, columns, steps, block fill, rebar</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-2 group-hover:gap-1.5 transition-all">
              View <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <!-- Spotlight: Roofing -->
      <a href="/calculators/roofing/" class="group relative p-6 card-elevated overflow-hidden rounded-2xl">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-sky-500/10 flex items-center justify-center shrink-0 text-sky-600 group-hover:bg-sky-500 group-hover:text-white transition-colors duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12L12 3l9 9M5 10v10h14V10" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Roofing</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed line-clamp-2">Shingles, metal, plywood, pitch angle, snow loads, underlayment</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-2 group-hover:gap-1.5 transition-all">
              View <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <!-- Paint & Interior -->
      <a href="/calculators/paint/" class="group relative p-6 card-elevated overflow-hidden rounded-2xl">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-violet-500/10 flex items-center justify-center shrink-0 text-violet-600 group-hover:bg-violet-500 group-hover:text-white transition-colors duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Paint &amp; Interior</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed line-clamp-2">Interior paint, tile floors, drywall, sealant, wall coverage</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-2 group-hover:gap-1.5 transition-all">
              View <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <!-- Tile & Flooring -->
      <a href="/calculators/tile/" class="group relative p-6 card-elevated overflow-hidden rounded-2xl">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center shrink-0 text-emerald-600 group-hover:bg-emerald-500 group-hover:text-white transition-colors duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16v16H4z" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Tile &amp; Flooring</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed line-clamp-2">Tile counts, box quantities, grid/diagonal/herringbone patterns</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-2 group-hover:gap-1.5 transition-all">
              View <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <!-- Maintenance Planner -->
      <a href="/maintenance/" class="group relative p-6 card-elevated overflow-hidden rounded-2xl">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-rose-500/10 flex items-center justify-center shrink-0 text-rose-600 group-hover:bg-rose-500 group-hover:text-white transition-colors duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Maintenance Planner</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed line-clamp-2">Seasonal checklists, cost estimates, home care schedules</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-2 group-hover:gap-1.5 transition-all">
              Explore <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <!-- Project Planner -->
      <a href="/planner/" class="group relative p-6 card-elevated overflow-hidden rounded-2xl">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center shrink-0 text-indigo-600 group-hover:bg-indigo-500 group-hover:text-white transition-colors duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Project Planner</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed line-clamp-2">Combine calculations, manage materials, build shopping lists</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-2 group-hover:gap-1.5 transition-all">
              Explore <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Concrete Calculators — Fix #12: hover lift -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl font-bold tracking-tight">Concrete Calculators</h2>
        <p class="text-sm text-[var(--fg-muted)] mt-0.5">Volume, bag count, and mix ratios for slabs, footings, walls, columns, and steps</p>
      </div>
      <a href="/calculators/concrete/" class="text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] transition-colors flex items-center gap-1 shrink-0">
        View all
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {concreteCalcs.map((calc) => (
        <a href={calc.href} class="group rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-[border-color,background-color,transform,box-shadow] duration-200 hover:-translate-y-0.5">
          <div class="flex items-start justify-between mb-3">
            <div class="w-9 h-9 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-600 group-hover:bg-amber-500 group-hover:text-white transition-colors duration-200">
