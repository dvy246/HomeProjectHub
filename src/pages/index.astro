---
import Layout from "../layouts/Layout.astro";
import { Card, CardTitle, CardDescription } from "../components/ui/Card";

const title = "Professional Home Material Calculators";
const description = "Calculate concrete slabs, post footings, and step volumes with precision. Save your room dimensions in the browser and compare construction materials instantly.";
---

<Layout title={title} description={description}>
  <div class="flex flex-col gap-12 max-w-4xl mx-auto py-4">
    <!-- Hero Header -->
    <header class="text-center flex flex-col gap-4">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-neutral-900 dark:text-neutral-50 text-balance">
        Estimate Materials & Plan Projects Like a Pro
      </h1>
      <p class="text-base sm:text-lg text-neutral-500 dark:text-neutral-400 max-w-2xl mx-auto text-pretty">
        HomeProjectHub provides deterministic mathematical estimators for your residential pours and building projects. Store your measurements in-browser to apply them instantly across our tool suites.
      </p>
    </header>

    <!-- Core Tools Grid -->
    <section class="flex flex-col gap-6">
      <h2 class="text-lg font-bold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">
        Active Tools & Calculators
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Slab Calculator -->
        <a href="/calculators/concrete/slab/" class="block group">
          <Card hoverable className="h-full flex flex-col justify-between">
            <div>
              <CardTitle className="group-hover:text-[#0070f3] dark:group-hover:text-white transition-colors">
                Concrete Slab Calculator &rarr;
              </CardTitle>
              <CardDescription>
                Calculate volume in cubic yards and standard bag counts for flat rectangular patios, driveways, and sidewalks.
              </CardDescription>
            </div>
            <span class="text-xs font-mono text-neutral-450 dark:text-neutral-500 mt-4 block">Calculates: Volume, Weight, 40/50/60/80lb Bags</span>
          </Card>
        </a>

        <!-- Footing Calculator -->
        <a href="/calculators/concrete/footing/" class="block group">
          <Card hoverable className="h-full flex flex-col justify-between">
            <div>
              <CardTitle className="group-hover:text-[#0070f3] dark:group-hover:text-white transition-colors">
                Concrete Footing Calculator &rarr;
              </CardTitle>
              <CardDescription>
                Estimate concrete needs for pier holes, circular columns, and square structural deck foundations.
              </CardDescription>
            </div>
            <span class="text-xs font-mono text-neutral-450 dark:text-neutral-500 mt-4 block">Calculates: Cylinder & Block Volume, Post Diameters</span>
          </Card>
        </a>

        <!-- Steps Calculator -->
        <a href="/calculators/concrete/steps/" class="block group">
          <Card hoverable className="h-full flex flex-col justify-between">
            <div>
              <CardTitle className="group-hover:text-[#0070f3] dark:group-hover:text-white transition-colors">
                Concrete Steps Calculator &rarr;
              </CardTitle>
              <CardDescription>
                Calculate step block volumes for staircases with landing extensions using precise mathematical sums.
              </CardDescription>
            </div>
            <span class="text-xs font-mono text-neutral-450 dark:text-neutral-500 mt-4 block">Calculates: Multi-Step Volume, Extra Landing Depth</span>
          </Card>
        </a>

        <!-- Compare Materials -->
        <a href="/compare/" class="block group">
          <Card hoverable className="h-full flex flex-col justify-between">
            <div>
              <CardTitle className="group-hover:text-[#0070f3] dark:group-hover:text-white transition-colors">
                Compare Construction Materials &rarr;
              </CardTitle>
              <CardDescription>
                Compare poured concrete, interlocking pavers, and loose gravel quantities based on your project dimensions.
              </CardDescription>
            </div>
            <span class="text-xs font-mono text-neutral-450 dark:text-neutral-500 mt-4 block">Compare: Durability, Lifespan, Maintenance, DIY Difficulty</span>
          </Card>
        </a>
      </div>
    </section>

    <!-- The Moat Section (Highlighting User Experience Value) -->
    <section class="border-t border-neutral-200 dark:border-neutral-800 pt-8 mt-4 grid grid-cols-1 md:grid-cols-2 gap-8 text-sm">
      <div>
        <h3 class="font-bold text-base text-neutral-900 dark:text-neutral-50 mb-2">
          Local Storage Planning Workspace
        </h3>
        <p class="text-neutral-500 dark:text-neutral-400 leading-relaxed text-pretty">
          Tired of typing dimensions repeatedly? Our tools sync with a browser-based memory unit. Save your room, deck, or patio parameters once, and instantly load them in any calculator to check different project configurations.
        </p>
      </div>
      <div>
        <h3 class="font-bold text-base text-neutral-900 dark:text-neutral-50 mb-2">
          Deterministic Formulas & E-E-A-T
        </h3>
        <p class="text-neutral-500 dark:text-neutral-400 leading-relaxed text-pretty">
          All calculations are fully open-source and step-by-step. We list exact mathematical formulas, worked examples, and common construction pitfalls to verify structural safety and order accuracy.
        </p>
      </div>
    </section>
  </div>
</Layout>
