---
import Layout from "../layouts/Layout.astro";
import HeroQuickCalc from "../components/HeroQuickCalc";
import { graphSchema, webSiteSchema, faqPageSchema, webPageSchema } from "../lib/schema";

const SITE_URL = "https://homeplanninghub.com";

const title = "Free Home Improvement Calculators & Project Planning Tools — Plan Every Project With Confidence";
const description = "Plan any home improvement project with free material calculators for concrete, roofing, paint, tile, gravel, and more. Estimate materials, compare options, and build a shopping list before you buy. Open formulas, no sign-up required.";

const concreteCalcs = [
  { href: "/calculators/concrete/slab/", title: "Slab", desc: "Patios, driveways, sidewalks" },
  { href: "/calculators/concrete/footing/", title: "Footing", desc: "Pier holes, deck foundations" },
  { href: "/calculators/concrete/column/", title: "Column", desc: "Round & square columns" },
  { href: "/calculators/concrete/wall/", title: "Wall", desc: "Walls with opening deductions" },
  { href: "/calculators/concrete/tube/", title: "Tube Form", desc: "Sonotubes & cylindrical piers" },
  { href: "/calculators/concrete/steps/", title: "Steps", desc: "Staircases with landings" },
];

const roofingCalcs = [
  { href: "/calculators/roofing/shingles/", title: "Shingles", desc: "Bundles, squares, nails" },
  { href: "/calculators/roofing/metal/", title: "Metal Roof", desc: "Panels, screws, ridge cap" },
  { href: "/calculators/roofing/plywood/", title: "Plywood Deck", desc: "Sheathing sheets & H-clips" },
  { href: "/calculators/roofing/pitch/", title: "Roof Pitch", desc: "Degrees, multiplier, rafter" },
];

const paintCalcs = [
  { href: "/calculators/paint/", title: "Interior Paint", desc: "Gallons for walls & ceilings" },
];

const tileCalcs = [
  { href: "/calculators/tile/", title: "Tile Flooring", desc: "Counts, boxes, patterns" },
];

const moreCalcs = [
  { href: "/calculators/drywall/", title: "Drywall", desc: "Sheets, tape, joint compound" },
  { href: "/calculators/gravel/", title: "Gravel", desc: "Driveways, pathways, drainage" },
  { href: "/calculators/mulch/", title: "Mulch", desc: "Bags, yards, coverage depth" },
  { href: "/calculators/sand/", title: "Sand", desc: "Patio base, paver joints" },
  { href: "/calculators/brick/", title: "Brick & Block", desc: "Wall counts, mortar" },
];

const faqs = [
  { q: "Are these calculators free to use?", a: "Yes. Every calculator on HomePlanningHub is completely free. No sign-up, no paywall, no data collection. Your dimensions are stored locally in your browser and never sent to a server." },
  { q: "What is the formula for calculating concrete?", a: "Concrete volume is calculated by multiplying length (in feet) by width (in feet) by thickness (in feet), then dividing by 27 to convert cubic feet to cubic yards. The formula is: Volume (cu yd) = Length (ft) × Width (ft) × Thickness (ft) ÷ 27. Our concrete calculator handles this automatically and also computes bag counts for 40lb, 60lb, and 80lb mixes." },
  { q: "How much paint do I need for a 12x12 room?", a: "A standard 12x12 foot bedroom with 8-foot ceilings has roughly 320 square feet of wall area after subtracting one door (21 sq ft) and two windows (24 sq ft). One gallon of paint covers about 350 square feet, so a single gallon is usually enough for one coat. Two gallons are recommended for two coats or if painting over a darker color." },
  { q: "How do I calculate square footage of a room?", a: "Measure the length and width of the room in feet, then multiply them: Area = Length × Width. For an L-shaped room, divide it into two rectangles, calculate each area, and add them together. All of our calculators that accept dimensions perform this square footage calculation automatically before applying material-specific formulas." },
  { q: "How accurate are the calculations?", a: "All formulas use standard engineering math: geometric volume calculations, pitch-corrected surface area for roofs, and manufacturer-published bag yields and coverage rates. Every calculator shows its formula and a worked example so you can verify the math yourself. Final quantities should always be compared against the specific products you purchase." },
  { q: "Can I save my project dimensions?", a: "Yes. Use the Save Measurement feature on any calculator to store your room or slab dimensions in-browser via localStorage. Visit the Saved Measurements page to manage and reload them instantly into any calculator. Your data never leaves your device." },
];

const schema = graphSchema(
  webSiteSchema("HomePlanningHub", "Free home improvement calculators and material estimation tools for homeowners and DIY builders."),
  webPageSchema({
    url: SITE_URL,
    topicName: "Home Improvement",
    topicUrl: "https://en.wikipedia.org/wiki/Home_improvement",
  }),
  faqPageSchema(faqs, SITE_URL),
);
---

<Layout title={title} description={description} canonical={SITE_URL} schema={schema}>
  <!-- HERO -->
  <section class="relative overflow-hidden -mx-4 sm:-mx-6 px-4 sm:px-6 -mt-8 md:-mt-12 pt-12 md:pt-20 pb-16">
    <div class="absolute inset-0 bg-grid opacity-50"></div>
    <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div class="flex flex-col gap-6">
        <div class="inline-flex items-center gap-2 self-start px-3 py-1 rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] text-xs font-medium text-[var(--fg-secondary)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--success)]"></span>
          Free project planning tools for homeowners
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-balance leading-[1.05]">
          Plan Every Home Improvement Project With Accurate Material Calculators
        </h1>
        <p class="text-base sm:text-lg text-[var(--fg-secondary)] text-pretty leading-relaxed">
          Stop over-ordering or running short. Whether you are pouring a concrete slab, shingling a roof, painting a bedroom, or laying tile — enter your dimensions once and get precise material counts with open formulas you can verify yourself. No sign-up, no ads, no guesswork.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mt-2">
          <a href="/calculators/concrete/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg bg-[var(--accent)] text-[var(--accent-fg)] hover:bg-[var(--accent-hover)] border border-[var(--accent)] shadow-sm transition-colors active:scale-[0.98]">
            Calculate Your Materials
            <svg class="w-4 h-4 ml-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
          <a href="/planner/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg border border-[var(--border-strong)] text-[var(--fg)] hover:border-[var(--border-hover)] hover:bg-[var(--bg-muted)] transition-colors active:scale-[0.98]">
            Start a Project Plan
          </a>
        </div>
      </div>
      <div class="w-full max-w-md mx-auto lg:max-w-none">
        <HeroQuickCalc client:load />
      </div>
    </div>
  </section>

  <!-- STATS BAR (clickable) -->
  <section class="border-y border-[var(--border)] -mx-4 sm:-mx-6 px-4 sm:px-6 py-6 mb-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
      <details class="group text-center cursor-pointer">
        <summary class="flex flex-col items-center list-none">
          <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--bg-muted)] mb-1 group-open:bg-[var(--accent)] group-open:text-[var(--accent-fg)] transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div class="text-xs font-semibold text-[var(--fg)]">Open Formulas</div>
          <div class="text-[11px] text-[var(--fg-muted)]">Every formula visible</div>
        </summary>
        <p class="text-[11px] text-[var(--fg-secondary)] leading-relaxed mt-2 px-2 text-pretty">Every calculation shows its formula and a worked example. You can verify the math yourself using the provided inputs — no black box.</p>
      </details>
      <details class="group text-center cursor-pointer">
        <summary class="flex flex-col items-center list-none">
          <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--bg-muted)] mb-1 group-open:bg-[var(--accent)] group-open:text-[var(--accent-fg)] transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          </div>
          <div class="text-xs font-semibold text-[var(--fg)]">No Sign-Up</div>
          <div class="text-[11px] text-[var(--fg-muted)]">Start calculating now</div>
        </summary>
        <p class="text-[11px] text-[var(--fg-secondary)] leading-relaxed mt-2 px-2 text-pretty">All calculations happen in your browser. No account, no email, no data collection. Your dimensions never leave your device.</p>
      </details>
      <details class="group text-center cursor-pointer">
        <summary class="flex flex-col items-center list-none">
          <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--bg-muted)] mb-1 group-open:bg-[var(--accent)] group-open:text-[var(--accent-fg)] transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
          </div>
          <div class="text-xs font-semibold text-[var(--fg)]">Mobile Friendly</div>
          <div class="text-[11px] text-[var(--fg-muted)]">Works on any device</div>
        </summary>
        <p class="text-[11px] text-[var(--fg-secondary)] leading-relaxed mt-2 px-2 text-pretty">Responsive layout adapts to phones, tablets, and desktops. Touch-friendly inputs with proper numeric keypad support on mobile browsers.</p>
      </details>
      <details class="group text-center cursor-pointer">
        <summary class="flex flex-col items-center list-none">
          <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--bg-muted)] mb-1 group-open:bg-[var(--accent)] group-open:text-[var(--accent-fg)] transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
          </div>
          <div class="text-xs font-semibold text-[var(--fg)]">Privacy First</div>
          <div class="text-[11px] text-[var(--fg-muted)]">Data stays in browser</div>
        </summary>
        <p class="text-[11px] text-[var(--fg-secondary)] leading-relaxed mt-2 px-2 text-pretty">Your room dimensions and project data are stored in localStorage on your device. Nothing is sent to a server. You can clear your data at any time.</p>
      </details>
    </div>
  </section>

  <!-- CATEGORY HUB CARDS -->
  <section class="mb-12">
    <h2 class="text-xl font-bold tracking-tight mb-6">Choose a project type to get started</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <a href="/calculators/concrete/" class="group relative rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--accent)] hover:bg-[var(--bg-subtle)] transition-all card-elevated overflow-hidden">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-[var(--bg-muted)] flex items-center justify-center shrink-0 group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-fg)] transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16v4H4zM4 10h16v10H4z" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Concrete &amp; Masonry</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed">Slabs, footings, walls, columns, steps, block fill, rebar</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-1.5 group-hover:gap-1.5 transition-all">
              View <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <a href="/calculators/roofing/" class="group relative rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--accent)] hover:bg-[var(--bg-subtle)] transition-all card-elevated overflow-hidden">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-[var(--bg-muted)] flex items-center justify-center shrink-0 group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-fg)] transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12L12 3l9 9M5 10v10h14V10" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Roofing</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed">Shingles, metal, plywood, pitch angle, snow loads, underlayment</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-1.5 group-hover:gap-1.5 transition-all">
              View <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <a href="/calculators/paint/" class="group relative rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--accent)] hover:bg-[var(--bg-subtle)] transition-all card-elevated overflow-hidden">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-[var(--bg-muted)] flex items-center justify-center shrink-0 group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-fg)] transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Paint &amp; Interior</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed">Interior paint, tile floors, drywall, sealant, wall coverage</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-1.5 group-hover:gap-1.5 transition-all">
              View <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <a href="/calculators/tile/" class="group relative rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--accent)] hover:bg-[var(--bg-subtle)] transition-all card-elevated overflow-hidden">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-[var(--bg-muted)] flex items-center justify-center shrink-0 group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-fg)] transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16v16H4z" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Tile &amp; Flooring</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed">Tile counts, box quantities, grid/diagonal/herringbone patterns</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-1.5 group-hover:gap-1.5 transition-all">
              View <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <a href="/maintenance/" class="group relative rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--accent)] hover:bg-[var(--bg-subtle)] transition-all card-elevated overflow-hidden">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-[var(--bg-muted)] flex items-center justify-center shrink-0 group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-fg)] transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Maintenance Planner</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed">Seasonal checklists, cost estimates, home care schedules</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-1.5 group-hover:gap-1.5 transition-all">
              Explore <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
      <a href="/planner/" class="group relative rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--accent)] hover:bg-[var(--bg-subtle)] transition-all card-elevated overflow-hidden">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-[var(--bg-muted)] flex items-center justify-center shrink-0 group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-fg)] transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-bold tracking-tight group-hover:text-[var(--fg)] transition-colors">Project Planner</h3>
            <p class="text-[11px] text-[var(--fg-muted)] mt-0.5 leading-relaxed">Combine calculations, manage materials, build shopping lists</p>
            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[var(--accent)] mt-1.5 group-hover:gap-1.5 transition-all">
              Explore <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Concrete Calculators -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl font-bold tracking-tight">Concrete Calculators</h2>
        <p class="text-sm text-[var(--fg-muted)] mt-0.5">Volume, bag count, and mix ratios for slabs, footings, walls, columns, and steps</p>
      </div>
      <a href="/calculators/concrete/" class="text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] transition-colors flex items-center gap-1 shrink-0">
        View all
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {concreteCalcs.map((calc) => (
        <a href={calc.href} class="group rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-colors">
          <div class="flex items-start justify-between mb-3">
            <div class="w-9 h-9 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center text-[var(--fg-secondary)] group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-fg)] transition-colors">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16v4H4zM4 10h16v10H4z" />
              </svg>
            </div>
          </div>
          <h3 class="text-sm font-semibold tracking-tight group-hover:text-[var(--fg)] transition-colors">{calc.title}</h3>
          <p class="text-xs text-[var(--fg-muted)] mt-0.5 text-pretty break-words">{calc.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Roofing Calculators -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl font-bold tracking-tight">Roofing Calculators</h2>
        <p class="text-sm text-[var(--fg-muted)] mt-0.5">Pitch-corrected material estimates for shingles, metal, plywood, and underlayment</p>
      </div>
      <a href="/calculators/roofing/" class="text-xs font-medium text-[var(--fg-secondary)] hover:text-[var(--fg)] transition-colors flex items-center gap-1 shrink-0">
        View all
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {roofingCalcs.map((calc) => (
        <a href={calc.href} class="group rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-colors">
          <div class="flex items-start justify-between mb-3">
            <div class="w-9 h-9 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center text-[var(--fg-secondary)] group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-fg)] transition-colors">
