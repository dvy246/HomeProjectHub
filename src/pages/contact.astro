---
import Layout from "../layouts/Layout.astro";
import { Button } from "../components/ui/Button";
import { Input } from "../components/ui/Input";

const title = "Contact Us";
const description = "Get in touch with the engineering and support team at HomeProjectHub.";
---

<Layout title={title} description={description}>
  <article class="max-w-3xl mx-auto flex flex-col gap-6 py-4 select-none">
    <header class="border-b border-neutral-150 dark:border-neutral-800 pb-6 mb-2">
      <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900 dark:text-neutral-50 mb-2">
        Contact HomeProjectHub
      </h1>
      <p class="text-sm text-neutral-500 dark:text-neutral-450 leading-relaxed text-pretty">
        Have questions about a calculation, feedback on our tools, or business inquiries? Send us a message.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <!-- Contact Form -->
      <div class="md:col-span-8">
        <form class="flex flex-col gap-4" onsubmit="event.preventDefault(); alert('Message sent! Thank you.');">
          <div class="grid grid-cols-2 gap-4">
            <Input label="Name" type="text" autocomplete="name" required placeholder="e.g. John Doe…" />
            <Input label="Email" type="email" autocomplete="email" required placeholder="e.g. john@example.com…" spellcheck="false" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium text-neutral-600 dark:text-neutral-450 cursor-pointer">Message</label>
            <textarea
              required
              rows={5}
              placeholder="Your inquiry details…"
              class="w-full text-sm bg-transparent border rounded-md p-3 border-neutral-200 dark:border-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:border-black dark:focus:border-white transition-colors"
            ></textarea>
          </div>
          <Button type="submit" variant="primary" className="self-start mt-2">
            Send Message
          </Button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="md:col-span-4 flex flex-col gap-6 text-sm text-neutral-600 dark:text-neutral-400">
        <div>
          <h3 class="font-bold text-neutral-800 dark:text-neutral-200 mb-1">Feedback & Inquiries</h3>
          <p class="text-xs leading-relaxed text-pretty">
            We review suggestions for new calculator tools and mathematical corrections weekly. 
          </p>
        </div>
        <div>
          <h3 class="font-bold text-neutral-800 dark:text-neutral-200 mb-1">Email</h3>
          <p class="text-xs font-mono">support@homeprojecthub.com</p>
        </div>
      </div>
    </div>
  </article>
</Layout>
