---
import Layout from "../layouts/Layout.astro";
import { Button } from "../components/ui/Button";

const title = "Contact Us";
const description = "Get in touch with the engineering and support team at HomeProjectHub.";
---

<Layout title={title} description={description} canonical="https://homeprojecthub.com/contact/">
  <article class="max-w-3xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Contact</span>
    </nav>

    <header class="pb-6 mb-2 border-b border-[var(--border)]">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        Contact HomeProjectHub
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Have questions about a calculation, feedback on our tools, or business inquiries? Send us a message.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <!-- Contact Form -->
      <div class="md:col-span-8">
        <form
          class="flex flex-col gap-4"
          action={import.meta.env.PUBLIC_FORMSPREE_ID ? `https://formspree.io/f/${import.meta.env.PUBLIC_FORMSPREE_ID}` : "https://formspree.io/f/meojvddk"}
          method="POST"
        >
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="name" class="text-xs font-medium text-[var(--fg-secondary)] cursor-pointer">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                autocomplete="name"
                required
                placeholder="e.g. John Doe"
                class="w-full text-sm bg-[var(--bg-inset)] border border-[var(--border)] rounded-lg h-10 px-3 text-[var(--fg)] placeholder:text-[var(--fg-muted)] focus:outline-none focus:border-[var(--border-hover)] focus:bg-[var(--bg)] focus:ring-2 focus:ring-[var(--ring)]/5 transition-colors"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-xs font-medium text-[var(--fg-secondary)] cursor-pointer">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                spellcheck="false"
                placeholder="e.g. john@example.com"
                class="w-full text-sm bg-[var(--bg-inset)] border border-[var(--border)] rounded-lg h-10 px-3 text-[var(--fg)] placeholder:text-[var(--fg-muted)] focus:outline-none focus:border-[var(--border-hover)] focus:bg-[var(--bg)] focus:ring-2 focus:ring-[var(--ring)]/5 transition-colors"
              />
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-xs font-medium text-[var(--fg-secondary)] cursor-pointer">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows={5}
              placeholder="Your inquiry details"
              class="w-full text-sm bg-[var(--bg-subtle)] border border-[var(--border)] rounded-lg p-3 text-[var(--fg)] placeholder:text-[var(--fg-muted)] focus:outline-none focus:border-[var(--border-hover)] focus:bg-[var(--bg)] transition-colors"
            ></textarea>
          </div>
          <Button type="submit" variant="primary" className="self-start mt-2">
            Send Message
          </Button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="md:col-span-4 flex flex-col gap-6 text-sm text-[var(--fg-secondary)]">
        <section>
          <h2 class="font-bold text-[var(--fg)] mb-1 text-sm">Feedback & Inquiries</h2>
          <p class="text-xs leading-relaxed text-pretty">
            We review suggestions for new calculator tools and mathematical corrections weekly.
          </p>
        </section>
        <section>
          <h2 class="font-bold text-[var(--fg)] mb-1 text-sm">Email</h2>
          <p class="text-xs font-mono">support@homeprojecthub.com</p>
        </section>
      </div>
    </div>
  </article>
</Layout>
