---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { graphSchema, articleSchema as articleSchemaFn, breadcrumbListSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const guides = await getCollection("guide");
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const SITE = "https://homeplanninghub.com";
const { guide } = Astro.props;
const { Content } = await render(guide);
const canonical = `${SITE}/guides/${guide.id}/`;
const articleSchema = articleSchemaFn({
  headline: guide.data.title,
  description: guide.data.description,
  author: guide.data.author,
  datePublished: guide.data.pubDate.toISOString(),
  dateModified: guide.data.updatedDate?.toISOString(),
  url: canonical,
});

const schema = graphSchema(
  breadcrumbListSchema([{ name: "Home", path: "/" }, { name: "Guides", path: "/guides/" }, { name: guide.data.title, path: `/guides/${guide.id}/` }]),
  articleSchema,
);

const RELATED_CALCS: Record<string, { href: string; title: string; desc: string }[]> = {
  concrete: [
    { href: "/calculators/concrete/slab/", title: "Concrete Slab Calculator", desc: "Calculate concrete volume for patios, driveways, and slabs." },
    { href: "/calculators/concrete/rebar/", title: "Rebar Calculator", desc: "Estimate rebar grids, length, and weight for concrete slabs." },
  ],
  roofing: [
    { href: "/calculators/roofing/shingles/", title: "Roof Shingle Calculator", desc: "Estimate shingle bundles, squares, and waste for your roof." },
    { href: "/calculators/roofing/metal-roof/", title: "Metal Roofing Calculator", desc: "Calculate metal panels, ridge caps, and screws for metal roofs." },
  ],
  paint: [
    { href: "/calculators/paint/", title: "Paint Calculator", desc: "Estimate paint gallons and cost for walls, ceilings, and trim." },
    { href: "/calculators/square-footage/", title: "Square Footage Calculator", desc: "Calculate total square footage for walls and rectangular rooms." },
  ],
  tile: [
    { href: "/calculators/tile/", title: "Tile Calculator", desc: "Estimate floor and wall tiles, grout volume, and patterns." },
    { href: "/calculators/concrete/slab/", title: "Concrete Slab Calculator", desc: "Calculate concrete subfloor base quantities." },
  ],
  flooring: [
    { href: "/calculators/decking/", title: "Decking Calculator", desc: "Estimate deck boards, fasteners, and joists for decking projects." },
    { href: "/calculators/square-footage/", title: "Square Footage Calculator", desc: "Determine flooring area in square feet or square yards." },
  ],
  general: [
    { href: "/calculators/board-foot/", title: "Board Foot Calculator", desc: "Calculate board footage for dimensional lumber." },
    { href: "/calculators/cubic-yard/", title: "Cubic Yard Calculator", desc: "Convert dimensions directly to cubic yards for gravel, mulch, or dirt." },
  ],
};

const related = RELATED_CALCS[guide.data.category] || RELATED_CALCS.general;

---

<Layout
  title={guide.data.title}
  description={guide.data.description}
  canonical={`${SITE}/guides/${guide.id}/`}
  schema={schema}
  articlePubDate={guide.data.pubDate}
  articleUpdatedDate={guide.data.updatedDate}
>
  <article class="max-w-3xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/guides/" class="hover:text-[var(--fg)] transition-colors">Guides</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">{guide.data.title}</span>
    </nav>

    <header class="pb-6 mb-2 border-b border-[var(--border)]">
      <div class="flex flex-wrap gap-2 mb-3">
        {guide.data.tags.map((tag: string) => (
          <span class="text-[10px] font-mono px-2 py-0.5 rounded-md bg-[var(--bg-muted)] text-[var(--fg-muted)]">{tag}</span>
        ))}
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        {guide.data.title}
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty mb-4">
        {guide.data.description}
      </p>
      <div class="flex items-center gap-3 text-xs text-[var(--fg-muted)]">
        <span>By {guide.data.author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={guide.data.pubDate.toISOString()}>
          {guide.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
      </div>
    </header>

    <div class="text-[var(--fg-secondary)] leading-relaxed [&_h2]:text-lg [&_h2]:font-bold [&_h2]:tracking-tight [&_h2]:text-[var(--fg)] [&_h2]:mt-8 [&_h2]:mb-3 [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-[var(--fg)] [&_h3]:mt-6 [&_h3]:mb-2 [&_p]:mb-4 [&_p]:text-pretty [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mb-4 [&_ul]:flex [&_ul]:flex-col [&_ul]:gap-1.5 [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:mb-4 [&_ol]:flex [&_ol]:flex-col [&_ol]:gap-2 [&_li_ul]:mt-2 [&_li_ol]:mt-2 [&_li_ul]:mb-1 [&_li_ol]:mb-1 [&_strong]:text-[var(--fg)] [&_table]:w-full [&_table]:text-xs [&_table]:text-left [&_table]:border-collapse [&_table]:mb-4 [&_table]:rounded-xl [&_table]:overflow-hidden [&_table]:border [&_table]:border-[var(--border)] [&_th]:py-2.5 [&_th]:px-3 [&_th]:font-semibold [&_th]:text-[var(--fg)] [&_th]:bg-[var(--bg-muted)] [&_th]:border-b [&_th]:border-[var(--border)] [&_td]:py-2.5 [&_td]:px-3 [&_td]:text-[var(--fg-secondary)] [&_td]:border-b [&_td]:border-[var(--border)] [&_tr:last-child_td]:border-b-0 [&_code]:text-xs [&_code]:font-mono [&_code]:bg-[var(--bg-muted)] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_pre]:bg-[var(--bg-muted)] [&_pre]:p-4 [&_pre]:rounded-xl [&_pre]:text-xs [&_pre]:font-mono [&_pre]:mb-4 [&_pre]:overflow-x-auto [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:rounded-none [&_blockquote]:border-l-2 [&_blockquote]:border-[var(--border)] [&_blockquote]:pl-4 [&_blockquote]:text-[var(--fg-muted)] [&_blockquote]:mb-4 [&_blockquote]:italic [&_hr]:border-[var(--border)] [&_hr]:my-8 [&_a]:text-[var(--fg)] [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:text-[var(--accent)] [&_img]:rounded-xl [&_img]:w-full [&_img]:mb-4">
      <Content />
    </div>

    <footer class="pt-8 mt-8 border-t border-[var(--border)]">
      <h4 class="text-xs font-bold uppercase tracking-wider text-[var(--fg-muted)] mb-4">Related Calculators</h4>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {related.map((calc) => (
          <a href={calc.href} class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors">
            <span class="block text-xs font-semibold text-[var(--fg)] mb-1">{calc.title}</span>
            <span class="text-[10px] text-[var(--fg-muted)]">{calc.desc}</span>
          </a>
        ))}
      </div>
    </footer>
  </article>
</Layout>
