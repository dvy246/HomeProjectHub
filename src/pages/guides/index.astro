---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const guides = await getCollection("guide");
const sortedGuides = guides.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Home Improvement Planning Guides";
const description = "Expert guides for concrete, roofing, painting, and home improvement projects. Learn how to calculate materials and plan your next DIY project.";
---

<Layout title={title} description={description} canonical="https://homeplanninghub.com/guides/">
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Guides</span>
    </nav>

    <header class="pb-6 mb-2 border-b border-[var(--border)]">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        Home Improvement Guides
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Practical planning guides to help you estimate materials, compare options, and understand common project tradeoffs. Each guide highlights assumptions, mistakes to avoid, and when to verify details with a local professional.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {sortedGuides.map((guide) => (
        <a
          href={`/guides/${guide.id}/`}
          class="group rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-5 hover:border-[var(--border-hover)] hover:bg-[var(--card-bg-hover)] card-elevated transition-all"
        >
          <div class="flex items-center gap-2 mb-2">
            <span class="text-[10px] font-mono px-2 py-0.5 rounded-md bg-[var(--bg-muted)] text-[var(--fg-muted)] uppercase">
              {guide.data.category}
            </span>
            <span class="text-[10px] text-[var(--fg-muted)]">
              {guide.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short" })}
            </span>
          </div>
          <h2 class="text-sm font-semibold tracking-tight group-hover:text-[var(--fg)] transition-colors mb-1.5">
            {guide.data.title}
          </h2>
          <p class="text-xs text-[var(--fg-secondary)] text-pretty leading-relaxed">
            {guide.data.description}
          </p>
          <div class="flex flex-wrap gap-1.5 mt-3">
            {guide.data.tags.slice(0, 4).map((tag: string) => (
              <span class="text-[10px] px-1.5 py-0.5 rounded bg-[var(--bg-muted)] text-[var(--fg-muted)]">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    {sortedGuides.length === 0 && (
      <div class="rounded-xl border border-dashed border-[var(--border)] p-12 text-center">
        <h4 class="text-sm font-semibold mb-1">No guides yet</h4>
        <p class="text-xs text-[var(--fg-muted)] text-pretty max-w-sm mx-auto">
          Guides are being written. Check back soon for expert planning resources.
        </p>
      </div>
    )}
  </article>
</Layout>
