---
import Layout from "../../../layouts/Layout.astro";
import { graphSchema, webPageSchema, breadcrumbListSchema, faqPageSchema, howToSchema } from "../../../lib/schema";
import { MAINTENANCE_TASKS, CATEGORIES } from "../../../data/maintenance/tasks";

const canonical = "https://homeplanninghub.com/maintenance/fall/";
const title = "Fall Home Maintenance Checklist";
const description = "Complete fall home maintenance checklist. Winterize your home with gutter cleaning, furnace service, weatherstripping, and seasonal safety checks.";
const PAGE_PATH = "/maintenance/fall/";

const fallTasks = MAINTENANCE_TASKS.filter((t) => t.seasons?.includes("fall"));
const categories = [...new Set(fallTasks.map((t) => t.category))];

const schema = graphSchema(
  breadcrumbListSchema([{ name: "Home", path: "/" }, { name: "Home Maintenance", path: "/maintenance/" }, { name: "Fall Maintenance", path: PAGE_PATH }]),
  webPageSchema({ url: canonical, topicName: "Fall Home Maintenance" }),
  howToSchema("Complete fall home maintenance", "Prepare your home for winter with this essential fall checklist covering heating, weatherproofing, and safety.", fallTasks.slice(0, 5).map((t) => ({ name: t.title, text: t.explanation }))),
  faqPageSchema([
    { q: "What fall maintenance prevents winter damage?", a: "Gutter cleaning, roof inspection, weatherstripping, furnace service, and pipe insulation are the most important tasks to prevent winter damage." },
    { q: "When should I winterize my sprinkler system?", a: "Before the first hard freeze. Typically late October to early November depending on your region. Drain all lines and blow out remaining water." },
    { q: "How do I prepare my furnace for winter?", a: "Replace the filter, clean ducts and vents, test the thermostat, inspect the heat exchanger, and schedule a professional tune-up." },
    { q: "Should I clean my gutters in fall?", a: "Yes — fall gutter cleaning is critical after leaves drop. Clogged gutters cause ice dams in winter, which lead to roof leaks and water damage." },
    { q: "What outdoor tasks are essential before winter?", a: "Drain and store garden hoses, winterize sprinklers, seal driveway cracks, trim dead tree branches, and store outdoor furniture." },
  ], canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/maintenance/" class="hover:text-[var(--fg)] transition-colors">Maintenance</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Fall</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Fall Home Maintenance Checklist</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Fall is your last chance to prepare your home for winter before temperatures drop. Use this checklist to winterize your home, prevent freeze damage, and reduce heating costs.</p>

    <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-inset)] p-4 text-sm space-y-2">
      {categories.map((cat) => {
        const catLabel = CATEGORIES.find((c) => c.key === cat)?.label || cat;
        const catTasks = fallTasks.filter((t) => t.category === cat);
        return (
          <details>
            <summary class="text-sm font-semibold cursor-pointer">{catLabel} ({catTasks.length} tasks)</summary>
            <ul class="mt-2 space-y-1.5">
              {catTasks.map((t) => (
                <li class="text-sm text-[var(--fg-secondary)]">{t.title} — <span class="text-[var(--fg-muted)]">{t.explanation}</span></li>
              ))}
            </ul>
          </details>
        );
      })}
    </div>

    <section><h2 id="winter-prep" class="text-xl font-bold mb-3">Winter Preparation Checklist</h2><div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm"><div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><div class="font-semibold mb-1">Heating System</div><p class="text-xs text-[var(--fg-secondary)]">Service furnace, replace filter, test carbon monoxide detectors, inspect chimney if applicable. Consider a programmable thermostat for energy savings.</p></div><div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><div class="font-semibold mb-1">Pipe Protection</div><p class="text-xs text-[var(--fg-secondary)]">Insulate exposed pipes in crawlspaces and attics. Disconnect garden hoses. Know where your main water shutoff valve is located for emergencies.</p></div><div class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><div class="font-semibold mb-1">Draft Prevention</div><p class="text-xs text-[var(--fg-secondary)]">Add weatherstripping to doors and windows. Seal gaps around pipes and vents. Install door sweeps. These tasks pay for themselves in heating savings within one winter.</p></div></div></section>

    <section><h2 id="faq" class="text-xl font-bold mb-3">Frequently Asked Questions</h2><div class="flex flex-col gap-3">
      <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">When should I winterize my home?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Mid-September to mid-November, depending on your climate. Northern regions should start earlier. Complete all outdoor tasks before the first freeze.</p></details>
      <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4"><summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">How do I prevent ice dams?</h3></summary><p class="mt-3 text-sm text-[var(--fg-secondary)]">Clean gutters thoroughly in fall, ensure attic insulation is adequate (R-49 recommended), and improve attic ventilation. Ice dams form when heat escapes through the roof and melts snow.</p></details>
    </div></section>

    <div class="flex gap-4 text-sm">
      <a href="/maintenance/planner/" class="text-[var(--accent)] hover:underline font-semibold">Use the interactive planner →</a>
      <a href="/maintenance/summer/" class="text-[var(--fg-secondary)] hover:text-[var(--fg)] transition-colors">← Summer maintenance</a>
      <a href="/maintenance/winter/" class="text-[var(--fg-secondary)] hover:text-[var(--fg)] transition-colors">Winter maintenance →</a>
    </div>
  </article>
</Layout>
