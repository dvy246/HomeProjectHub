---
import Layout from "../../../layouts/Layout.astro";
import MaintenancePlanner from "../../../components/maintenance/MaintenancePlanner";
import { graphSchema, webPageSchema, breadcrumbListSchema } from "../../../lib/schema";

const canonical = "https://homeplanninghub.com/maintenance/planner/";
const title = "Interactive Home Maintenance Planner";
const description = "Track your home maintenance tasks with an interactive checklist. Monthly, seasonal, and yearly tasks with progress tracking and local storage.";
const PAGE_PATH = "/maintenance/planner/";

const schema = graphSchema(
  breadcrumbListSchema([{ name: "Home", path: "/" }, { name: "Home Maintenance", path: "/maintenance/" }, { name: "Planner", path: PAGE_PATH }]),
  webPageSchema({ url: canonical, topicName: "Home Maintenance Planner" }),
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/maintenance/" class="hover:text-[var(--fg)] transition-colors">Maintenance</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Planner</span>
    </nav>

    <div class="flex items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Interactive Home Maintenance Planner</h1>
        <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl mt-2">Check off completed tasks and track your progress. Your data is saved in your browser — no account needed.</p>
      </div>
      <button onclick="window.print()" class="no-print shrink-0 inline-flex items-center gap-1.5 px-3 py-2 text-xs font-medium rounded-lg border border-[var(--border-strong)] text-[var(--fg)] hover:bg-[var(--bg-muted)] transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 9V3h12v6m4 3v7a2 2 0 01-2 2H4a2 2 0 01-2-2v-7a2 2 0 012-2h16a2 2 0 012 2zM6 14h12M6 18h6" /></svg>
        Print checklist
      </button>
    </div>

    <MaintenancePlanner client:load />

    <div class="flex gap-4 text-sm">
      <a href="/maintenance/cost-estimator/" class="text-[var(--accent)] hover:underline font-semibold">Estimate maintenance costs →</a>
      <a href="/maintenance/" class="text-[var(--fg-secondary)] hover:text-[var(--fg)] transition-colors">← All guides</a>
    </div>
  </article>
</Layout>
