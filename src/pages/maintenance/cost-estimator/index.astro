---
import Layout from "../../../layouts/Layout.astro";
import CostEstimator from "../../../components/maintenance/CostEstimator";
import { graphSchema, webPageSchema, breadcrumbListSchema, faqPageSchema } from "../../../lib/schema";

const canonical = "https://homeplanninghub.com/maintenance/cost-estimator/";
const title = "Home Maintenance Cost Estimator";
const description = "Estimate your annual home maintenance costs based on home size, age, region, and property type. Free interactive budget calculator.";
const PAGE_PATH = "/maintenance/cost-estimator/";

const faqs = [
  {
    q: "How much to budget for home maintenance?",
    a: "As a general rule of thumb, homeowners should budget between 1% and 4% of their home's purchase price annually for maintenance and repairs. For example, on a $300,000 home, this equates to $3,000 to $12,000 per year. The exact amount depends on your home’s age, location, and condition. Older homes (15+ years) or homes in harsh winter climates require a higher percentage (3% to 4%) due to aging roofing, HVAC, and siding. Use our free Home Maintenance Cost Estimator to dynamically model your property's specific annual costs."
  }
];

const schema = graphSchema(
  breadcrumbListSchema([{ name: "Home", path: "/" }, { name: "Home Maintenance", path: "/maintenance/" }, { name: "Cost Estimator", path: PAGE_PATH }]),
  webPageSchema({ url: canonical, topicName: "Home Maintenance Cost Estimator" }),
  faqPageSchema(faqs, canonical)
);
---

<Layout title={title} description={description} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/maintenance/" class="hover:text-[var(--fg)] transition-colors">Maintenance</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Cost Estimator</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance">Home Maintenance Cost Estimator</h1>
    <p class="text-base text-[var(--fg-secondary)] text-pretty max-w-2xl">Understand what your home really costs to maintain. Adjust the factors below for a personalized annual budget estimate.</p>

    <CostEstimator client:visible />

    <section class="max-w-3xl border-t border-[var(--border)] pt-8 mt-6">
      <h2 class="text-xl font-bold tracking-tight mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-3">
        {faqs.map((faq) => (
          <details class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4">
            <summary class="text-sm font-semibold cursor-pointer"><h3 class="text-sm font-semibold m-0">{faq.q}</h3></summary>
            <p class="mt-3 text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

    <div class="flex gap-4 text-sm mt-4">
      <a href="/maintenance/planner/" class="text-[var(--accent)] hover:underline font-semibold">Go to interactive planner →</a>
      <a href="/maintenance/" class="text-[var(--fg-secondary)] hover:text-[var(--fg)] transition-colors">← All guides</a>
    </div>
  </article>
</Layout>
