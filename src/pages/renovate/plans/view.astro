---
import Layout from "../../../layouts/Layout.astro";
import BudgetPlanView from "../../../components/budget/BudgetPlanView";

const title = "Budget Plan";
const description = "View and edit your renovation budget plan with line items and cost tracking.";
---

<Layout title={title} description={description} noindex={true}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/renovate/" class="hover:text-[var(--fg)] transition-colors">Renovate</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/renovate/plans/" class="hover:text-[var(--fg)] transition-colors">Budget Plans</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Plan Detail</span>
    </nav>

    <header class="pb-4 border-b border-[var(--border)]">
      <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-balance">{title}</h1>
      <p class="text-sm text-[var(--fg-muted)] mt-1">{description}</p>
    </header>

    <BudgetPlanView client:visible />
  </article>
</Layout>
