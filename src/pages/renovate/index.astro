---
import Layout from "../../layouts/Layout.astro";

const title = "Renovation Planning Tools";
const description = "Plan and budget your home renovation projects. Free renovation tools, cost planners, and material calculators for homeowners.";
---

<Layout title={title} description={description}>
  <article class="max-w-4xl mx-auto flex flex-col gap-8 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Renovation Planning</span>
    </nav>

    <header class="pb-4 border-b border-[var(--border)]">
      <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-balance">Renovation Planning Tools</h1>
      <p class="text-sm text-[var(--fg-muted)] mt-1">Everything you need to plan, budget, and execute your home renovation projects.</p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2">
      <a href="/renovate/plans/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-6 hover:border-[var(--border-hover)] transition-all group">
        <div class="w-10 h-10 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center mb-4 group-hover:bg-[var(--accent)]/10 transition-colors">
          <svg class="w-5 h-5 text-[var(--fg)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="text-sm font-bold text-[var(--fg)] mb-1">Budget Plans</h2>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed">Create renovation budgets with your own material and labor prices. Track estimated vs. actual costs.</p>
        <span class="inline-flex items-center gap-1 text-xs font-medium text-[var(--accent)] mt-3">Get started <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></span>
      </a>

      <a href="/projects/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-6 hover:border-[var(--border-hover)] transition-all group">
        <div class="w-10 h-10 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center mb-4 group-hover:bg-[var(--accent)]/10 transition-colors">
          <svg class="w-5 h-5 text-[var(--fg)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
        </div>
        <h2 class="text-sm font-bold text-[var(--fg)] mb-1">Project Plans</h2>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed">Plan full projects with linked calculator results, material lists, and shared measurements.</p>
        <span class="inline-flex items-center gap-1 text-xs font-medium text-[var(--accent)] mt-3">View projects <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></span>
      </a>

      <a href="/maintenance/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-6 hover:border-[var(--border-hover)] transition-all group">
        <div class="w-10 h-10 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center mb-4 group-hover:bg-[var(--accent)]/10 transition-colors">
          <svg class="w-5 h-5 text-[var(--fg)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h2 class="text-sm font-bold text-[var(--fg)] mb-1">Maintenance Planner</h2>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed">Seasonal home maintenance checklists, cost estimates, and scheduling calendar.</p>
        <span class="inline-flex items-center gap-1 text-xs font-medium text-[var(--accent)] mt-3">Open planner <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></span>
      </a>

      <a href="/calculators/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-6 hover:border-[var(--border-hover)] transition-all group">
        <div class="w-10 h-10 rounded-lg bg-[var(--bg-muted)] flex items-center justify-center mb-4 group-hover:bg-[var(--accent)]/10 transition-colors">
          <svg class="w-5 h-5 text-[var(--fg)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        </div>
        <h2 class="text-sm font-bold text-[var(--fg)] mb-1">Calculators</h2>
        <p class="text-xs text-[var(--fg-secondary)] leading-relaxed">Browse 48+ home improvement calculators for concrete, roofing, paint, tile, and more.</p>
        <span class="inline-flex items-center gap-1 text-xs font-medium text-[var(--accent)] mt-3">All calculators <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></span>
      </a>
    </div>

    <section class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-6">
      <h2 class="text-sm font-bold mb-3">How to Plan a Renovation</h2>
      <ol class="list-decimal pl-5 flex flex-col gap-2 text-sm text-[var(--fg-secondary)]">
        <li><strong>Measure your space</strong> — use our calculators to determine exact material quantities.</li>
        <li><strong>Research prices</strong> — check Lowe's, Home Depot, or local suppliers for current pricing.</li>
        <li><strong>Create a budget plan</strong> — add each material and labor cost with your own price data.</li>
        <li><strong>Compare options</strong> — use our material comparison tools to find the best fit.</li>
        <li><strong>Track as you go</strong> — update actual costs in your budget plan to stay on target.</li>
      </ol>
    </section>
  </article>
</Layout>
