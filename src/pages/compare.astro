---
import Layout from "../layouts/Layout.astro";
import CompareMaterials from "../components/CompareMaterials";
import AdSlot from "../components/AdSlot.astro";
import { graphSchema, webPageSchema, breadcrumbListSchema } from "../lib/schema";

const canonical = "https://homeprojecthub.com/compare/";
const title = "Compare Patio & Driveway Materials";
const description = "Compare poured concrete, concrete pavers, and pea gravel. Calculate the quantities needed for your dimensions, and compare durability, DIY difficulty, and lifespan.";

const schema = graphSchema(
  breadcrumbListSchema([{ name: "Home", path: "/" }, { name: "Compare", path: "/compare/" }]),
  webPageSchema({ url: canonical, topicName: "Patio and Driveway Material Comparison" }),
);
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Compare</span>
    </nav>

    <header class="pb-6 mb-2 border-b border-[var(--border)]">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        Compare Construction Materials
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Planning a new patio, driveway, or walkway? Enter your project dimensions below to generate a comparison matrix. See the exact quantities needed for poured concrete, pavers, and gravel, alongside critical metrics like lifespan, maintenance needs, and DIY feasibility.
      </p>
    </header>

    <!-- Top Ad Slot -->
    <AdSlot slotId="ad-top-compare" />

    <!-- Interactive Component -->
    <section class="my-4">
      <CompareMaterials client:load />
    </section>

    <!-- Editorial Content for SEO (E-E-A-T) -->
    <section class="border-t border-[var(--border)] pt-8 mt-6 flex flex-col gap-6">
      <div>
        <h2 id="durability-comparison" class="text-lg font-bold tracking-tight mb-3 text-[var(--fg)]">
          Poured Concrete vs. Pavers vs. Pea Gravel
        </h2>
        <p class="text-sm text-[var(--fg-secondary)] leading-relaxed text-pretty">
          Choosing the right material depends on your budget, timescale, aesthetic preference, and structural needs. Here is a summary of how they compare in practice:
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-sm">
        <div>
          <h3 class="font-semibold text-[var(--fg)] mb-1">Poured Concrete</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">
            The most permanent, clean-looking option. It provides a solid foundation suitable for heavy patio furniture and vehicular traffic. However, it requires careful mixing, quick pouring, and is prone to cracking if the ground shifts.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-[var(--fg)] mb-1">Interlocking Pavers</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">
            Very durable and highly modular. Since they are separated by sand joints, they flex naturally with ground movements without cracking. Individual pavers can be replaced easily, making them a great long-term DIY investment.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-[var(--fg)] mb-1">Loose Pea Gravel</h3>
          <p class="text-xs text-[var(--fg-secondary)] leading-relaxed text-pretty">
            The fastest, lowest-cost pathway. It drains stormwater beautifully and offers a rustic look. However, it requires a border border frame, shifting gravel needs regular raking, and it cannot support thin-legged chairs.
          </p>
        </div>
      </div>
    </section>

    <!-- Secondary Ad Slot -->
    <AdSlot slotId="ad-bottom-compare" />
  </article>
</Layout>
