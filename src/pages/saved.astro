---
import Layout from "../layouts/Layout.astro";
import SavedRoomsDashboard from "../components/SavedRoomsDashboard";

const title = "My Saved Rooms & Projects";
const description = "Manage your saved room, deck, and patio dimensions. Load them directly into any of our calculators to compare materials instantly.";
---

<Layout title={title} description={description}>
  <meta name="robots" content="noindex, follow" />
  <article class="max-w-4xl mx-auto flex flex-col gap-6 py-4">
    <nav class="flex items-center gap-1.5 text-xs text-[var(--fg-muted)] mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">Home</a>
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-[var(--fg-secondary)] font-medium">Saved</span>
    </nav>

    <header class="pb-6 mb-2 border-b border-[var(--border)]">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-balance mb-3 text-[var(--fg)]">
        Saved Measurements Workspace
      </h1>
      <p class="text-base text-[var(--fg-secondary)] leading-relaxed text-pretty">
        Review your saved rooms, foundations, and excavation measurements. These are stored locally in your browser cache (localStorage) and never leave your machine.
      </p>
    </header>

    <!-- Interactive Component -->
    <section class="my-4">
      <SavedRoomsDashboard client:load />
    </section>
  </article>
</Layout>
