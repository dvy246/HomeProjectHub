---
import Layout from "../layouts/Layout.astro";

const title = "Page Not Found";
const description = "The page you are looking for does not exist. Try one of our free home improvement calculators instead.";
---

<Layout title={title} description={description} noindex={true}>
  <div class="max-w-3xl mx-auto flex flex-col items-center text-center gap-8 py-10 md:py-16">
    <div class="text-8xl font-extrabold tracking-tight text-[var(--fg-muted)] leading-none">404</div>
    <div class="space-y-2">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-[var(--fg)]">Page Not Found</h1>
      <p class="text-sm text-[var(--fg-secondary)] max-w-md mx-auto text-pretty">
        The page you are looking for may have been moved, renamed, or deleted. Try searching for what you need below.
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-3">
      <a href="/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg bg-[var(--accent)] text-[var(--accent-fg)] border border-[var(--accent)] hover:opacity-90 transition-all">
        Go Home
      </a>
      <a href="/calculators/concrete/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg border border-[var(--border-strong)] text-[var(--fg)] hover:border-[var(--border-hover)] hover:bg-[var(--bg-muted)] transition-all">
        Browse All Calculators
      </a>
      <a href="/guides/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg border border-[var(--border-strong)] text-[var(--fg)] hover:border-[var(--border-hover)] hover:bg-[var(--bg-muted)] transition-all">
        Browse Guides
      </a>
    </div>

    <div class="w-full border-t border-[var(--border)] pt-8 mt-4">
      <h2 class="text-base font-semibold text-[var(--fg)] mb-4">Popular Calculators</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <a href="/calculators/concrete/slab/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Concrete Slab</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Volume, bags, weight</span>
        </a>
        <a href="/calculators/roofing/shingles/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Roof Shingles</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Bundles, squares</span>
        </a>
        <a href="/calculators/paint/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Paint</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Gallons, coats</span>
        </a>
        <a href="/calculators/tile/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Tile</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Floor layouts</span>
        </a>
      </div>
    </div>

    <div class="w-full border-t border-[var(--border)] pt-8">
      <h2 class="text-base font-semibold text-[var(--fg)] mb-4">Latest Planning Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/guides/concrete-volume-guide/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">How to Calculate Concrete Volume</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Formulas, examples, and pro tips</span>
        </a>
        <a href="/guides/slab-preparation-guide/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Concrete Slab Preparation</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Subgrade, forms, reinforcement</span>
        </a>
        <a href="/guides/paint-estimating-guide/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">How to Estimate Paint Coverage</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Paint quantities for any room</span>
        </a>
        <a href="/guides/tile-installation-guide/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">How to Estimate Tile Quantities</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Pattern waste, grout, pro tips</span>
        </a>
      </div>
    </div>
  </div>
</Layout>
