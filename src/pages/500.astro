---
import Layout from "../layouts/Layout.astro";

const title = "Server Error";
const description = "Something went wrong on our end. Please try again or contact us.";
---

<Layout title={title} description={description} noindex={true}>
  <div class="max-w-2xl mx-auto flex flex-col items-center text-center gap-8 py-10 md:py-16">
    <div class="text-8xl font-extrabold tracking-tight text-[var(--fg-muted)] leading-none">500</div>
    <div class="space-y-2">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-[var(--fg)]">Server Error</h1>
      <p class="text-sm text-[var(--fg-secondary)] max-w-md mx-auto text-pretty">
        Something went wrong on our end. This has been logged and we will look into it. In the meantime, try one of our calculators below.
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-3">
      <a href="/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg bg-[var(--accent)] text-[var(--accent-fg)] border border-[var(--accent)] hover:opacity-90 transition-all">
        Go Home
      </a>
      <a href="/contact/" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium rounded-lg border border-[var(--border-strong)] text-[var(--fg)] hover:border-[var(--border-hover)] hover:bg-[var(--bg-muted)] transition-all">
        Report a Problem
      </a>
    </div>

    <div class="w-full border-t border-[var(--border)] pt-8 mt-4">
      <h2 class="text-base font-semibold text-[var(--fg)] mb-4">Try These Popular Tools</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <a href="/calculators/concrete/slab/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Concrete Slab</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Volume, bags, weight</span>
        </a>
        <a href="/calculators/concrete/footing/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Concrete Footing</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Deck post footings</span>
        </a>
        <a href="/calculators/roofing/shingles/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Roof Shingles</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Bundles and squares</span>
        </a>
        <a href="/calculators/paint/" class="rounded-xl border border-[var(--border)] bg-[var(--card-bg)] p-4 hover:border-[var(--border-hover)] transition-colors text-left">
          <span class="block text-xs font-semibold text-[var(--fg)] mb-0.5">Paint</span>
          <span class="text-[10px] text-[var(--fg-muted)] leading-snug block">Gallons and coats</span>
        </a>
      </div>
    </div>

    <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-subtle)] p-5 text-left w-full">
      <h3 class="text-xs font-semibold text-[var(--fg)] mb-1">Still having issues?</h3>
      <p class="text-xs text-[var(--fg-muted)] leading-relaxed text-pretty">
        If this error persists, <a href="/contact/" class="underline underline-offset-2 hover:no-underline">contact our support team</a> with details about what you were doing when the error occurred.
      </p>
    </div>
  </div>
</Layout>
